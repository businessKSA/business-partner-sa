    {
      "parameters": {
        "content": "### ⚠️ التحقق من الاشتراك — placeholder\nحالياً يقرأ العلم subscription_active من الطلب نفسه. قبل الإطلاق: استبدله بعقدة Notion/CRM تبحث عن subscriber_id وتتحقق أن الاشتراك فعّال (فرد أو منشأة) وتجيب صلاحياته. عزل بيانات المشتركين إلزامي.",
        "height": 200,
        "width": 320
      },
      "id": "sticky-subscription",
      "name": "Sticky Note — Subscription Check",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [80, 420]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
