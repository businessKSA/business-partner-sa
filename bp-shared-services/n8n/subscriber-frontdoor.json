          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-active",
      "name": "Active Subscriber?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [380, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'subscription_required', reply: 'أهلاً بك. هذه الخدمة متاحة لمشتركي المكتب الافتراضي. فريق المبيعات يوصلك عرض اشتراك رسمي بعد الاعتماد — أرسل بياناتك ونتواصل معك.' }) }}",
        "options": {}
      },
      "id": "respond-no-sub",
      "name": "Respond — Subscription Required",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [620, 420]
