---
import '../../styles/global.css';
export const prerender = true;
const API_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/bp3-portal-9kq4z';
const CHAT_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/05804653-e4bf-465c-aa1f-69773ea1f86d/chat';
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>لوحة العميل | وكيل الامتثال — شريك الأعمال</title>
  <style>
    :root{ --navy:#0B1B5A; --brand:#0066cc; --gold:#C79A3A; --red:#dc2626; --yellow:#d97706; --green:#16a34a; }
    body{ padding-top:0; background:#f2f4f9; min-height:100vh; }
    .wrap{ max-width:1080px; margin-inline:auto; padding:1.2rem; }
    /* ---- login ---- */
    #login-screen{ min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; background:linear-gradient(150deg,#0B1B5A 0%,#12307f 60%,#0066cc 130%); }
    .login-card{ background:#fff; border-radius:20px; padding:2rem; width:100%; max-width:400px; box-shadow:0 20px 50px rgba(0,0,0,.25); }
    .login-card img{ height:36px; margin-bottom:.6rem; }
    .login-card h1{ font-size:1.35rem; color:var(--navy); margin-bottom:.3rem; }
    .login-card p{ color:#667; font-size:.9rem; margin-bottom:1.2rem; }
    .field{ margin-bottom:.9rem; display:flex; flex-direction:column; gap:.3rem; }
    .field label{ font-size:.85rem; font-weight:600; color:#334; }
    .field input{ border:1px solid #cfd8e6; border-radius:10px; padding:.75rem .9rem; font:inherit; }
    .field input:focus{ outline:2px solid #bcd2ff; border-color:var(--brand); }
    .btn{ border:0; border-radius:12px; padding:.85rem; font-weight:700; cursor:pointer; width:100%; font-size:1rem; }
    .btn-navy{ background:var(--navy); color:#fff; }
    .login-err{ color:#b3261e; background:#fdecec; border-radius:8px; padding:.6rem .8rem; font-size:.85rem; margin-top:.8rem; display:none; }
    .hint{ font-size:.78rem; color:#8a94a6; margin-top:1rem; text-align:center; }
    /* ---- dashboard ---- */
    #dash{ display:none; }
    header.top{ background:var(--navy); color:#fff; padding:1.1rem 0; }
    header.top .wrap{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.6rem; }
    header.top .brand{ display:flex; align-items:center; gap:.5rem; font-weight:700; }
    header.top .brand img{ height:26px; }
    .logout{ background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.3); color:#fff; padding:.4rem .9rem; border-radius:8px; font-size:.85rem; cursor:pointer; }
    .grid{ display:grid; gap:1rem; }
    .cols-3{ grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); }
    .card{ background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1.1rem 1.3rem; box-shadow:0 8px 24px rgba(11,27,90,.05); }
    .score-card{ display:flex; align-items:center; gap:1.2rem; }
    .score-ring{ width:92px; height:92px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.5rem; font-weight:800; color:#fff; flex-shrink:0; }
    .score-meta h2{ font-size:1.5rem; color:var(--navy); }
    .score-meta div{ color:#667; font-size:.9rem; }
    .stat{ text-align:center; }
    .stat .n{ font-size:1.8rem; font-weight:800; }
    .stat.red .n{ color:var(--red); } .stat.yellow .n{ color:var(--yellow); } .stat.green .n{ color:var(--green); }
    .stat .l{ color:#667; font-size:.85rem; margin-top:.2rem; }
    h3.sec{ font-size:1.1rem; color:var(--navy); margin:1.6rem 0 .7rem; }
    .alert-row{ display:flex; gap:.7rem; align-items:flex-start; padding:.8rem 0; border-bottom:1px solid #eef1f6; }
    .alert-row:last-child{ border-bottom:0; }
    .dot{ width:10px; height:10px; border-radius:50%; margin-top:.4rem; flex-shrink:0; }
    .dot.red{ background:var(--red); } .dot.yellow{ background:var(--yellow); } .dot.green{ background:var(--green); }
    .alert-row .t{ font-weight:700; color:#222; }
    .alert-row .m{ color:#667; font-size:.85rem; margin-top:.15rem; }
    table.reg{ width:100%; border-collapse:collapse; font-size:.9rem; }
    table.reg th{ text-align:right; color:#667; font-weight:600; padding:.5rem .4rem; border-bottom:2px solid #eef1f6; font-size:.82rem; }
    table.reg td{ padding:.6rem .4rem; border-bottom:1px solid #f1f3f8; }
    .badge{ display:inline-block; padding:.15rem .55rem; border-radius:999px; font-size:.78rem; font-weight:700; }
    .badge.d0{ background:#fee2e2; color:#991b1b; } .badge.d7{ background:#ffedd5; color:#9a3412; } .badge.d30{ background:#fef9c3; color:#854d0e; } .badge.dok{ background:#dcfce7; color:#166534; }
    .empty{ color:#8a94a6; font-size:.9rem; padding:.6rem 0; }
    /* chat */
    #chat-toggle{ position:fixed; bottom:1.2rem; left:1.2rem; background:var(--gold); color:#221a00; border:0; border-radius:999px; padding:.8rem 1.3rem; font-weight:700; box-shadow:0 8px 20px rgba(0,0,0,.25); cursor:pointer; z-index:50; }
    #chat-frame-wrap{ position:fixed; bottom:5rem; left:1.2rem; width:min(380px,92vw); height:min(560px,70vh); border-radius:16px; overflow:hidden; box-shadow:0 20px 50px rgba(0,0,0,.3); display:none; z-index:50; background:#fff; }
    #chat-frame-wrap iframe{ width:100%; height:100%; border:0; }
    .err-banner{ background:#fdecec; color:#b3261e; border-radius:10px; padding:.8rem 1rem; margin-bottom:1rem; display:none; }
    @media(max-width:640px){ .score-card{ flex-direction:column; text-align:center; } }
  </style>
</head>
<body>
  <div id="login-screen">
    <form class="login-card" id="login-form">
      <img src="/logo.svg" alt="" />
      <h1>لوحة الامتثال</h1>
      <p>ادخل باسم منشأتك ورمز الدخول المرسل لك لمتابعة حالة الامتثال يومياً.</p>
      <div class="field"><label>اسم المنشأة</label><input type="text" id="in-company" required autocomplete="organization" /></div>
      <div class="field"><label>رمز الدخول</label><input type="text" id="in-code" required autocomplete="off" /></div>
      <button type="submit" class="btn btn-navy" id="login-btn">دخول</button>
      <div class="login-err" id="login-err"></div>
      <div class="hint">ما عندك رمز دخول؟ تواصل معنا واتساب لتفعيل اشتراكك.</div>
    </form>
  </div>

  <div id="dash">
    <header class="top">
      <div class="wrap">
        <div class="brand"><img src="/logo.svg" alt="" /><span>لوحة الامتثال — شريك الأعمال</span></div>
        <button class="logout" id="logout-btn">تسجيل الخروج</button>
      </div>
    </header>
    <div class="wrap">
      <div class="err-banner" id="dash-err"></div>

      <div class="card score-card">
        <div class="score-ring" id="score-ring">--</div>
        <div class="score-meta">
          <h2 id="company-name">—</h2>
          <div id="score-band">—</div>
          <div id="last-analysis" style="font-size:.8rem;color:#9aa3b2;margin-top:.3rem;"></div>
        </div>
      </div>

      <div class="grid cols-3" style="margin-top:1rem">
        <div class="card stat red"><div class="n" id="cnt-red">0</div><div class="l">🔴 حرجة</div></div>
        <div class="card stat yellow"><div class="n" id="cnt-yellow">0</div><div class="l">🟡 متوسطة</div></div>
        <div class="card stat green"><div class="n" id="cnt-green">0</div><div class="l">🟢 منخفضة</div></div>
      </div>

      <h3 class="sec">🚨 التنبيهات</h3>
      <div class="card" id="alerts-list"><div class="empty">جارٍ التحميل...</div></div>

      <h3 class="sec">⏳ البنود والاستحقاقات</h3>
      <div class="card">
        <table class="reg">
          <thead><tr><th>المنصة</th><th>الموظف/الموضوع</th><th>نوع الإجراء</th><th>تاريخ الانتهاء</th><th>الأيام</th></tr></thead>
          <tbody id="reg-body"><tr><td colspan="5" class="empty">جارٍ التحميل...</td></tr></tbody>
        </table>
      </div>

      <h3 class="sec">💰 التكلفة الحكومية التقديرية</h3>
      <div class="grid cols-3">
        <div class="card"><div style="color:#667;font-size:.85rem">ربعياً</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="cost-q">—</div></div>
        <div class="card"><div style="color:#667;font-size:.85rem">سنوياً</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="cost-a">—</div></div>
        <div class="card"><div style="color:#667;font-size:.85rem">الموظفون / السعوديون</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="emp-info">—</div></div>
      </div>
      <div style="height:5rem"></div>
    </div>
  </div>

  <button id="chat-toggle">💬 اسأل وكيل الامتثال</button>
  <div id="chat-frame-wrap"><iframe src={CHAT_URL} title="وكيل الامتثال"></iframe></div>

  <script define:vars={{ API_URL }}>
    const loginScreen = document.getElementById('login-screen');
    const dash = document.getElementById('dash');
    const loginForm = document.getElementById('login-form');
    const loginErr = document.getElementById('login-err');
    const loginBtn = document.getElementById('login-btn');
    const dashErr = document.getElementById('dash-err');

    function riskDot(r){ return r === 'أحمر' ? 'red' : (r === 'أصفر' ? 'yellow' : 'green'); }
    function dayBadge(d){
      if (d === null || d === undefined) return '<span class="badge dok">—</span>';
      if (d <= 0) return '<span class="badge d0">منتهي</span>';
      if (d <= 7) return '<span class="badge d0">' + d + ' يوم</span>';
      if (d <= 30) return '<span class="badge d7">' + d + ' يوم</span>';
      return '<span class="badge dok">' + d + ' يوم</span>';
    }
    function fmtMoney(n){ return (typeof n === 'number') ? n.toLocaleString('ar-SA') + ' ريال' : '—'; }

    function render(data) {
      document.getElementById('company-name').textContent = data.company || '—';
      const ring = document.getElementById('score-ring');
      const score = typeof data.healthScore === 'number' ? data.healthScore : 0;
      ring.textContent = score;
      ring.style.background = score >= 85 ? 'linear-gradient(135deg,#16a34a,#22c55e)' : score >= 65 ? 'linear-gradient(135deg,#0066cc,#3b82f6)' : score >= 40 ? 'linear-gradient(135deg,#d97706,#f59e0b)' : 'linear-gradient(135deg,#dc2626,#ef4444)';
      document.getElementById('score-band').textContent = 'الحالة: ' + (data.healthBand || '—') + (data.status ? (' · ' + data.status) : '');
      document.getElementById('last-analysis').textContent = data.lastAnalysis ? ('آخر تحليل: ' + data.lastAnalysis) : '';

      const c = data.counts || {};
      document.getElementById('cnt-red').textContent = c.red || 0;
      document.getElementById('cnt-yellow').textContent = c.yellow || 0;
      document.getElementById('cnt-green').textContent = c.green || 0;

      const alertsEl = document.getElementById('alerts-list');
      const alerts = data.alerts || [];
      alertsEl.innerHTML = alerts.length ? alerts.map(a =>
        '<div class="alert-row"><div class="dot ' + riskDot(a.risk) + '"></div><div><div class="t">' + (a.title || '') + '</div><div class="m">' +
        (a.platform || '') + (a.daysRemaining !== null && a.daysRemaining !== undefined ? ' · ' + a.daysRemaining + ' يوم متبقٍ' : '') +
        (a.action ? (' · ' + a.action) : '') + (a.approval ? (' · ' + a.approval) : '') + '</div></div></div>'
      ).join('') : '<div class="empty">لا توجد تنبيهات حالياً ✅</div>';

      const regBody = document.getElementById('reg-body');
      const reg = data.register || [];
      regBody.innerHTML = reg.length ? reg.map(r =>
        '<tr><td>' + (r.platform || '—') + '</td><td>' + (r.subject || '—') + '</td><td>' + (r.actionType || '—') + '</td><td>' +
        (r.expiry || '—') + '</td><td>' + dayBadge(r.daysRemaining) + '</td></tr>'
      ).join('') : '<tr><td colspan="5" class="empty">لا توجد بنود مسجّلة بعد</td></tr>';

      document.getElementById('cost-q').textContent = fmtMoney(data.quarterlyCost);
      document.getElementById('cost-a').textContent = fmtMoney(data.annualCost);
      document.getElementById('emp-info').textContent = (data.employees ?? '—') + ' / ' + (data.saudis ?? '—') + (data.band ? (' (' + data.band + ')') : '');
    }

    async function loadDashboard(company, code) {
      const url = API_URL + '?company=' + encodeURIComponent(company) + '&code=' + encodeURIComponent(code);
      const res = await fetch(url);
      if (res.status === 401) throw new Error('unauthorized');
      const data = await res.json();
      if (!data || data.ok === false) throw new Error(data && data.error || 'error');
      return data;
    }

    function showDash(company, code) {
      loginScreen.style.display = 'none';
      dash.style.display = 'block';
      loadDashboard(company, code).then(render).catch(() => {
        dashErr.textContent = 'تعذّر تحميل البيانات. جرّب تسجيل الخروج والدخول من جديد.';
        dashErr.style.display = 'block';
      });
    }

    loginForm.addEventListener('submit', function (e) {
      e.preventDefault();
      const company = document.getElementById('in-company').value.trim();
      const code = document.getElementById('in-code').value.trim();
      if (!company || !code) return;
      loginBtn.disabled = true; loginBtn.textContent = '...جارٍ الدخول';
      loginErr.style.display = 'none';
      loadDashboard(company, code).then(function (data) {
        localStorage.setItem('bp_portal_company', company);
        localStorage.setItem('bp_portal_code', code);
        loginScreen.style.display = 'none';
        dash.style.display = 'block';
        render(data);
      }).catch(function () {
        loginErr.textContent = 'اسم المنشأة أو رمز الدخول غير صحيح.';
        loginErr.style.display = 'block';
      }).finally(function () {
        loginBtn.disabled = false; loginBtn.textContent = 'دخول';
      });
    });

    document.getElementById('logout-btn').addEventListener('click', function () {
      localStorage.removeItem('bp_portal_company');
      localStorage.removeItem('bp_portal_code');
      dash.style.display = 'none';
      loginScreen.style.display = 'flex';
    });

    const chatToggle = document.getElementById('chat-toggle');
    const chatWrap = document.getElementById('chat-frame-wrap');
    chatToggle.addEventListener('click', function () {
      chatWrap.style.display = chatWrap.style.display === 'block' ? 'none' : 'block';
    });

    (function init() {
      const c = localStorage.getItem('bp_portal_company');
      const k = localStorage.getItem('bp_portal_code');
      if (c && k) showDash(c, k);
    })();
  </script>
</body>
</html>
