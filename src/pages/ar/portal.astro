---
import '../../styles/global.css';
export const prerender = true;
const API_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/bp3-portal-9kq4z';
const CHAT_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/05804653-e4bf-465c-aa1f-69773ea1f86d/chat';
const INTAKE_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/client-intake-web';
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <title>لوحة العميل | وكيل الامتثال — شريك الأعمال</title>
  <link href="https://cdn.jsdelivr.net/npm/@n8n/chat/dist/style.css" rel="stylesheet" />
  <style>
    :root{ --navy:#0B1B5A; --brand:#0066cc; --gold:#C79A3A; --red:#dc2626; --yellow:#d97706; --green:#16a34a; --gray:#6b7280; }
    body{ padding-top:0; background:#eef1f7; min-height:100vh; }
    .wrap{ max-width:1080px; margin-inline:auto; padding:1.2rem; }
    /* ---- login ---- */
    #login-screen, #locked-screen{ min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; background:linear-gradient(150deg,#0B1B5A 0%,#12307f 60%,#0066cc 130%); }
    .login-card{ background:#fff; border-radius:20px; padding:2rem; width:100%; max-width:400px; box-shadow:0 20px 50px rgba(0,0,0,.25); }
    .login-card img{ height:36px; margin-bottom:.6rem; }
    .login-card h1{ font-size:1.35rem; color:var(--navy); margin-bottom:.3rem; }
    .login-card p{ color:#667; font-size:.9rem; margin-bottom:1.2rem; }
    .field{ margin-bottom:.9rem; display:flex; flex-direction:column; gap:.3rem; }
    .field label{ font-size:.85rem; font-weight:600; color:#334; }
    .field input{ border:1px solid #cfd8e6; border-radius:10px; padding:.75rem .9rem; font:inherit; }
    .field input:focus{ outline:2px solid #bcd2ff; border-color:var(--brand); }
    .btn{ border:0; border-radius:12px; padding:.75rem 1rem; font-weight:700; cursor:pointer; font-size:.95rem; }
    .btn-block{ width:100%; padding:.85rem; }
    .btn-navy{ background:var(--navy); color:#fff; }
    .btn-ghost-light{ background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.35); color:#fff; }
    .login-err{ color:#b3261e; background:#fdecec; border-radius:8px; padding:.6rem .8rem; font-size:.85rem; margin-top:.8rem; display:none; }
    .hint{ font-size:.78rem; color:#8a94a6; margin-top:1rem; text-align:center; }
    /* ---- dashboard shell ---- */
    #dash{ display:none; }
    header.top{ background:var(--navy); color:#fff; padding:1rem 0; position:sticky; top:0; z-index:40; }
    header.top .wrap{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.6rem; padding-block:0; }
    header.top .brand{ display:flex; align-items:center; gap:.5rem; font-weight:700; }
    header.top .brand img{ height:24px; }
    header.top .actions{ display:flex; gap:.5rem; align-items:center; }
    .icon-btn{ background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.3); color:#fff; padding:.45rem .9rem; border-radius:8px; font-size:.82rem; cursor:pointer; }
    /* tabs */
    .tabs{ display:flex; gap:.3rem; background:#fff; border-radius:14px; padding:.35rem; box-shadow:0 4px 14px rgba(11,27,90,.06); margin:1rem 0; overflow-x:auto; }
    .tab{ border:0; background:transparent; padding:.6rem 1rem; border-radius:10px; font-weight:700; font-size:.88rem; color:#5b6472; cursor:pointer; white-space:nowrap; }
    .tab.active{ background:var(--navy); color:#fff; }
    .panel{ display:none; }
    .panel.active{ display:block; }
    /* cards */
    .grid{ display:grid; gap:1rem; }
    .cols-3{ grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); }
    .cols-auto{ grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); }
    .card{ background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1.1rem 1.3rem; box-shadow:0 6px 18px rgba(11,27,90,.05); }
    .score-card{ display:flex; align-items:center; gap:1.2rem; }
    .score-ring{ width:88px; height:88px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.45rem; font-weight:800; color:#fff; flex-shrink:0; }
    .score-meta h2{ font-size:1.35rem; color:var(--navy); }
    .score-meta div{ color:#667; font-size:.88rem; }
    .stat{ text-align:center; padding:.9rem; }
    .stat .n{ font-size:1.7rem; font-weight:800; }
    .stat.red .n{ color:var(--red); } .stat.yellow .n{ color:var(--yellow); } .stat.green .n{ color:var(--green); }
    .stat .l{ color:#667; font-size:.82rem; margin-top:.2rem; }
    /* quick-glance overview tiles */
    .qgrid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:.9rem; margin-top:1.2rem; }
    .qtile{ background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1.1rem .8rem; text-align:center; box-shadow:0 6px 16px rgba(11,27,90,.05); }
    .qicon{ width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; margin:0 auto .6rem; }
    .qicon.red{ background:#fee2e2; } .qicon.yellow{ background:#ffedd5; } .qicon.green{ background:#dcfce7; }
    .qicon.blue{ background:#e0edff; } .qicon.gold{ background:#faf1dc; } .qicon.navy{ background:#e7eaf6; }
    .qn{ font-size:1.5rem; font-weight:800; color:#222; }
    .qn.small{ font-size:1.05rem; }
    .ql{ color:#8a94a6; font-size:.8rem; margin-top:.25rem; }
    h3.sec{ font-size:1.02rem; color:var(--navy); margin:0 0 .8rem; display:flex; align-items:center; gap:.4rem; }
    .filter-chip{ display:inline-flex; align-items:center; gap:.4rem; background:#eef2fb; color:var(--navy); border-radius:999px; padding:.3rem .8rem; font-size:.82rem; font-weight:700; margin-bottom:.8rem; }
    .filter-chip button{ background:none; border:0; color:var(--navy); cursor:pointer; font-weight:800; }
    /* entity grid */
    .entity{ background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1rem; box-shadow:0 6px 18px rgba(11,27,90,.05); cursor:pointer; transition:transform .12s, box-shadow .12s; text-align:right; }
    .entity:hover{ transform:translateY(-2px); box-shadow:0 10px 26px rgba(11,27,90,.1); }
    .entity .icon{ width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.5rem; background:#eef2fb; margin-bottom:.6rem; }
    .entity .badge-logo{ width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:.6rem; color:#fff; font-weight:800; font-size:.72rem; line-height:1.15; text-align:center; padding:.2rem; box-shadow:inset 0 0 0 1px rgba(255,255,255,.25); }
    .entity .badge-logo svg{ width:26px; height:26px; display:block; }
    .calc-card{ display:flex; align-items:center; gap:.9rem; background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1rem 1.2rem; text-decoration:none; box-shadow:0 6px 18px rgba(11,27,90,.05); transition:transform .12s; }
    .calc-card:hover{ transform:translateY(-2px); }
    .calc-card .cicon{ width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; background:#eef2fb; flex-shrink:0; }
    .calc-card .ct{ font-weight:700; color:#222; font-size:.96rem; }
    .calc-card .cd{ color:#8a94a6; font-size:.8rem; margin-top:.15rem; }
    .calc-card .go{ margin-inline-start:auto; color:var(--navy); font-weight:800; }
    .entity .label{ font-weight:700; color:#222; font-size:.94rem; }
    .entity .authority{ color:#8a94a6; font-size:.76rem; margin-top:.1rem; }
    .entity .status{ margin-top:.6rem; font-size:.78rem; font-weight:700; padding:.2rem .55rem; border-radius:999px; display:inline-block; }
    .status.ok{ background:#dcfce7; color:#166534; }
    .status.warn{ background:#ffedd5; color:#9a3412; }
    .status.crit{ background:#fee2e2; color:#991b1b; }
    .status.nodata{ background:#f1f3f8; color:#8a94a6; }
    .entity .api-note{ font-size:.7rem; color:#b3bac7; margin-top:.4rem; }
    /* alerts/register — email-style table */
    .alert-table-wrap{ overflow-x:auto; }
    table.alert-table{ width:100%; border-collapse:separate; border-spacing:0 .5rem; font-size:.88rem; }
    table.alert-table tr.arow{ background:#fbfcfe; }
    table.alert-table tr.arow.risk-red{ background:#fff1f1; }
    table.alert-table tr.arow.risk-yellow{ background:#fffaf0; }
    table.alert-table tr.arow.risk-green{ background:#f2fbf5; }
    table.alert-table td{ padding:.6rem .55rem; vertical-align:middle; border-top:1px solid rgba(0,0,0,.04); border-bottom:1px solid rgba(0,0,0,.04); }
    table.alert-table tr.arow td:first-child{ border-inline-start:4px solid transparent; border-start-start-radius:10px; border-end-start-radius:10px; }
    table.alert-table tr.arow.risk-red td:first-child{ border-inline-start-color:var(--red); }
    table.alert-table tr.arow.risk-yellow td:first-child{ border-inline-start-color:var(--yellow); }
    table.alert-table tr.arow.risk-green td:first-child{ border-inline-start-color:var(--green); }
    table.alert-table tr.arow td:last-child{ border-start-end-radius:10px; border-end-end-radius:10px; }
    .risk-emoji{ font-size:1rem; }
    .platform-chip{ display:inline-block; color:#fff; font-weight:700; font-size:.74rem; padding:.22rem .6rem; border-radius:999px; white-space:nowrap; }
    .alert-table .t{ font-weight:700; color:#222; font-size:.9rem; overflow-wrap:anywhere; }
    .alert-table .m{ color:#667; font-size:.8rem; margin-top:.1rem; overflow-wrap:anywhere; }
    table.reg{ width:100%; border-collapse:collapse; font-size:.88rem; }
    table.reg th{ text-align:right; color:#667; font-weight:600; padding:.5rem .4rem; border-bottom:2px solid #eef1f6; font-size:.78rem; }
    table.reg td{ padding:.6rem .4rem; border-bottom:1px solid #f1f3f8; }
    .badge{ display:inline-block; padding:.15rem .55rem; border-radius:999px; font-size:.76rem; font-weight:700; }
    .badge.d0{ background:#fee2e2; color:#991b1b; } .badge.d7{ background:#ffedd5; color:#9a3412; } .badge.d30{ background:#fef9c3; color:#854d0e; } .badge.dok{ background:#dcfce7; color:#166534; }
    .empty{ color:#8a94a6; font-size:.88rem; padding:.6rem 0; }
    .note-box{ background:#f5f3ea; border:1px solid #e4dfc7; border-radius:12px; padding:.8rem 1rem; font-size:.82rem; color:#5b4d1f; margin-top:1rem; }
    /* chat */
    #chat-toggle{ position:fixed; bottom:1.2rem; left:1.2rem; background:var(--gold); color:#221a00; border:0; border-radius:999px; padding:.8rem 1.3rem; font-weight:700; box-shadow:0 8px 20px rgba(0,0,0,.25); cursor:pointer; z-index:50; }
    #chat-frame-wrap{ position:fixed; bottom:5rem; left:1.2rem; width:min(380px,92vw); height:min(560px,70vh); border-radius:16px; overflow:hidden; box-shadow:0 20px 50px rgba(0,0,0,.3); display:none; z-index:50; background:#fff; }
    #chat-frame-wrap #n8n-chat-widget{ width:100%; height:100%; }
    .err-banner{ background:#fdecec; color:#b3261e; border-radius:10px; padding:.8rem 1rem; margin-bottom:1rem; display:none; }
    @media(max-width:640px){ .score-card{ flex-direction:column; text-align:center; } }
  </style>
</head>
<body>
  <div id="login-screen">
    <form class="login-card" id="login-form">
      <img src="/logo.svg" alt="" />
      <h1>لوحة الامتثال</h1>
      <p>ادخل بريدك الإلكتروني ورمز الدخول المرسل إليه لمتابعة حالة الامتثال يومياً.</p>
      <div class="field"><label>البريد الإلكتروني</label><input type="email" id="in-email" required autocomplete="email" /></div>
      <div class="field"><label>رمز الدخول</label><input type="text" id="in-code" required autocomplete="off" /></div>
      <button type="submit" class="btn btn-navy btn-block" id="login-btn">دخول</button>
      <div class="login-err" id="login-err"></div>
      <div class="hint">ما وصلك كود؟ اشترك عبر new.businesspartner.sa/ar/compliance-agent — يصلك الكود بعد تأكيد الاشتراك.</div>
    </form>
  </div>

  <div id="locked-screen" style="display:none">
    <div class="login-card" style="max-width:440px">
      <img src="/logo.svg" alt="" />
      <h1>🔒 أكمل الدفع لتفعيل الخدمة</h1>
      <p id="locked-company-name" style="font-weight:700;color:var(--navy)"></p>
      <p>سجّلنا بيانات منشأتك بنجاح، لكن لوحة الامتثال تُفتح فور تأكيد الدفع. أكمل الاشتراك وستُفعَّل الخدمة تلقائياً خلال دقائق.</p>
      <a class="btn btn-navy btn-block" id="locked-pay-btn" href="https://new.businesspartner.sa/ar/compliance-agent#pricing" target="_blank" rel="noopener">إكمال الدفع الآن</a>
      <button type="button" class="btn btn-ghost-light" style="width:100%;margin-top:.6rem;background:#eef2fb;color:var(--navy);border-color:#dbe4f5" id="locked-logout-btn">تسجيل خروج</button>
      <div class="hint">بعد تأكيد الدفع تصلك رسالة بريد بأن الخدمة فُتحت — سجّل الدخول من جديد بنفس الرمز.</div>
    </div>
  </div>

  <div id="dash">
    <header class="top">
      <div class="wrap">
        <div class="brand"><img src="/logo.svg" alt="" /><span id="company-name">لوحة الامتثال</span></div>
        <div class="actions">
          <button class="icon-btn" id="refresh-btn">↻ تحديث الآن</button>
          <button class="icon-btn" id="logout-btn">خروج</button>
        </div>
      </div>
    </header>

    <div class="wrap">
      <div class="err-banner" id="dash-err"></div>

      <div class="tabs">
        <button class="tab active" data-tab="overview">نظرة عامة</button>
        <button class="tab" data-tab="upload">📤 رفع الملفات</button>
        <button class="tab" data-tab="entities">الجهات الحكومية</button>
        <button class="tab" data-tab="alerts">التنبيهات والبنود</button>
        <button class="tab" data-tab="costs">التكاليف</button>
        <button class="tab" data-tab="calcs">الحاسبات</button>
      </div>

      <!-- OVERVIEW -->
      <div class="panel active" id="panel-overview">
        <div class="card score-card">
          <div class="score-ring" id="score-ring">--</div>
          <div class="score-meta">
            <h2 id="score-title">🎯 درجة الامتثال</h2>
            <div id="score-band">—</div>
            <div id="last-analysis" style="font-size:.78rem;color:#9aa3b2;margin-top:.3rem;"></div>
          </div>
        </div>

        <div class="qgrid">
          <div class="qtile"><div class="qicon red">🔴</div><div class="qn" id="cnt-red">0</div><div class="ql">حرجة</div></div>
          <div class="qtile"><div class="qicon yellow">🟡</div><div class="qn" id="cnt-yellow">0</div><div class="ql">متوسطة</div></div>
          <div class="qtile"><div class="qicon green">🟢</div><div class="qn" id="cnt-green">0</div><div class="ql">منخفضة</div></div>
          <div class="qtile"><div class="qicon blue">👥</div><div class="qn" id="qi-employees">—</div><div class="ql">الموظفون</div></div>
          <div class="qtile"><div class="qicon gold">💰</div><div class="qn small" id="qi-cost">—</div><div class="ql">التكلفة ربعياً</div></div>
          <div class="qtile"><div class="qicon navy">🏷️</div><div class="qn small" id="qi-band">—</div><div class="ql">النطاق</div></div>
        </div>

        <h3 class="sec" style="margin-top:1.6rem">🚨 أبرز التنبيهات</h3>
        <div class="card" id="top-alerts"><div class="empty">جارٍ التحميل...</div></div>
      </div>

      <!-- UPLOAD WIZARD -->
      <div class="panel" id="panel-upload">
        <h3 class="sec">📤 رفع ملفات الامتثال</h3>
        <p style="color:#667;font-size:.85rem;margin-bottom:1rem">ارفع مستنداتك خطوة بخطوة — يقرأها وكيل الامتثال ويرتّبها تلقائياً تحت كل منصة. لو ملف غير جاهز الآن اضغط «تخطي» وارجع له لاحقاً.</p>
        <div class="card" id="upload-wizard">
          <div id="upload-progress" style="font-size:.82rem;color:#667;margin-bottom:.6rem"></div>
          <div style="background:#eef1f7;border-radius:8px;height:6px;margin-bottom:1.1rem;overflow:hidden"><div id="upload-bar" style="height:100%;background:var(--brand);width:0%;transition:width .25s"></div></div>
          <h4 id="upload-step-title" style="color:var(--navy);font-size:1.05rem;margin-bottom:.3rem"></h4>
          <p id="upload-step-desc" style="color:#667;font-size:.85rem;margin-bottom:.9rem"></p>
          <input type="file" id="upload-step-file" style="margin-bottom:1rem" />
          <div id="upload-step-msg" style="display:none;border-radius:8px;padding:.6rem .8rem;font-size:.85rem;margin-bottom:.9rem"></div>
          <div style="display:flex;gap:.6rem;flex-wrap:wrap">
            <button type="button" id="upload-back" style="background:#fff;color:var(--navy);border:1px solid var(--navy);padding:.5rem 1rem;border-radius:8px;font-size:.85rem;cursor:pointer">← السابق</button>
            <button type="button" id="upload-skip" style="background:#fff;color:#667;border:1px solid #ccd2e0;padding:.5rem 1rem;border-radius:8px;font-size:.85rem;cursor:pointer">تخطي</button>
            <button type="button" class="btn btn-navy" id="upload-next" style="margin-inline-start:auto">التالي ←</button>
          </div>
        </div>
        <div class="card" id="upload-done" style="display:none;text-align:center">
          <h3 style="color:var(--navy)">✅ تم استلام ملفاتك</h3>
          <p style="color:#667;font-size:.9rem;margin:.6rem 0">وكيل الامتثال يراجع ملفاتك الآن ويحدّث لوحتك خلال دقائق — يصلك إيميل بكل تحديث. اضغط تحديث بعد قليل لمشاهدة التحليل.</p>
          <button type="button" class="btn btn-navy" id="upload-refresh-after">↻ تحديث اللوحة الآن</button>
          <button type="button" id="upload-restart" style="margin-top:.7rem;display:block;margin-inline:auto;background:#fff;color:var(--navy);border:1px solid var(--navy);padding:.5rem 1rem;border-radius:8px;font-size:.85rem;cursor:pointer">✏️ الرجوع لقائمة الملفات لتعديل أو إضافة مستند</button>
        </div>
      </div>

      <!-- ENTITIES -->
      <div class="panel" id="panel-entities">
        <h3 class="sec">🏛️ الجهات الحكومية المرتبطة بمنشأتك</h3>
        <p style="color:#667;font-size:.85rem;margin-bottom:1rem">اضغط أي جهة لعرض تنبيهاتها وبنودها. الربط المباشر (API) قادم لكل جهة تباعاً — البيانات حالياً من ملفاتك المرفوعة.</p>
        <div class="grid cols-auto" id="entity-grid"></div>
      </div>

      <!-- ALERTS + REGISTER -->
      <div class="panel" id="panel-alerts">
        <div id="platform-filter-chip" style="display:none"></div>
        <h3 class="sec">🚨 التنبيهات</h3>
        <div class="card" id="alerts-list"><div class="empty">جارٍ التحميل...</div></div>
        <h3 class="sec" style="margin-top:1.4rem">⏳ البنود والاستحقاقات</h3>
        <div class="card">
          <table class="reg">
            <thead><tr><th>المنصة</th><th>الموظف/الموضوع</th><th>نوع الإجراء</th><th>تاريخ الانتهاء</th><th>الأيام</th></tr></thead>
            <tbody id="reg-body"><tr><td colspan="5" class="empty">جارٍ التحميل...</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- COSTS -->
      <div class="panel" id="panel-costs">
        <h3 class="sec">💰 التكلفة الحكومية التقديرية</h3>
        <div class="grid cols-3">
          <div class="card"><div style="color:#667;font-size:.85rem">ربعياً</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="cost-q">—</div></div>
          <div class="card"><div style="color:#667;font-size:.85rem">سنوياً</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="cost-a">—</div></div>
          <div class="card"><div style="color:#667;font-size:.85rem">الموظفون / السعوديون</div><div style="font-size:1.4rem;font-weight:800;color:var(--navy)" id="emp-info">—</div></div>
        </div>
        <div class="note-box">💡 التكلفة أعلاه تقديرية إجمالية (رخص العمل + الإقامات + التأمين الطبي + الغرامات المحتملة) مبنية على عدد الموظفين. لحساب دقيق لكل موظف حسب مهنته وحالته، أضف بيانات المهن — والوكيل يقدر يفصّلها لك عند الطلب في المحادثة.</div>
      </div>

      <!-- CALCULATORS -->
