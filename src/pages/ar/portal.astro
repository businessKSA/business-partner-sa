  </div>

  <button id="chat-toggle">💬 اسأل وكيل الامتثال</button>
  <div id="chat-frame-wrap"><div id="n8n-chat-widget"></div></div>

  <script define:vars={{ API_URL }}>
    // Branded badges (colored word-marks) instead of generic emoji or scraped
    // trademarked logos — each authority gets a distinct, recognizable color chip.
    const ENTITY_BADGES = {
      sbc:          { bg:'#0B1B5A', label:'مركز الأعمال' },
      cr:           { bg:'#334155', label:'السجل التجاري' },
      chamber:      { bg:'#B7791F', label:'الغرفة' },
      address:      { bg:'#475569', label:'العنوان الوطني' },
      qiwa:         { bg:'#0F9D8C', label:'قوى' },
      muqeem:       { bg:'#15803D', label:'مقيم' },
      mudad:        { bg:'#7C3AED', label:'مدد' },
      gosi:         { bg:'#9F1239', label:'التأمينات' },
      zatca:        { bg:'#166534', label:'الزكاة والضريبة' },
      customs:      { bg:'#78350F', label:'الجمارك' },
      balady:       { bg:'#CA8A04', label:'بلدي' },
      civildefense: { bg:'#B91C1C', label:'الدفاع المدني' },
      ejar:         { bg:'#1D4ED8', label:'إيجار' },
      misa:         { bg:'#0369A1', label:'MISA' },
    };

    // One distinct pictogram per government entity (simple generic icons, not
    // scraped official emblems — same rationale as the color chips above).
    const ENTITY_ICONS = {
      sbc:          '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V8l8-5 8 5v13"/><path d="M9 21v-6h6v6"/><path d="M9 12h.01M15 12h.01M9 8h.01M15 8h.01"/></svg>',
      cr:           '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h8l4 4v14H7z"/><path d="M15 3v4h4"/><path d="M9 12h6M9 16h6"/></svg>',
      chamber:      '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V10M19 21V10M9 21V10M15 21V10"/><path d="M3 10l9-6 9 6"/></svg>',
      address:      '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.1 7-11.5A7 7 0 0 0 5 9.5C5 14.9 12 21 12 21z"/><circle cx="12" cy="9.5" r="2.3"/></svg>',
      qiwa:         '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 12h18"/></svg>',
      muqeem:       '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M6 16c0-1.7 1.3-3 3-3s3 1.3 3 3"/><path d="M14 9h4M14 13h4"/></svg>',
      mudad:        '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><circle cx="7" cy="14.5" r="1"/></svg>',
      gosi:         '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
      zatca:        '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h8l4 4v14H7z"/><path d="M15 3v4h4"/><path d="M9 17l6-6M10 12h.01M15 15h.01"/></svg>',
      customs:      '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l9-4 9 4-9 4-9-4z"/><path d="M3 8v9l9 4 9-4V8"/><path d="M12 12v9"/></svg>',
      balady:       '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V10l5-4 5 4v11"/><path d="M14 21v-7l4-3 3 3v7z"/><path d="M8 21v-4M8 13h.01"/></svg>',
      civildefense: '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6z"/><path d="M12 8c1.5 2 1.5 3.5 0 5.5-1.5-2-1.5-3.5 0-5.5z"/></svg>',
      ejar:         '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/><circle cx="14.5" cy="15.5" r="1.5"/><path d="M14.5 17v2"/></svg>',
      misa:         '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 4 5.8 4 9s-1.5 6.5-4 9c-2.5-2.5-4-5.8-4-9s1.5-6.5 4-9z"/></svg>',
    };

    // Step-by-step compliance document checklist — one document per step,
    // submitted immediately to the same intake pipeline used for new
    // registrations. Passing notion_page_id + code (both already known from
    // this authenticated session) routes it into an update of THIS client's
    // existing record instead of creating a duplicate/new one.
    const DOC_STEPS = [
      { key:'cr', label:'السجل التجاري', desc:'ارفع صورة أو PDF للسجل التجاري (اسم المنشأة والرقم الموحّد يجب أن يظهرا بوضوح).' },
      { key:'gosi', label:'برنت التأمينات الاجتماعية (Excel)', desc:'صادر من موقع التأمينات — ملف Excel بقائمة المشتركين.' },
      { key:'address', label:'شهادة العنوان الوطني', desc:'شهادة العنوان الوطني الصادرة من البريد السعودي.' },
      { key:'zatca', label:'الشهادة الضريبية (ZATCA)', desc:'شهادة تسجيل ضريبة القيمة المضافة.' },
      { key:'zatca', label:'شهادة الزكاة', desc:'شهادة الزكاة السارية من هيئة الزكاة والضريبة والجمارك.' },
      { key:'muqeem', label:'برنت مقيم (Excel)', desc:'كشف بيانات الإقامات من منصة مقيم.' },
      { key:'chamber', label:'شهادة الغرفة التجارية', desc:'شهادة العضوية السارية من الغرفة التجارية.' },
      { key:'balady', label:'الرخصة البلدية', desc:'الرخصة البلدية السارية لموقع نشاطك.' },
      { key:'qiwa', label:'شهادة المديونيات (قوى)', desc:'شهادة عدم الممانعة/المديونيات من منصة قوى.' },
      { key:'qiwa', label:'شهادة التوطين / النطاقات (قوى)', desc:'شهادة النطاق الحالي من منصة قوى.' },
      { key:'gosi', label:'شهادة الاشتراك (التأمينات)', desc:'شهادة اشتراك سارية من التأمينات الاجتماعية.' },
      { key:'mudad', label:'شهادة الالتزام بحماية الأجور (مدد)', desc:'شهادة الالتزام الصادرة من منصة مدد.' },
      { key:'gosi', label:'بوليصة التأمين الطبي لجميع الموظفين (Excel)', desc:'كشف بوليصة التأمين الطبي بجميع الموظفين المؤمّن عليهم — ملف Excel.' },
      { key:'', label:'لقطة شاشة لكل منصة حكومية', desc:'لقطة شاشة لصفحة حسابك في كل منصة (قوى، التأمينات، المركز السعودي للأعمال...) لتوثيق تاريخ التسجيل — يمكنك اختيار أكثر من صورة دفعة واحدة.', multiple:true },
      { key:'qiwa', label:'عقود قوى لكل الموظفين (PDF)', desc:'ملفات PDF لعقود العمل من قوى — لاستخراج البنود وتاريخ المباشرة والانتهاء لكل موظف.', multiple:true },
    ];
    let uploadStep = 0;
    function renderUploadStep() {
      const s = DOC_STEPS[uploadStep];
      document.getElementById('upload-progress').textContent = 'الخطوة ' + (uploadStep + 1) + ' من ' + DOC_STEPS.length;
      document.getElementById('upload-bar').style.width = Math.round((uploadStep / DOC_STEPS.length) * 100) + '%';
      document.getElementById('upload-step-title').textContent = s.label;
      document.getElementById('upload-step-desc').textContent = s.desc;
      const fileInput = document.getElementById('upload-step-file');
      fileInput.value = ''; fileInput.multiple = !!s.multiple;
      document.getElementById('upload-back').disabled = uploadStep === 0;
      document.getElementById('upload-step-msg').style.display = 'none';
      document.getElementById('upload-wizard').style.display = 'block';
      document.getElementById('upload-done').style.display = 'none';
    }
    function showUploadMsg(text, ok) {
      const el = document.getElementById('upload-step-msg');
      el.style.display = 'block'; el.style.background = ok ? '#dcfce7' : '#fee2e2'; el.style.color = ok ? '#065f46' : '#991b1b';
      el.textContent = text;
    }
    function finishUploadStep() {
      if (uploadStep < DOC_STEPS.length - 1) { uploadStep++; renderUploadStep(); }
      else { document.getElementById('upload-wizard').style.display = 'none'; document.getElementById('upload-done').style.display = 'block'; }
    }
    function submitUploadStep(cb) {
      const s = DOC_STEPS[uploadStep];
      const fileInput = document.getElementById('upload-step-file');
      if (!fileInput.files.length) { cb(); return; }
      const nextBtn = document.getElementById('upload-next');
      nextBtn.disabled = true; nextBtn.textContent = '...جارٍ الرفع';
      const fd = new FormData();
      fd.append('company', (lastData && lastData.company) || '');
      fd.append('email', localStorage.getItem('bp_portal_email') || '');
      fd.append('code', localStorage.getItem('bp_portal_code') || '');
      fd.append('notion_page_id', (lastData && lastData.pageId) || '');
      fd.append('notes', s.label);
      fd.append('platforms', s.key || '');
      for (let i = 0; i < fileInput.files.length; i++) fd.append('files', fileInput.files[i]);
      fetch(INTAKE_URL, { method: 'POST', body: fd })
        .then(function (r) { if (!r.ok) throw new Error('status ' + r.status); showUploadMsg('✅ تم رفع: ' + s.label, true); })
        .catch(function () { showUploadMsg('تعذّر رفع "' + s.label + '" — تحقق من اتصالك وحاول مجدداً.', false); })
        .finally(function () { nextBtn.disabled = false; nextBtn.textContent = 'التالي ←'; cb(); });
    }
    document.getElementById('upload-next').addEventListener('click', function () { submitUploadStep(finishUploadStep); });
    document.getElementById('upload-skip').addEventListener('click', finishUploadStep);
    document.getElementById('upload-back').addEventListener('click', function () { if (uploadStep > 0) { uploadStep--; renderUploadStep(); } });
    document.getElementById('upload-restart').addEventListener('click', function () { renderUploadStep(); });
    document.getElementById('upload-refresh-after').addEventListener('click', function () { switchTab('overview'); document.getElementById('refresh-btn').click(); });
    renderUploadStep();

    const loginScreen = document.getElementById('login-screen');
    const lockedScreen = document.getElementById('locked-screen');
    const dash = document.getElementById('dash');
    const loginForm = document.getElementById('login-form');
    const loginErr = document.getElementById('login-err');
    const loginBtn = document.getElementById('login-btn');
    const dashErr = document.getElementById('dash-err');
    let lastData = null;
    let activePlatformFilter = null;

    function riskDot(r){ return r === 'أحمر' ? 'red' : (r === 'أصفر' ? 'yellow' : 'green'); }
    const RISK_EMOJI = { red:'🔴', yellow:'🟡', green:'🟢' };
    const LABEL_COLORS = {};
    Object.values(ENTITY_BADGES).forEach(b => { LABEL_COLORS[b.label] = b.bg; });
    function dayBadge(d){
      if (d === null || d === undefined) return '<span class="badge dok">—</span>';
      if (d <= 0) return '<span class="badge d0">منتهي</span>';
      if (d <= 7) return '<span class="badge d0">' + d + ' يوم</span>';
      if (d <= 30) return '<span class="badge d7">' + d + ' يوم</span>';
      return '<span class="badge dok">' + d + ' يوم</span>';
    }
    function fmtMoney(n){ return (typeof n === 'number') ? n.toLocaleString('ar-SA') + ' ريال' : '—'; }
    function shortText(s, n) { s = (s || '').trim(); return s.length > n ? s.slice(0, n).trim() + '…' : s; }
    // Alert titles/actions from Notion sometimes carry a full narrative sentence
    // (legacy fallback text) instead of a short label — clean + dedupe for display.
    function cleanTitle(t) {
      t = (t || '').trim();
      const cut = t.search(/[:.]|\s-\s/);
      if (cut > 8 && cut < 70) t = t.slice(0, cut);
      return shortText(t, 90);
    }
    function dedupeAlerts(alerts) {
      const groups = {};
      const order = [];
      alerts.forEach(a => {
        const key = (a.platform || '') + '|' + cleanTitle(a.title).replace(/[-−]?\s*\d+\s*يوم/g, '').trim();
        if (!groups[key]) { groups[key] = { ...a, count: 1 }; order.push(key); }
        else {
          groups[key].count++;
          const curDays = groups[key].daysRemaining, newDays = a.daysRemaining;
          if (newDays !== null && newDays !== undefined && (curDays === null || curDays === undefined || newDays < curDays)) {
            groups[key].daysRemaining = newDays; groups[key].expiry = a.expiry;
          }
        }
      });
      return order.map(k => groups[k]);
    }

    function switchTab(name) {
      document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
      document.querySelectorAll('.panel').forEach(p => p.classList.toggle('active', p.id === 'panel-' + name));
    }
    document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

    function renderAlertsList(el, alertsRaw, opts) {
      opts = opts || {};
      const limit = opts.limit || 0;
      const deduped = dedupeAlerts(alertsRaw || []);
      const shown = limit ? deduped.slice(0, limit) : deduped;
      const rowHtml = (a) => {
        const risk = riskDot(a.risk);
        const days = (a.daysRemaining !== null && a.daysRemaining !== undefined)
          ? (a.daysRemaining <= 0 ? 'منتهي' : a.daysRemaining + ' يوم') : '—';
        const countBadge = a.count > 1 ? (' <span class="badge d7">×' + a.count + '</span>') : '';
        const color = LABEL_COLORS[a.platform] || '#0B1B5A';
        return '<tr class="arow risk-' + risk + '">' +
          '<td><span class="risk-emoji">' + RISK_EMOJI[risk] + '</span></td>' +
          '<td>' + (a.platform ? '<span class="platform-chip" style="background:' + color + '">' + a.platform + '</span>' : '—') + '</td>' +
          '<td><div class="t">' + cleanTitle(a.title) + countBadge + '</div>' + (a.action ? '<div class="m">' + shortText(a.action, 70) + '</div>' : '') + '</td>' +
          '<td>' + dayBadge(a.daysRemaining) + '</td>' +
        '</tr>';
      };
      let html = '<div class="alert-table-wrap"><table class="alert-table"><thead><tr><th></th><th>الجهة</th><th>البند</th><th>الأيام</th></tr></thead><tbody>' +
        (shown.length ? shown.map(rowHtml).join('') : '<tr><td colspan="4" class="empty">لا توجد تنبيهات حالياً ✅</td></tr>') +
        '</tbody></table></div>';
      if (limit && !opts.noMore && deduped.length > limit) {
        html += '<button class="tab" style="width:100%;margin-top:.6rem;color:var(--navy)" id="alerts-showmore">عرض الكل (' + deduped.length + ')</button>';
      }
      el.innerHTML = html;
      const moreBtn = document.getElementById('alerts-showmore');
      if (moreBtn) moreBtn.addEventListener('click', () => renderAlertsList(el, alertsRaw, {}));
    }

    function applyPlatformFilter(entityLabel) {
      activePlatformFilter = entityLabel;
      const chip = document.getElementById('platform-filter-chip');
      if (entityLabel) {
        chip.style.display = 'block';
        chip.innerHTML = '<div class="filter-chip">مفلتر حسب: ' + entityLabel + ' <button id="clear-filter">✕</button></div>';
        document.getElementById('clear-filter').addEventListener('click', () => { applyPlatformFilter(null); renderAll(lastData); });
      } else {
        chip.style.display = 'none';
        chip.innerHTML = '';
      }
    }

    function renderEntityGrid(platforms) {
      const grid = document.getElementById('entity-grid');
      grid.innerHTML = platforms.map(p => {
        let statusClass = 'nodata', statusText = 'بحاجة بيانات';
        if (p.red > 0) { statusClass = 'crit'; statusText = p.red + ' حرج'; }
        else if (p.yellow > 0) { statusClass = 'warn'; statusText = p.yellow + ' تنبيه'; }
        else if (p.hasData) { statusClass = 'ok'; statusText = 'سليم'; }
        const badge = ENTITY_BADGES[p.key] || { bg:'#0B1B5A', label: p.label };
        const icon = ENTITY_ICONS[p.key] || badge.label;
        return '<div class="entity" data-label="' + p.label + '"><div class="badge-logo" style="background:' + badge.bg + '" title="' + badge.label + '">' + icon + '</div>' +
          '<div class="label">' + p.label + '</div><div class="authority">' + p.authority + '</div>' +
          '<div class="status ' + statusClass + '">' + statusText + '</div>' +
          '<div class="api-note">🔌 ربط مباشر قريباً</div></div>';
      }).join('');
      grid.querySelectorAll('.entity').forEach(el => el.addEventListener('click', () => {
        applyPlatformFilter(el.dataset.label);
        switchTab('alerts');
        renderAll(lastData);
      }));
    }

    function renderAll(data) {
      if (!data) return;
      document.getElementById('company-name').textContent = data.company || '—';
      const ring = document.getElementById('score-ring');
      const score = typeof data.healthScore === 'number' ? data.healthScore : 0;
      ring.textContent = score;
      ring.style.background = score >= 85 ? 'linear-gradient(135deg,#16a34a,#22c55e)' : score >= 65 ? 'linear-gradient(135deg,#0066cc,#3b82f6)' : score >= 40 ? 'linear-gradient(135deg,#d97706,#f59e0b)' : 'linear-gradient(135deg,#dc2626,#ef4444)';
      document.getElementById('score-band').textContent = 'الحالة: ' + (data.healthBand || '—') + (data.status ? (' · ' + data.status) : '');
      document.getElementById('last-analysis').textContent = data.lastAnalysis ? ('آخر تحليل: ' + data.lastAnalysis) : '';

      const c = data.counts || {};
      document.getElementById('cnt-red').textContent = c.red || 0;
      document.getElementById('cnt-yellow').textContent = c.yellow || 0;
      document.getElementById('cnt-green').textContent = c.green || 0;

      document.getElementById('qi-employees').textContent = (data.employees ?? '—') + (data.saudis !== null && data.saudis !== undefined ? (' / ' + data.saudis) : '');
      document.getElementById('qi-cost').textContent = fmtMoney(data.quarterlyCost);
      document.getElementById('qi-band').textContent = data.band || '—';

      const allAlerts = data.alerts || [];
      renderAlertsList(document.getElementById('top-alerts'), allAlerts, { limit: 3, noMore: true });

      const filteredAlerts = activePlatformFilter ? allAlerts.filter(a => a.platform === activePlatformFilter) : allAlerts;
      renderAlertsList(document.getElementById('alerts-list'), filteredAlerts, { limit: 10 });

      const allReg = data.register || [];
      const filteredReg = activePlatformFilter ? allReg.filter(r => r.platform === activePlatformFilter) : allReg;
      const regBody = document.getElementById('reg-body');
      regBody.innerHTML = filteredReg.length ? filteredReg.map(r =>
        '<tr><td>' + (r.platform || '—') + '</td><td>' + (r.subject || '—') + '</td><td>' + (r.actionType || '—') + '</td><td>' +
        (r.expiry || '—') + '</td><td>' + dayBadge(r.daysRemaining) + '</td></tr>'
      ).join('') : '<tr><td colspan="5" class="empty">لا توجد بنود مسجّلة بعد</td></tr>';

      renderEntityGrid(data.platforms || []);

      document.getElementById('cost-q').textContent = fmtMoney(data.quarterlyCost);
      document.getElementById('cost-a').textContent = fmtMoney(data.annualCost);
      document.getElementById('emp-info').textContent = (data.employees ?? '—') + ' / ' + (data.saudis ?? '—') + (data.band ? (' (' + data.band + ')') : '');
    }

    async function loadDashboard(email, code) {
      const url = API_URL + '?email=' + encodeURIComponent(email) + '&code=' + encodeURIComponent(code);
      const res = await fetch(url);
      if (res.status === 401) throw new Error('unauthorized');
      const data = await res.json();
      if (!data || data.ok === false) throw new Error(data && data.error || 'error');
      return data;
    }

    function showApp(data) {
      loginScreen.style.display = 'none';
      if (data.locked) {
        lockedScreen.style.display = 'flex';
        dash.style.display = 'none';
        document.getElementById('locked-company-name').textContent = data.company || '';
      } else {
        lockedScreen.style.display = 'none';
        dash.style.display = 'block';
      }
    }

    loginForm.addEventListener('submit', function (e) {
      e.preventDefault();
      const email = document.getElementById('in-email').value.trim().toLowerCase();
      const code = document.getElementById('in-code').value.trim();
      if (!email || !code) return;
      loginBtn.disabled = true; loginBtn.textContent = '...جارٍ الدخول';
      loginErr.style.display = 'none';
      loadDashboard(email, code).then(function (data) {
        localStorage.setItem('bp_portal_email', email);
        localStorage.setItem('bp_portal_code', code);
        lastData = data;
        showApp(data);
        if (!data.locked) renderAll(data);
      }).catch(function () {
        loginErr.textContent = 'البريد الإلكتروني أو رمز الدخول غير صحيح.';
        loginErr.style.display = 'block';
      }).finally(function () {
        loginBtn.disabled = false; loginBtn.textContent = 'دخول';
      });
    });

    function doLogout() {
      localStorage.removeItem('bp_portal_email');
      localStorage.removeItem('bp_portal_code');
      dash.style.display = 'none';
      lockedScreen.style.display = 'none';
      loginScreen.style.display = 'flex';
    }
    document.getElementById('logout-btn').addEventListener('click', doLogout);
    document.getElementById('locked-logout-btn').addEventListener('click', doLogout);

    document.getElementById('refresh-btn').addEventListener('click', function () {
      const email = localStorage.getItem('bp_portal_email');
      const code = localStorage.getItem('bp_portal_code');
      if (!email || !code) return;
      const btn = document.getElementById('refresh-btn');
      btn.disabled = true; btn.textContent = '...جارٍ التحديث';
      dashErr.style.display = 'none';
      loadDashboard(email, code).then(function (data) {
        lastData = data;
        renderAll(data);
      }).catch(function () {
        dashErr.textContent = 'تعذّر التحديث. حاول مرة أخرى.';
        dashErr.style.display = 'block';
      }).finally(function () {
        btn.disabled = false; btn.textContent = '↻ تحديث الآن';
      });
    });

    const chatToggle = document.getElementById('chat-toggle');
    const chatWrap = document.getElementById('chat-frame-wrap');
    chatToggle.addEventListener('click', function () {
      chatWrap.style.display = chatWrap.style.display === 'block' ? 'none' : 'block';
    });

    (function init() {
      const e = localStorage.getItem('bp_portal_email');
      const k = localStorage.getItem('bp_portal_code');
      if (e && k) {
        loginScreen.style.display = 'none';
        loadDashboard(e, k).then(function (data) {
          lastData = data;
          showApp(data);
          if (!data.locked) renderAll(data);
        }).catch(function () {
          doLogout();
          loginErr.textContent = 'تعذّر تحميل البيانات. سجّل الدخول من جديد.';
          loginErr.style.display = 'block';
        });
      }
    })();
  </script>
  <script type="module" define:vars={{ CHAT_URL }}>
    // n8n's hosted-chat webhook page can't be embedded via a raw <iframe> (it
    // isn't served with iframe-friendly framing), so we mount the official
    // @n8n/chat widget in fullscreen mode inside our own toggleable wrapper
    // instead — it talks to the webhook via fetch, not by navigating a frame.
    import { createChat } from 'https://cdn.jsdelivr.net/npm/@n8n/chat/dist/chat.bundle.es.js';
    createChat({
      webhookUrl: CHAT_URL,
      target: '#n8n-chat-widget',
      mode: 'fullscreen',
      showWelcomeScreen: false,
      initialMessages: [
        'أهلاً! أنا وكيل الامتثال في شريك الأعمال 👋',
        'اسألني عن التأمينات (GOSI)، قوى، النطاقات والسعودة، الشهادات وتواريخ انتهائها، أو أي التزام حكومي.',
      ],
      i18n: { en: { title: 'وكيل الامتثال', subtitle: '', footer: '', getStarted: 'ابدأ محادثة', inputPlaceholder: 'اكتب سؤالك عن الامتثال...', closeButtonTooltip: 'إغلاق' } },
    });
  </script>
</body>
</html>
