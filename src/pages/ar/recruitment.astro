---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'ar';
const t = getContent(locale);

// روابط منظومة التوظيف (تُحدَّث عند ربط لوحة التحكم الفعلية)
const WA = 'https://wa.me/966530540231';
const employerHref = '#employer';
const seekerHref = '#seeker';
const dashboardHref = '#dashboard';

// نقاط الدخول الثلاث
const entries = [
  {
    icon: '🏢',
    title: 'صاحب العمل',
    desc: 'سجّل شركتك، أنشئ إعلاناً وظيفياً بمساعدة وكيل ذكي، واستقبل سيراً مفروزة جاهزة للمقابلة.',
    cta: 'ابدأ كصاحب عمل',
    href: employerHref,
  },
  {
    icon: '👤',
    title: 'الباحث عن عمل',
    desc: 'أنشئ ملفك، ارفع سيرتك، وتقدّم على وظائف داخل السعودية — مع تقييم وتدريب مجاني يرفع فرصك.',
    cta: 'سجّل كباحث عن عمل',
    href: seekerHref,
  },
  {
    icon: '📊',
    title: 'لوحة التوظيف',
    desc: 'لوحة تحكم موحّدة: كانبان الفرز، المحادثات، جدولة المقابلات، العروض، وتتبّع الامتثال في قوى.',
    cta: 'افتح لوحة التوظيف',
    href: dashboardHref,
  },
];

// دورة حياة التوظيف الكاملة
const lifecycle = [
  { n: '1', icon: '📄', title: 'اختيار السيرة', desc: 'بنك سير ذكي + فرز آلي يرشّح الأنسب من قاعدة المرشحين.' },
  { n: '2', icon: '🔎', title: 'الفرز والتقييم', desc: 'اختبارات ومقابلات بالذكاء الاصطناعي قبل وصول المرشح لصاحب العمل.' },
  { n: '3', icon: '💬', title: 'المقابلات', desc: 'جدولة عبر Google Calendar ورابط Meet/Teams/Zoom مع إشعارات للجميع.' },
  { n: '4', icon: '📝', title: 'العرض الوظيفي', desc: 'وكيل يكتب العرض ببراند الشركة، ومهلة 24 ساعة للقبول أو الرفض.' },
  { n: '5', icon: '📜', title: 'التعاقد', desc: 'عقد رسمي موثّق في منصة قوى وفق نظام العمل السعودي.' },
  { n: '6', icon: '🛂', title: 'التأشيرة والاستقدام', desc: 'إصدار التأشيرة وتصريح العمل عبر قوى لغير السعوديين (استقطاب خارجي).' },
  { n: '7', icon: '✈️', title: 'الدخول للمملكة', desc: 'إجراءات الوصول، الفحص الطبي، الإقامة، ونقل الخدمات عبر قوى.' },
  { n: '8', icon: '🎯', title: 'الأونبوردينج', desc: 'تهيئة كاملة داخل السعودية: تسجيل GOSI، حماية الأجور (مدد)، والتفعيل التشغيلي.' },
];

// أنواع الاستقطاب والتوظيف
const tracks = [
  { icon: '🇸🇦', title: 'توظيف السعوديين', desc: 'محور تركيزنا: رفع نسب السعودة وتحقيق نطاقات قوى بمرشحين سعوديين مؤهّلين.', featured: true },
  { icon: '⏱️', title: 'العمل المرن (بالساعة / اليوم)', desc: 'توظيف مرن بالساعة أو اليوم تحت مظلة العمل المرن المعتمدة في قوى.', featured: true },
  { icon: '🌐', title: 'العمل عن بُعد', desc: 'عقود عمل عن بُعد بحقوق وأجور كاملة وفق نظام العمل السعودي.' },
  { icon: '🌍', title: 'توظيف غير السعوديين', desc: 'استقطاب واستقدام الكفاءات الأجنبية مع كامل تصاريح العمل والامتثال.' },
  { icon: '🏠', title: 'الاستقطاب الداخلي', desc: 'التوظيف من داخل السوق السعودي عبر بنك السير ونقل الخدمات في قوى.' },
  { icon: '🛫', title: 'الاستقطاب الخارجي', desc: 'استقدام من الخارج: تأشيرات، وكالات معتمدة، وسير جاهزة من شركاء موثوقين.' },
  { icon: '🤝', title: 'EOR / الإسناد', desc: 'صاحب العمل الرسمي (Employer of Record) والإسناد الوظيفي دون فتح كيان.' },
  { icon: '🗂️', title: 'بنك السير (شركاء خارجيون)', desc: 'شركاء يغذّون القاعدة بالسير الذاتية باستمرار لبناء مخزون مواهب جاهز.' },
];

// الأتمتة الكاملة
const automation = [
  { icon: '🤖', title: 'وكيل الوصف الوظيفي', desc: 'يكتب إعلانات دقيقة وجذّابة تلقائياً.' },
  { icon: '⚡', title: 'فرز آلي ذكي', desc: 'ترتيب المرشحين حسب المطابقة خلال دقائق.' },
  { icon: '🎙️', title: 'مقابلات بالذكاء الاصطناعي', desc: 'تقييم أولي آلي قبل المقابلة البشرية.' },
  { icon: '📅', title: 'جدولة وإشعارات تلقائية', desc: 'مواعيد، تذكيرات، وإشعارات بريدية للجميع.' },
  { icon: '📄', title: 'توليد العروض والعقود', desc: 'عروض ببراند الشركة ومؤقّت قبول 24 ساعة.' },
  { icon: '🛡️', title: 'متابعة امتثال قوى آلية', desc: 'قوى / مقيم / GOSI / مدد + نطاقات السعودة.' },
];
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="width:100%; overflow-x:hidden;">

    <!-- HERO -->
    <section style="text-align:center; padding:120px 24px 80px; max-width:1200px; margin:0 auto;">
      <div style="display:inline-block; padding:8px 18px; background:#EFF6FF; color:#2563EB; border-radius:999px; font-size:16px; font-weight:700; margin-bottom:24px;">
        👥 الموارد البشرية والتوظيف من Business Partner
      </div>
      <h1 style="font-size:56px; line-height:1.2; margin-bottom:20px; color:#0F172A; font-weight:800;">
        منظومة التوظيف المتكاملة
      </h1>
      <h2 style="font-size:26px; color:#475569; margin-bottom:28px; font-weight:600; line-height:1.5;">
        من اختيار السيرة الذاتية إلى التوظيف والدخول للمملكة والأونبوردينج الكامل داخل السعودية
      </h2>
      <p style="max-width:820px; margin:0 auto 40px; font-size:20px; line-height:1.9; color:#334155;">
        نظام واحد أتمتة كاملة يجمع صاحب العمل والباحث عن عمل ولوحة التوظيف تحت مظلة واحدة —
        بتقنية ذكاء اصطناعي على مستوى أفضل منصات التوظيف عالمياً، وامتثال حكومي سعودي كامل عبر قوى.
      </p>
      <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <a href={employerHref} style="padding:18px 34px; background:#2563EB; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">أنا صاحب عمل</a>
        <a href={seekerHref} style="padding:18px 34px; background:#0F172A; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">أبحث عن عمل</a>
        <a href={WA} target="_blank" style="padding:18px 34px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">تحدّث مع مستشار</a>
      </div>
    </section>

    <!-- نقاط الدخول الثلاث -->
    <section id="entries" style="padding:70px 24px; background:#F8FAFC;">
      <div style="max-width:1200px; margin:0 auto;">
        <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">منظومة واحدة · ثلاث بوابات</h2>
        <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:48px;">كل ما يخص التوظيف مدموج داخل الموارد البشرية.</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:28px;">
          {entries.map((e) => (
            <div style="background:white; border:1px solid #E2E8F0; border-radius:18px; padding:36px; text-align:center; box-shadow:0 2px 12px rgba(15,23,42,.04);">
              <div style="font-size:52px; margin-bottom:16px;">{e.icon}</div>
              <h3 style="font-size:26px; color:#0F172A; font-weight:800; margin-bottom:12px;">{e.title}</h3>
              <p style="color:#475569; font-size:17px; line-height:1.8; margin-bottom:24px;">{e.desc}</p>
              <a href={e.href} style="display:inline-block; padding:12px 26px; background:#2563EB; color:white; text-decoration:none; border-radius:10px; font-size:16px; font-weight:700;">{e.cta}</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- دورة الحياة الكاملة -->
    <section id="lifecycle" style="padding:90px 24px; max-width:1200px; margin:0 auto;">
      <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">رحلة التوظيف الكاملة — 8 مراحل</h2>
      <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:52px;">من اختيار السيفي حتى الأونبوردينج داخل السعودية — كل مرحلة مؤتمتة ومربوطة بالجهات الحكومية.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:22px;">
        {lifecycle.map((s) => (
          <div style="position:relative; background:white; border:1px solid #E2E8F0; border-radius:16px; padding:28px;">
            <div style="position:absolute; top:-14px; inset-inline-start:24px; width:34px; height:34px; background:#2563EB; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:16px;">{s.n}</div>
            <div style="font-size:40px; margin-bottom:12px; margin-top:8px;">{s.icon}</div>
            <h3 style="font-size:21px; color:#0F172A; font-weight:800; margin-bottom:10px;">{s.title}</h3>
            <p style="color:#475569; font-size:16px; line-height:1.75;">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- أنواع الاستقطاب والتوظيف -->
    <section id="tracks" style="padding:90px 24px; background:#0F172A;">
      <div style="max-width:1200px; margin:0 auto;">
        <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:white; font-weight:800;">كل مسارات التوظيف تحت سقف واحد</h2>
        <p style="text-align:center; color:#94A3B8; font-size:19px; margin-bottom:52px;">مع تركيز خاص على توظيف السعوديين والعمل المرن بالساعة واليوم.</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px;">
          {tracks.map((tr) => (
            <div style={`border-radius:16px; padding:28px; border:1px solid ${tr.featured ? '#2563EB' : '#1E293B'}; background:${tr.featured ? 'linear-gradient(160deg,#1E3A8A,#1E293B)' : '#111827'};`}>
              <div style="font-size:40px; margin-bottom:12px;">{tr.icon}</div>
              <h3 style="font-size:21px; color:white; font-weight:800; margin-bottom:10px;">{tr.title}{tr.featured ? ' ⭐' : ''}</h3>
              <p style="color:#CBD5E1; font-size:16px; line-height:1.75;">{tr.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- الأتمتة الكاملة -->
    <section id="automation" style="padding:90px 24px; max-width:1200px; margin:0 auto;">
      <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">أتمتة كاملة على مستوى عالمي</h2>
      <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:52px;">مستوحاة من أفضل منصات التوظيف عالمياً (Deel · Greenhouse · Factorial) ومطبّقة على السوق السعودي.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px;">
        {automation.map((a) => (
          <div style="display:flex; gap:16px; align-items:flex-start; background:#F8FAFC; border:1px solid #E2E8F0; border-radius:14px; padding:24px;">
            <div style="font-size:34px; line-height:1;">{a.icon}</div>
            <div>
              <h3 style="font-size:19px; color:#0F172A; font-weight:800; margin-bottom:6px;">{a.title}</h3>
              <p style="color:#475569; font-size:15px; line-height:1.7;">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- بوابات صاحب العمل / الباحث / اللوحة (مراسي) -->
    <section style="padding:80px 24px; background:#F8FAFC;">
      <div style="max-width:1000px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:24px;">
        <div id="employer" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">🏢 صاحب العمل</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">سجّل شركتك واطلب موظفين أو عمالة، وابدأ الاستقطاب بلوحة كاملة.</p>
          <a href={WA} target="_blank" style="display:inline-block; padding:12px 24px; background:#2563EB; color:white; text-decoration:none; border-radius:10px; font-weight:700;">اطلب موظفين الآن</a>
        </div>
        <div id="seeker" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">👤 الباحث عن عمل</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">ارفع سيرتك وانضم لبنك السير، وتصلك الفرص المناسبة داخل السعودية.</p>
          <a href={WA} target="_blank" style="display:inline-block; padding:12px 24px; background:#0F172A; color:white; text-decoration:none; border-radius:10px; font-weight:700;">أرسل سيرتك</a>
        </div>
        <div id="dashboard" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">📊 لوحة التوظيف</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">لوحة تحكم الاستقطاب والفرز والمقابلات والعروض — قريباً على المنصة.</p>
          <span style="display:inline-block; padding:12px 24px; background:#E2E8F0; color:#475569; border-radius:10px; font-weight:700;">قيد الإطلاق</span>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="padding:100px 24px; text-align:center; max-width:900px; margin:0 auto;">
      <h2 style="font-size:40px; color:#0F172A; font-weight:800; margin-bottom:18px;">جاهز تبدأ التوظيف بالطريقة الأذكى؟</h2>
      <p style="color:#475569; font-size:20px; line-height:1.8; margin-bottom:34px;">وظّف سعوديين وغير سعوديين، مرن أو دائم، من داخل المملكة أو خارجها — ونحن نتولى الأتمتة والامتثال.</p>
      <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <a href={WA} target="_blank" style="padding:18px 40px; background:#25D366; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">واتساب مباشر</a>
        <a href="tel:+966530540231" style="padding:18px 40px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">اتصل بنا</a>
      </div>
    </section>

  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>
