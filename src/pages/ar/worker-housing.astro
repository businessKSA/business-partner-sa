---
import '../../styles/global.css';
export const prerender = true;
const INTAKE_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/client-intake-web';
const WHATSAPP = 'https://wa.me/966503793356';
const platforms = ['إيجار','بلدي','مقيم','الدفاع المدني','أبشر أعمال','العنوان الوطني','الأمانات والبلديات'];
const steps = [
  ['1','ترفع بيانات السكن والعمالة','عقد الإيجار، موقع السكن، عدد العمال — صورة أو PDF، واحنا نرتب الباقي.'],
  ['2','نراجع وضعك النظامي','نفحص توثيق العقد في إيجار، رخصة سكن العمالة، اشتراطات السلامة والإشغال.'],
  ['3','ننفذ التوثيق والترخيص','توثيق العقد، إصدار/تجديد رخصة بلدي، شهادة الدفاع المدني، تحديث العناوين في مقيم.'],
  ['4','متابعة وتنبيهات مستمرة','ننبهك قبل انتهاء العقد أو الرخصة أو الشهادة — سكنك يظل نظامي طول السنة.'],
];
const pains = [
  ['🏚️','سكن غير مرخص = مخالفات','الأمانات والبلديات تكثف جولاتها على سكن العمالة الجماعي، والمخالفات تصل لآلاف الريالات وقد يصل الأمر لإخلاء السكن.'],
  ['📄','عقد إيجار غير موثق','بدون توثيق في منصة إيجار ما تقدر تصدر رخصة سكن العمالة، وتتعطل إجراءات حكومية أخرى مرتبطة بالعنوان.'],
  ['📍','عناوين العمالة غير محدثة','تحديث عنوان سكن كل عامل في مقيم مطلوب نظاماً — وتحديثه يدوياً لعشرات العمال يستهلك وقت فريقك.'],
  ['⏰','انتهاءات ما أحد ينتبه لها','رخصة البلدية وشهادة الدفاع المدني وعقد الإيجار كلها لها تواريخ انتهاء — نسيان واحد منها يرجعك لنقطة الصفر.'],
];
const faqs = [
  ['من الملزم بتوفير سكن نظامي للعمالة؟','المنشآت التي توفر سكناً جماعياً لعمالتها ملزمة باستيفاء اشتراطات سكن العمالة الجماعي (الترخيص، السلامة، الحد الأدنى للمساحة لكل عامل) حسب لوائح الأمانات والبلديات.'],
  ['وش يصير إذا كان السكن بدون ترخيص؟','السكن غير المرخص معرض لمخالفات مالية من البلدية، وقد يصل الأمر لإغلاق السكن أو إخلائه، إضافة لتعطل إجراءات مرتبطة بعنوان العمالة.'],
  ['هل تشمل الخدمة أكثر من مدينة؟','نعم — الخدمة تغطي جميع مناطق المملكة، وكل موقع سكن يُدار كملف مستقل بترخيصه وعقده وتنبيهاته.'],
  ['كم تستغرق الإجراءات؟','توثيق العقد في إيجار يتم خلال أيام قليلة، ورخصة سكن العمالة وشهادة الدفاع المدني تعتمد على جاهزية الموقع — نعطيك خطة زمنية واضحة بعد مراجعة ملفك.'],
  ['هل تطلبون كلمات مرور أو رموز دخول؟','لا نطلب كلمات مرور أو رموز نفاذ (OTP) أبداً، ولا يُنفَّذ أي إجراء حكومي دون موافقتك.'],
];
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>تسكين العمالة — توثيق وترخيص سكن العمال في السعودية | شريك الأعمال</title>
  <meta name="description" content="سكّن عمالتك بشكل نظامي 100% — نتكفل بتوثيق عقد الإيجار في إيجار، إصدار رخصة سكن العمالة من بلدي، شهادة الدفاع المدني، وتحديث عناوين العمالة في مقيم، مع تنبيهات قبل كل انتهاء." />
  <link rel="canonical" href="https://businesspartner.sa/ar/worker-housing" />
  <meta property="og:title" content="تسكين العمالة من شريك الأعمال" />
  <meta property="og:description" content="توثيق وترخيص سكن العمالة — إيجار، بلدي، مقيم، الدفاع المدني — مع متابعة وتنبيهات مستمرة." />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://businesspartner.sa/logo.svg" />
  <meta property="og:locale" content="ar_SA" />
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "خدمة تسكين العمالة",
    "provider": { "@type": "Organization", "name": "شريك الأعمال", "url": "https://businesspartner.sa" },
    "areaServed": "SA",
    "description": "توثيق وترخيص سكن العمالة في السعودية: توثيق عقود الإيجار في إيجار، رخصة سكن العمالة من بلدي، شهادة الدفاع المدني، وتحديث عناوين العمالة في مقيم."
  }
  </script>
  <style>
    :root{ --navy:#0B1B5A; --brand:#0066cc; --gold:#C79A3A; }
    body{ padding-top:0; background:#f5f7fb; }
    .wrap{ max-width:1080px; margin-inline:auto; padding-inline:1.1rem; }
    a{ text-decoration:none; }
    .hero{ background:linear-gradient(150deg,#0B1B5A 0%,#12307f 55%,#0066cc 130%); color:#fff; padding:3.4rem 0 3.6rem; }
    .hero .wrap{ display:flex; flex-direction:column; gap:1.1rem; }
    .brandrow{ display:flex; align-items:center; gap:.6rem; opacity:.95; }
    .brandrow img{ height:34px; }
    .brandrow span{ font-weight:700; letter-spacing:.3px; }
    .hero h1{ font-size:2.35rem; line-height:1.25; max-width:24ch; }
    .hero p.lead{ font-size:1.16rem; max-width:60ch; color:#e7ecfb; }
    .cta{ display:flex; gap:.7rem; flex-wrap:wrap; margin-top:.4rem; }
    .btn{ display:inline-flex; align-items:center; gap:.5rem; padding:.85rem 1.4rem; border-radius:12px; font-weight:700; font-size:1rem; cursor:pointer; border:0; }
    .btn-gold{ background:var(--gold); color:#221a00; }
    .btn-wa{ background:#25D366; color:#0a2e14; }
    .btn-navy{ background:var(--navy); color:#fff; width:100%; justify-content:center; font-size:1.05rem; padding:1rem; }
    .chips{ display:flex; flex-wrap:wrap; gap:.5rem; margin-top:.6rem; }
    .chip{ background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.22); color:#eaf0ff; padding:.32rem .7rem; border-radius:999px; font-size:.85rem; }
    .section{ padding:3rem 0; }
    .section h2{ font-size:1.7rem; color:var(--navy); margin-bottom:.4rem; }
    .section .sub{ color:#5b6472; margin-bottom:1.6rem; }
    .steps{ display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:1rem; }
    .step{ background:#fff; border:1px solid #e6eaf2; border-radius:16px; padding:1.2rem; box-shadow:0 8px 24px rgba(11,27,90,.05); }
    .step .n{ width:34px; height:34px; border-radius:50%; background:var(--navy); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; margin-bottom:.6rem; }
    .step h3{ font-size:1.05rem; color:var(--navy); margin-bottom:.3rem; }
    .step p{ color:#5b6472; font-size:.94rem; }
    .pains{ display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1rem; }
    .pain{ background:#fff; border:1px solid #f0e0e0; border-radius:16px; padding:1.2rem; box-shadow:0 8px 24px rgba(90,11,11,.04); }
    .pain .ic{ font-size:1.6rem; margin-bottom:.5rem; }
    .pain h3{ font-size:1.02rem; color:#8a2b2b; margin-bottom:.3rem; }
    .pain p{ color:#5b6472; font-size:.93rem; }
    .value{ background:#fff; border:1px solid #e6eaf2; border-radius:20px; padding:1.6rem; box-shadow:0 10px 30px rgba(11,27,90,.06); }
    .value ul{ list-style:none; display:grid; gap:.7rem; }
    .value li{ display:flex; gap:.6rem; align-items:flex-start; color:#333; }
    .value li b{ color:var(--navy); }
    .price{ display:flex; gap:1rem; flex-wrap:wrap; align-items:center; background:linear-gradient(135deg,#fff,#f2f6ff); border:1px solid #dce6ff; border-radius:18px; padding:1.3rem 1.5rem; }
    .price .amt{ font-size:2rem; font-weight:800; color:var(--navy); }
    .price .amt small{ font-size:.95rem; color:#6b7280; font-weight:600; }
    .faq{ display:grid; gap:.8rem; }
    .faq details{ background:#fff; border:1px solid #e6eaf2; border-radius:14px; padding:1rem 1.2rem; }
    .faq summary{ font-weight:700; color:var(--navy); cursor:pointer; }
    .faq p{ color:#5b6472; margin-top:.6rem; font-size:.95rem; }
    .formcard{ background:#fff; border:1px solid #e6eaf2; border-radius:20px; padding:1.6rem; box-shadow:0 12px 34px rgba(11,27,90,.08); }
    .formgrid{ display:grid; grid-template-columns:1fr 1fr; gap:.9rem; }
    .field{ display:flex; flex-direction:column; gap:.3rem; }
    .field.full{ grid-column:1 / -1; }
    label{ font-size:.9rem; font-weight:600; color:#334; }
    input,select,textarea{ border:1px solid #cfd8e6; border-radius:10px; padding:.7rem .8rem; font:inherit; background:#fff; }
    input:focus,select:focus,textarea:focus{ outline:2px solid #bcd2ff; border-color:var(--brand); }
    .req{ color:#d33; }
    .note{ font-size:.85rem; color:#6b7280; margin-top:.9rem; display:flex; gap:.5rem; }
    .msg{ margin-top:.9rem; padding:.8rem 1rem; border-radius:10px; font-weight:600; display:none; }
    .msg.ok{ background:#e7f8ee; color:#137a3e; display:block; }
    .msg.err{ background:#fdecec; color:#b3261e; display:block; }
    footer{ background:var(--navy); color:#cfd6f5; padding:1.4rem 0; font-size:.85rem; }
    @media(max-width:640px){ .formgrid{ grid-template-columns:1fr; } .hero h1{ font-size:1.9rem; } }
  </style>
</head>
<body>
  <header class="hero">
    <div class="wrap">
      <div class="brandrow"><img src="/logo.svg" alt="شريك الأعمال" /><span>شريك الأعمال · تسكين العمالة</span></div>
      <h1>سكّن عمالتك بشكل نظامي 100% — واحنا نتكفل بكل الإجراءات</h1>
      <p class="lead">توثيق عقد الإيجار في <b>إيجار</b>، إصدار رخصة سكن العمالة من <b>بلدي</b>، شهادة <b>الدفاع المدني</b>، وتحديث عناوين عمالتك في <b>مقيم</b> دفعة واحدة — مع تنبيهات قبل كل انتهاء. بدون ما تدخل أي منصة حكومية بنفسك.</p>
      <div class="cta">
        <a class="btn btn-gold" href="#intake">ابدأ الآن — سجّل سكنك</a>
        <a class="btn btn-wa" href={WHATSAPP} target="_blank" rel="noopener">تحدّث معنا واتساب</a>
      </div>
      <div class="chips">{platforms.map((p)=> <span class="chip">{p}</span>)}</div>
    </div>
  </header>

  <section class="section"><div class="wrap">
    <h2>ليش تحتاج الخدمة؟</h2>
    <p class="sub">سكن العمالة صار ملف رقابي بحد ذاته — وأي تقصير فيه يكلفك مخالفات وتعطيل.</p>
    <div class="pains">
      {pains.map(([ic,t,d])=> (
        <div class="pain"><div class="ic">{ic}</div><h3>{t}</h3><p>{d}</p></div>
      ))}
    </div>
  </div></section>

  <section class="section" style="padding-top:0"><div class="wrap">
    <div class="value">
      <h2 style="margin-bottom:1rem">وش يشمل الاشتراك؟</h2>
      <ul>
        <li>✅ <span><b>توثيق عقد الإيجار:</b> توثيق عقد سكن العمالة في منصة إيجار وربطه بمنشأتك.</span></li>
        <li>✅ <span><b>رخصة سكن العمالة:</b> إصدار أو تجديد رخصة السكن الجماعي من بلدي واستيفاء الاشتراطات.</span></li>
        <li>✅ <span><b>شهادة الدفاع المدني:</b> ترتيب شهادة السلامة لموقع السكن ومتابعة تجديدها.</span></li>
        <li>✅ <span><b>تحديث عناوين العمالة:</b> تحديث عنوان السكن لكل عامل في مقيم دفعة واحدة — مهما كان عددهم.</span></li>
        <li>✅ <span><b>تقرير امتثال دوري:</b> سجل واضح لكل موقع سكن: العقد، الرخصة، الشهادة، وتواريخ الانتهاء.</span></li>
        <li>✅ <span><b>تنبيهات قبل الانتهاء:</b> ننبهك واتساب وإيميل قبل انتهاء العقد أو الرخصة أو الشهادة بوقت كافٍ.</span></li>
      </ul>
    </div>
  </div></section>

  <section class="section" style="padding-top:0"><div class="wrap">
    <h2>كيف تشتغل الخدمة؟</h2>
    <p class="sub">أربع خطوات — من رفع بيانات سكنك إلى ملف سكن نظامي متابع طول السنة.</p>
    <div class="steps">
      {steps.map(([n,t,d])=> (
        <div class="step"><div class="n">{n}</div><h3>{t}</h3><p>{d}</p></div>
      ))}
    </div>
  </div></section>

  <section class="section" style="padding-top:0"><div class="wrap">
    <div class="price">
      <div><div class="amt">يبدأ من 499 <small>ريال / لكل موقع سكن</small></div>
      <div style="color:#5b6472">رسوم إدارة ملف تسكين العمالة — التوثيق والترخيص والمتابعة. الرسوم الحكومية للإجراءات منفصلة وتُنفَّذ بموافقتك.</div></div>
      <a class="btn btn-gold" href="#intake" style="margin-inline-start:auto">اشترك الآن</a>
    </div>
  </div></section>

  <section class="section" style="padding-top:0"><div class="wrap">
    <h2>أسئلة شائعة</h2>
    <div class="faq">
      {faqs.map(([q,a])=> (
        <details><summary>{q}</summary><p>{a}</p></details>
      ))}
    </div>
  </div></section>

  <section id="intake" class="section" style="background:#eef2fb"><div class="wrap">
    <h2>سجّل سكن عمالتك وابدأ التوثيق</h2>
    <p class="sub">عبّئ البيانات وارفع مستنداتك — نستلمها بأمان في مجلد خاص بمنشأتك ونرجع لك بخطة واضحة.</p>
    <form id="bp-form" class="formcard" novalidate>
      <div class="formgrid">
        <div class="field"><label>اسم المنشأة <span class="req">*</span></label><input name="company" required /></div>
        <div class="field"><label>رقم السجل التجاري <span class="req">*</span></label><input name="cr_number" required /></div>
        <div class="field"><label>المالك / المفوّض <span class="req">*</span></label><input name="authorized_person" required /></div>
        <div class="field"><label>الجوال / واتساب <span class="req">*</span></label><input name="whatsapp" required placeholder="05xxxxxxxx" /></div>
        <div class="field"><label>البريد الإلكتروني <span class="req">*</span></label><input type="email" name="email" required /></div>
        <div class="field"><label>المدينة <span class="req">*</span></label><input name="city" required /></div>
        <div class="field"><label>عدد العمالة</label><input name="workers_count" type="number" min="1" placeholder="مثال: 25" /></div>
        <div class="field"><label>عدد مواقع السكن</label><input name="housing_sites" type="number" min="1" placeholder="مثال: 1" /></div>
        <div class="field"><label>عقد الإيجار موثق في إيجار؟</label>
          <select name="ejar_contract"><option>غير معروف</option><option>نعم</option><option>لا</option><option>لا يوجد عقد بعد</option></select></div>
        <div class="field"><label>يوجد رخصة سكن عمالة من بلدي؟</label>
          <select name="balady_license"><option>غير معروف</option><option>نعم</option><option>لا</option><option>منتهية</option></select></div>
        <div class="field full"><label>ارفع مستنداتك (عقد الإيجار / رخصة السكن / السجل / قوى / مقيم) — PDF أو Excel أو صور</label>
          <input type="file" id="bp-files" name="files" multiple accept=".pdf,.xlsx,.xls,.csv,.png,.jpg,.jpeg,.webp" /></div>
        <div class="field full"><label>ملاحظات</label><textarea name="notes" rows="3"></textarea></div>
        <div class="field full" style="flex-direction:row; align-items:flex-start; gap:.5rem">
          <input type="checkbox" id="consent" required style="margin-top:.35rem" />
          <label for="consent" style="font-weight:500">أوافق على استخدام بياناتي لدراسة ملف تسكين العمالة فقط، وتُحفظ في مجلد خاص بمنشأتي، ولا تُشارك دون موافقتي.</label></div>
      </div>
      <button type="submit" class="btn btn-navy" id="bp-submit" style="margin-top:1rem">🔒 إرسال آمن وبدء التوثيق</button>
      <div class="msg" id="bp-msg"></div>
      <div class="note">🔒 <span>بياناتك محمية — تُستخدم لدراسة ملف سكن عمالتك فقط. لا نطلب كلمات مرور أو رموز نفاذ (OTP)، ولا يُنفَّذ أي إجراء حكومي دون موافقتك.</span></div>
    </form>
  </div></section>

  <footer><div class="wrap">شريك الأعمال · businesspartner.sa · التقديرات تخضع للتأكيد من المصادر الرسمية. لا يُنفَّذ أي إجراء حكومي دون موافقتك.</div></footer>

  <script define:vars={{ INTAKE_URL }}>
    const f = document.getElementById('bp-form');
    const msg = document.getElementById('bp-msg');
    const btn = document.getElementById('bp-submit');
    const files = document.getElementById('bp-files');
    const show = (t, cls) => { msg.textContent = t; msg.className = 'msg ' + cls; };
    f.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!f.company.value.trim() || !f.whatsapp.value.trim() || !f.cr_number.value.trim() || !f.email.value.trim() || !f.city.value.trim()) {
        show('يرجى تعبئة اسم المنشأة والسجل والجوال والبريد والمدينة.', 'err'); return;
      }
      if (!document.getElementById('consent').checked) { show('يرجى الموافقة على استخدام البيانات.', 'err'); return; }
      const fd = new FormData();
      ['company','cr_number','authorized_person','whatsapp','email','city','workers_count','housing_sites','ejar_contract','balady_license','notes']
        .forEach((k) => fd.append(k, (f[k] && f[k].value) || ''));
      fd.append('source', 'website-worker-housing');
      fd.append('service', 'worker-housing');
      for (const file of files.files) fd.append('files', file);
      btn.disabled = true; btn.textContent = '... جارٍ الإرسال';
      fetch(INTAKE_URL, { method: 'POST', body: fd })
        .then((r) => { if (!r.ok) throw new Error(r.status); return r.text(); })
        .then(() => { show('✅ استلمنا بياناتك! نراجع ملف سكن عمالتك ونتواصل معك واتساب/إيميل بخطة واضحة.', 'ok'); f.reset(); })
        .catch(() => show('تعذّر الإرسال. جرّب مرة أخرى أو تواصل معنا واتساب.', 'err'))
        .finally(() => { btn.disabled = false; btn.textContent = '🔒 إرسال آمن وبدء التوثيق'; });
    });
  </script>
</body>
</html>
