      entities:{en:['NEOM Investment Fund','OXAGON (industry)','THE LINE','TROJENA'], ar:['صندوق استثمار نيوم','أوكساجون (الصناعة)','ذا لاين','تروجينا']},
      incl:{en:['NEOM regions & sectors briefing','OXAGON advanced-industry overview','Introductions to NEOM investment teams','Executive hospitality','Site-visit coordination'], ar:['إحاطة عن مناطق وقطاعات نيوم','نظرة على الصناعات المتقدمة في أوكساجون','تعريفات بفرق استثمار نيوم','ضيافة تنفيذية','تنسيق الزيارات الميدانية']}},
    {name:'Jazan', ar:'جازان',
      tag:{en:'Industrial south with agri & logistics upside', ar:'جنوب صناعي بفرص زراعية ولوجستية'},
      sectors:{en:['Energy','Mining','Agriculture','Fisheries','Logistics'], ar:['الطاقة','التعدين','الزراعة','الثروة السمكية','اللوجستيات']},
      entities:{en:['Jazan City for Primary & Downstream Industries (JCPDI)','Royal Commission','Jazan Chamber'], ar:['مدينة جازان للصناعات الأساسية والتحويلية (JCPDI)','الهيئة الملكية','غرفة جازان']},
      incl:{en:['JCPDI industrial-city briefing','Coffee, mango & fisheries value-chain intros','Meetings with regional authority','Executive hospitality','Farasan Islands cultural experience'], ar:['إحاطة عن المدينة الصناعية (JCPDI)','تعريفات بسلاسل القيمة: البن والمانجو والأسماك','اجتماعات مع الهيئة الإقليمية','ضيافة تنفيذية','تجربة ثقافية في جزر فرسان']}},
  ];

  const SECTOR_TILES = [
    {ic:'⚡', b:{en:'Energy & Renewables',ar:'الطاقة والمتجددة'}, s:{en:'Green hydrogen, solar, grid',ar:'هيدروجين أخضر، طاقة شمسية، الشبكة'}},
    {ic:'🏭', b:{en:'Manufacturing',ar:'التصنيع'}, s:{en:'Localization & Industry 4.0',ar:'التوطين والصناعة 4.0'}},
    {ic:'💻', b:{en:'Technology',ar:'التقنية'}, s:{en:'Cloud, AI, digital economy',ar:'السحابة، الذكاء الاصطناعي، الاقتصاد الرقمي'}},
    {ic:'🏨', b:{en:'Tourism',ar:'السياحة'}, s:{en:'Hotels, destinations, MICE',ar:'فنادق، وجهات، فعاليات أعمال'}},
    {ic:'🏦', b:{en:'Financial Services',ar:'الخدمات المالية'}, s:{en:'Capital markets, fintech',ar:'أسواق المال، التقنية المالية'}},
    {ic:'🚢', b:{en:'Logistics',ar:'اللوجستيات'}, s:{en:'Ports, air cargo, land bridge',ar:'موانئ، شحن جوي، الجسر البري'}},
    {ic:'🧬', b:{en:'Healthcare',ar:'الرعاية الصحية'}, s:{en:'Hospitals, biotech, pharma',ar:'مستشفيات، تقنية حيوية، أدوية'}},
    {ic:'⚽', b:{en:'Sports & Ent.',ar:'الرياضة والترفيه'}, s:{en:'Clubs, events, gaming',ar:'أندية، فعاليات، ألعاب'}},
    {ic:'🌾', b:{en:'Agri & Food',ar:'الزراعة والغذاء'}, s:{en:'Agritech, food security',ar:'تقنية زراعية، أمن غذائي'}},
    {ic:'🏗️', b:{en:'Real Estate',ar:'العقار'}, s:{en:'Giga-projects, PropTech',ar:'مشاريع عملاقة، تقنية عقارية'}},
    {ic:'🎓', b:{en:'Education',ar:'التعليم'}, s:{en:'Universities, EdTech',ar:'جامعات، تقنية تعليم'}},
    {ic:'🛢️', b:{en:'Petrochemicals',ar:'البتروكيماويات'}, s:{en:'Downstream & specialty',ar:'الصناعات التحويلية والمتخصصة'}},
  ];

  // ═══════════ Apply i18n ═══════════
  let LANG = 'en';
  function tr(k){ return (T[LANG] && T[LANG][k]) || T.en[k] || k; }
  function applyLang(lang){
    LANG = T[lang] ? lang : 'en';
    document.documentElement.lang = LANG;
    document.documentElement.dir = (LANG === 'ar') ? 'rtl' : 'ltr';
    document.getElementById('langLabel').textContent = LANG.toUpperCase();
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const k = el.getAttribute('data-i18n');
      const v = (T[LANG] && T[LANG][k]);
      if (v) el.textContent = v;
    });
    renderCities();
    renderSectors();
    renderWizard();
  }

  // ═══════════ Render cities ═══════════
  function renderCities(){
    const grid = document.getElementById('cityGrid');
    const pk=(f)=> (f && (f[LANG]||f.en)) || '';
    const nm=(LANG==='ar')?'المدينة':'City';
    grid.innerHTML = CITIES.map(c => `
      <div class="city-card">
        <div class="city-banner" style="background-image:linear-gradient(120deg, rgba(11,27,90,.92), rgba(19,36,110,.86)), url('${SKY}')"><h3>${LANG==='ar'?c.ar:c.name}</h3><span class="city-ar">${LANG==='ar'?c.name:c.ar}</span></div>
        <div class="city-body">
          <p class="city-tag">${pk(c.tag)}</p>
          <div class="city-label">${LANG==='ar'?'القطاعات':'Sectors'}</div>
          <div class="city-chips">${pk(c.sectors).map(x=>`<span>${x}</span>`).join('')}</div>
          <div class="city-label">${LANG==='ar'?'جهات وعلاقات':'Authorities & relations'}</div>
          <ul class="city-entities">${pk(c.entities).map(e=>`<li>${e}</li>`).join('')}</ul>
          <div class="city-label">${LANG==='ar'?'يشمل البرنامج':'Program includes'}</div>
          <ul class="city-incl">${pk(c.incl).map(i=>`<li>${i}</li>`).join('')}</ul>
          <div class="city-foot">
            <a class="btn btn-navy" target="_blank" rel="noopener" href="https://wa.me/${WA}?text=${encodeURIComponent((LANG==='ar'?'استفسار مستثمر — برنامج ':'Investor enquiry — ')+(LANG==='ar'?c.ar:c.name))}">${LANG==='ar'?'اطلب هذا البرنامج':'Request this program'}</a>
          </div>
        </div>
      </div>`).join('');
  }
  function renderSectors(){
    document.getElementById('sectorGrid').innerHTML = SECTOR_TILES.map(s=>`
      <div class="sector"><span>${s.ic}</span><b>${(s.b[LANG]||s.b.en)}</b><small>${(s.s[LANG]||s.s.en)}</small></div>`).join('');
  }

  // ═══════════ Wizard ═══════════
  const state = { step:0, purpose:null, sector:null, region:null, timeline:null };
  const STEPS = ['purpose','sector','region','timeline'];

  function optLabel(o){ return o.t ? (o.t[LANG]||o.t.en) : (LANG==='ar'&&o.ar ? o.ar+' · '+o.id : o.id); }

  function renderWizard(){
    const body = document.getElementById('cxBody');
    const bar = document.getElementById('cxBar');
    if (state.step >= STEPS.length){ renderResult(); return; }
    const key = STEPS[state.step];
    bar.style.width = ((state.step)/STEPS.length*100)+'%';
    let list = key==='purpose'?PURPOSE : key==='sector'?SECTORS : key==='region'?REGIONS : TIMELINE;
    const cur = state[key];
    const q = QUESTIONS[key][LANG] || QUESTIONS[key].en;
    body.innerHTML = `
      <div class="cx-q">${q}</div>
      <div class="cx-options">
        ${list.map(o=>`<button class="cx-opt ${cur===o.id?'sel':''}" data-opt="${o.id}"><span class="ic">${o.ic}</span><span>${optLabel(o)}</span></button>`).join('')}
      </div>
      <div class="cx-actions">
        ${state.step>0?`<button class="cx-btn cx-back">${tr('cx.back')}</button>`:''}
        <button class="cx-btn cx-next" ${cur?'':'disabled'}>${tr('cx.next')}</button>
      </div>
      <p class="cx-hint">${tr('cx.hint')}</p>`;
    body.querySelectorAll('.cx-opt').forEach(b=>b.addEventListener('click',()=>{ state[key]=b.getAttribute('data-opt'); renderWizard(); }));
    const nx=body.querySelector('.cx-next'); if(nx) nx.addEventListener('click',()=>{ state.step++; renderWizard(); });
    const bk=body.querySelector('.cx-back'); if(bk) bk.addEventListener('click',()=>{ state.step--; renderWizard(); });
  }

  function findLabel(list,id){ const o=list.find(x=>x.id===id); return o?optLabel(o):id; }

  function renderResult(){
    document.getElementById('cxBar').style.width='100%';
    const purpose=findLabel(PURPOSE,state.purpose);
    const sector=findLabel(SECTORS,state.sector);
    const regionObj=REGIONS.find(x=>x.id===state.region);
    const region = regionObj ? (regionObj.t?optLabel(regionObj):(regionObj.id+' / '+regionObj.ar)) : state.region;
    const timeline=findLabel(TIMELINE,state.timeline);
    const msg = `Investment enquiry via Mahfol Makfol by Business Partner\n• Goal: ${purpose}\n• Sector: ${sector}\n• Region: ${region}\n• Timeline: ${timeline}`;
    try {
      fetch('/api/investor-lead', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ purpose: purpose, sector: sector, region: region, timeline: timeline, lang: LANG, source: 'Concierge wizard' })
      }).catch(function(){});
    } catch (e) {}
    document.getElementById('cxBody').innerHTML = `
      <div class="cx-result">
        <h3>${tr('cx.rTitle')}</h3>
        <p>${tr('cx.rBody')}</p>
        <div class="cx-summary">
          <div><span class="k">${tr('cx.kPurpose')}:</span> ${purpose}</div>
          <div><span class="k">${tr('cx.kSector')}:</span> ${sector}</div>
          <div><span class="k">${tr('cx.kRegion')}:</span> ${region}</div>
          <div><span class="k">${tr('cx.kTime')}:</span> ${timeline}</div>
        </div>
        <div class="cx-actions">
          <button class="cx-btn cx-back">${tr('cx.restart')}</button>
          <a class="cx-btn cx-next" style="text-decoration:none;text-align:center;line-height:1.4" target="_blank" rel="noopener" href="https://wa.me/${WA}?text=${encodeURIComponent(msg)}">${tr('cx.wa')}</a>
        </div>
      </div>`;
    document.querySelector('#cxBody .cx-back').addEventListener('click',()=>{ state.step=0; state.purpose=state.sector=state.region=state.timeline=null; renderWizard(); });
  }

  // Language menu
  const langBtn=document.getElementById('langBtn'), langMenu=document.getElementById('langMenu');
  langBtn.addEventListener('click',()=>{ langMenu.hidden=!langMenu.hidden; });
  document.addEventListener('click',(e)=>{ if(!e.target.closest('.lang-wrap')) langMenu.hidden=true; });
  langMenu.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{ applyLang(b.getAttribute('data-lang')); langMenu.hidden=true; }));

  // Init — detect browser language
  const nav=(navigator.language||'en').slice(0,2);
  applyLang(T[nav]?nav:'en');
</script>
</body>
</html>
