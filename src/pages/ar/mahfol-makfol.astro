---
// Mahfol Makfol By Business Partner — Saudi Investor Gateway
// بوابة المستثمر: علاقات حكومية، تصاريح MISA، اجتماعات، فعاليات، ضيافة تنفيذية.
// معالج ذكي متعدد اللغات يعمل داخل المتصفح (بدون اعتماد على خدمة خارجية).
export const prerender = true;

const contact = { email: 'info@businesspartner.sa', wa: '966501386327' };

// بانرات المدن: تدرّج كحلي + أفق مدينة (SVG) — أنيق ولائق بمستثمر
const skyline = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 260' preserveAspectRatio='xMidYMax slice'%3E%3Cg fill='%23ffffff' opacity='0.10'%3E%3Crect x='60' y='120' width='46' height='140'/%3E%3Crect x='120' y='80' width='38' height='180'/%3E%3Crect x='170' y='150' width='30' height='110'/%3E%3Cpolygon points='230,60 250,40 270,60 270,260 230,260'/%3E%3Crect x='300' y='100' width='52' height='160'/%3E%3Crect x='366' y='40' width='30' height='220'/%3E%3Crect x='410' y='130' width='40' height='130'/%3E%3Crect x='470' y='90' width='34' height='170'/%3E%3Cpolygon points='540,70 560,20 580,70 580,260 540,260'/%3E%3Crect x='610' y='120' width='48' height='140'/%3E%3Crect x='672' y='70' width='36' height='190'/%3E%3Crect x='724' y='140' width='30' height='120'/%3E%3Crect x='770' y='100' width='50' height='160'/%3E%3Crect x='834' y='50' width='28' height='210'/%3E%3Crect x='876' y='130' width='42' height='130'/%3E%3Cpolygon points='940,80 958,50 976,80 976,260 940,260'/%3E%3Crect x='1000' y='110' width='46' height='150'/%3E%3Crect x='1060' y='150' width='34' height='110'/%3E%3Crect x='1104' y='90' width='40' height='170'/%3E%3C/g%3E%3C/svg%3E";
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mahfol Makfol By Business Partner | Your Gateway to Investing in Saudi Arabia</title>
  <meta name="description" content="A premium investor gateway to the Kingdom of Saudi Arabia: MISA licensing, government & authority relations, curated meetings, investment forums, executive hospitality, and a multilingual smart concierge. Powered by Business Partner." />
  <link rel="icon" href="/logo.png" />
  <meta property="og:title" content="Mahfol Makfol By Business Partner | Invest in Saudi Arabia" />
  <meta property="og:description" content="Government relations, MISA setup, meetings, forums, and executive hospitality for foreign investors in Saudi Arabia." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="brand">
        <img src="/logo.png" alt="Business Partner" class="brand-logo" />
        <span class="brand-txt">Mahfol Makfol <em data-i18n="brand.by">By Business Partner</em></span>
      </a>
      <nav class="nav-links">
        <a href="#concierge" data-i18n="nav.concierge">Concierge</a>
        <a href="#services" data-i18n="nav.services">Services</a>
        <a href="#cities" data-i18n="nav.cities">Cities</a>
        <a href="#sectors" data-i18n="nav.sectors">Sectors</a>
        <a href="#how" data-i18n="nav.how">How it works</a>
      </nav>
      <div class="nav-right">
        <div class="lang-wrap">
          <button class="lang-btn" id="langBtn" aria-haspopup="true">🌐 <span id="langLabel">EN</span> ▾</button>
          <div class="lang-menu" id="langMenu" hidden>
            <button data-lang="en">🇬🇧 English</button>
            <button data-lang="ar">🇸🇦 العربية</button>
            <button data-lang="zh">🇨🇳 中文</button>
            <button data-lang="ru">🇷🇺 Русский</button>
            <button data-lang="es">🇪🇸 Español</button>
            <button data-lang="fr">🇫🇷 Français</button>
            <button data-lang="ko">🇰🇷 한국어</button>
            <button data-lang="ja">🇯🇵 日本語</button>
          </div>
        </div>
        <a class="btn btn-gold" href="#concierge" data-i18n="cta.start">Start</a>
      </div>
    </div>
  </header>

  <main id="top">

    <!-- Hero + concierge -->
    <section class="hero">
      <div class="hero-inner container">
        <div class="hero-copy">
          <p class="hero-badge" data-i18n="hero.badge">✦ Powered by Business Partner · Vision 2030 enabler</p>
          <h1 data-i18n="hero.h1">Your Gateway to Investing in Saudi Arabia</h1>
          <p class="hero-sub" data-i18n="hero.sub">From your first interest to signing on the ground — we open the doors to ministries, authorities and decision-makers, arrange your meetings, forums and site visits, and host you at the Kingdom's finest. One trusted partner, end to end.</p>
          <div class="hero-stats">
            <div><b>100%</b><span data-i18n="hero.s1">Foreign ownership in many sectors</span></div>
            <div><b>0%</b><span data-i18n="hero.s2">Personal income tax</span></div>
            <div><b>$1T+</b><span data-i18n="hero.s3">Giga-project pipeline</span></div>
            <div><b>MISA</b><span data-i18n="hero.s4">Investor license facilitation</span></div>
          </div>
        </div>

        <!-- Smart concierge wizard -->
        <div class="concierge" id="concierge">
          <div class="cx-head">
            <span class="cx-avatar">🧭</span>
            <div>
              <b data-i18n="cx.title">Investment Concierge</b>
              <small data-i18n="cx.sub">Answer a few questions — get a tailored plan</small>
            </div>
          </div>
          <div class="cx-progress"><div class="cx-bar" id="cxBar"></div></div>
          <div class="cx-body" id="cxBody"><!-- injected by JS --></div>
        </div>
      </div>
    </section>

    <!-- Trust -->
    <div class="trust">
      <div class="container trust-inner">
        <span data-i18n="trust.1">🏛️ Ministry of Investment (MISA) facilitation</span>
        <span data-i18n="trust.2">🤝 Government & authority relations</span>
        <span data-i18n="trust.3">🗓️ Curated meetings & forums</span>
        <span data-i18n="trust.4">🌐 8 languages · dedicated concierge</span>
        <span data-i18n="trust.5">💼 Registered Saudi company</span>
      </div>
    </div>

    <!-- Services -->
    <section class="section" id="services">
      <div class="container">
        <h2 class="section-title" data-i18n="sec.services">Investor Services</h2>
        <p class="section-sub" data-i18n="sec.servicesSub">A concierge-grade service built for foreign investors entering the Saudi market</p>
        <div class="grid grid-4">
          <div class="scard"><span>🏛️</span><h3 data-i18n="sv1.t">MISA Licensing & Setup</h3><p data-i18n="sv1.d">Investor license, company formation, RHQ program, and full establishment support through the Ministry of Investment.</p></div>
          <div class="scard"><span>🤝</span><h3 data-i18n="sv2.t">Government Relations</h3><p data-i18n="sv2.d">Direct introductions to ministries, regional authorities, chambers of commerce, and sector regulators.</p></div>
          <div class="scard"><span>🗓️</span><h3 data-i18n="sv3.t">Curated Meetings</h3><p data-i18n="sv3.d">We arrange your agenda: decision-makers, potential partners, and site visits — scheduled and briefed.</p></div>
          <div class="scard"><span>🎤</span><h3 data-i18n="sv4.t">Forums, Workshops & Events</h3><p data-i18n="sv4.d">Access to investment forums, sector workshops, and official events relevant to your field.</p></div>
          <div class="scard"><span>🔎</span><h3 data-i18n="sv5.t">Opportunity Sourcing</h3><p data-i18n="sv5.d">Market-entry studies, sector deep-dives, and matchmaking with vetted local partners and funds.</p></div>
          <div class="scard"><span>🍽️</span><h3 data-i18n="sv6.t">Executive Hospitality</h3><p data-i18n="sv6.d">Luxury hotels, business lunches, official invitations, and protocol handled with discretion.</p></div>
          <div class="scard"><span>🕌</span><h3 data-i18n="sv7.t">Cultural Immersion</h3><p data-i18n="sv7.d">A curated cultural program so you understand the market, its people, and how business is done here.</p></div>
          <div class="scard"><span>⚖️</span><h3 data-i18n="sv8.t">Legal, Tax & Advisory</h3><p data-i18n="sv8.d">Guidance on ownership, incentives, taxation, and compliance through trusted local advisors.</p></div>
        </div>
      </div>
    </section>

    <!-- Cities -->
    <section class="section section-alt" id="cities">
      <div class="container">
        <h2 class="section-title" data-i18n="sec.cities">Investor Packages by City</h2>
        <p class="section-sub" data-i18n="sec.citiesSub">Each program pairs your sector with the right authorities, meetings, and executive hospitality</p>
        <div class="city-grid" id="cityGrid"><!-- injected --></div>
      </div>
    </section>

    <!-- Sectors -->
    <section class="section" id="sectors">
      <div class="container">
        <h2 class="section-title" data-i18n="sec.sectors">Priority Sectors — Vision 2030</h2>
        <p class="section-sub" data-i18n="sec.sectorsSub">Where the Kingdom is investing — and where opportunity is opening for you</p>
        <div class="sector-grid" id="sectorGrid"><!-- injected --></div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section section-alt" id="how">
      <div class="container">
        <h2 class="section-title" data-i18n="sec.how">How It Works</h2>
        <div class="steps">
          <div class="step"><b>1</b><h3 data-i18n="hw1.t">Tell us your interest</h3><p data-i18n="hw1.d">Use the concierge or talk to us — sector, goals, and timeline.</p></div>
          <div class="step"><b>2</b><h3 data-i18n="hw2.t">We design your program</h3><p data-i18n="hw2.d">Meetings, authorities, forums, site visits, and hospitality — tailored.</p></div>
          <div class="step"><b>3</b><h3 data-i18n="hw3.t">You visit the Kingdom</h3><p data-i18n="hw3.d">We host and guide you end to end, with a dedicated concierge.</p></div>
          <div class="step"><b>4</b><h3 data-i18n="hw4.t">You invest with confidence</h3><p data-i18n="hw4.d">Licensing, partners, and follow-through until you're established.</p></div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section" id="contact">
      <div class="container narrow center">
        <h2 class="section-title" data-i18n="sec.contact">Let's Open the Kingdom for You</h2>
        <p class="section-sub" data-i18n="sec.contactSub">Speak with a dedicated investment concierge — in your language</p>
        <div class="cta-row">
          <a class="btn btn-wa btn-lg" id="waMain" href={`https://wa.me/${contact.wa}`} target="_blank" rel="noopener">💬 WhatsApp Concierge</a>
          <a class="btn btn-outline btn-lg" href={`mailto:${contact.email}`}>{contact.email}</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <img src="/logo.png" alt="Business Partner" class="foot-logo" />
      <p><b>Mahfol Makfol</b> By Business Partner</p>
      <p class="foot-legal" data-i18n="foot.legal">Investor gateway to the Kingdom of Saudi Arabia · Registered Saudi company</p>
      <p class="foot-legal">© 2026 Business Partner</p>
    </div>
  </footer>

  <a class="wa-fab" id="waFab" href={`https://wa.me/${contact.wa}`} target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg viewBox="0 0 24 24" width="30" height="30" fill="#fff"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.83 14.12c-.25.7-1.44 1.34-1.98 1.39-.54.05-1.04.24-3.5-.73-2.96-1.17-4.83-4.2-4.98-4.39-.14-.19-1.18-1.57-1.18-3s.75-2.13 1.02-2.42c.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.25.58.84 2 .91 2.15.07.14.12.31.02.5-.09.19-.14.31-.28.48-.14.17-.3.37-.42.5-.14.14-.29.29-.13.57.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.41.29.14.45.12.62-.07.17-.19.71-.83.9-1.11.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.18 1.39z"/></svg>
  </a>

<style is:global>
  :root {
    --navy: #0B1B5A;
    --navy-2: #13246e;
    --navy-soft: #eef1fb;
    --gold: #c6a45c;
    --gold-strong: #a9863b;
    --bg: #ffffff;
    --bg-alt: #f6f8fd;
    --text: #14213d;
    --muted: #5b6480;
    --border: #e5e8f3;
    --radius: 16px;
    --shadow: 0 10px 40px rgba(11,27,90,0.08);
    --font: 'Inter', 'Tajawal', 'Segoe UI', sans-serif;
    --serif: 'Playfair Display', 'Tajawal', serif;
  }
  html[dir="rtl"] { --font: 'Tajawal', 'Inter', sans-serif; --serif: 'Tajawal', serif; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.75; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 22px; }
  .container.narrow { max-width: 820px; }
  .center { text-align: center; }

  /* Nav */
  .nav { position: sticky; top: 0; z-index: 60; background: rgba(255,255,255,0.94); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
  .nav-inner { display: flex; align-items: center; gap: 18px; padding: 12px 22px; }
  .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--navy); }
  .brand-logo { height: 34px; width: auto; }
  .brand-txt { font-weight: 800; font-size: 1.02rem; line-height: 1.1; }
  .brand-txt em { display: block; font-style: normal; font-size: 0.7rem; color: var(--gold-strong); font-weight: 700; letter-spacing: .02em; }
  .nav-links { display: flex; gap: 22px; margin-inline-start: auto; }
  .nav-links a { color: var(--muted); text-decoration: none; font-weight: 600; font-size: 0.92rem; }
  .nav-links a:hover { color: var(--navy); }
  .nav-right { display: flex; align-items: center; gap: 12px; }

  .lang-wrap { position: relative; }
  .lang-btn { background: var(--navy-soft); border: 1px solid var(--border); color: var(--navy); font-weight: 700; font-family: inherit; padding: 8px 12px; border-radius: 999px; cursor: pointer; font-size: 0.85rem; }
  .lang-menu { position: absolute; top: 110%; inset-inline-end: 0; background: #fff; border: 1px solid var(--border); border-radius: 12px; box-shadow: var(--shadow); padding: 6px; min-width: 160px; z-index: 70; }
  .lang-menu button { display: block; width: 100%; text-align: start; background: none; border: none; padding: 9px 12px; border-radius: 8px; cursor: pointer; font-family: inherit; font-size: 0.9rem; color: var(--text); }
  .lang-menu button:hover { background: var(--navy-soft); }

  .btn { display: inline-block; padding: 11px 22px; border-radius: 999px; font-weight: 700; text-decoration: none; font-size: 0.92rem; border: none; cursor: pointer; font-family: inherit; transition: transform .15s, box-shadow .15s; white-space: nowrap; }
  .btn:hover { transform: translateY(-2px); }
  .btn-gold { background: linear-gradient(135deg, var(--gold), var(--gold-strong)); color: #1c1608; box-shadow: 0 6px 20px rgba(198,164,92,0.35); }
  .btn-navy { background: linear-gradient(135deg, var(--navy), var(--navy-2)); color: #fff; }
  .btn-wa { background: linear-gradient(135deg, #2bdc70, #1da851); color: #fff; box-shadow: 0 6px 20px rgba(37,211,102,0.3); }
  .btn-outline { border: 1.5px solid var(--navy); color: var(--navy); background: transparent; }
  .btn-lg { padding: 15px 32px; font-size: 1.02rem; }

  /* Hero */
  .hero { background: radial-gradient(ellipse 70% 60% at 15% 10%, rgba(11,27,90,0.06), transparent), linear-gradient(180deg, #fbfcff, var(--bg)); padding: 60px 0 70px; }
  .hero-inner { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 46px; align-items: center; }
  .hero-badge { display: inline-block; padding: 7px 18px; border-radius: 999px; background: var(--navy-soft); color: var(--navy); font-weight: 700; font-size: 0.82rem; margin-bottom: 20px; }
  .hero h1 { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.18; color: var(--navy); margin-bottom: 18px; font-weight: 800; }
  .hero-sub { color: var(--muted); font-size: 1.08rem; margin-bottom: 30px; max-width: 560px; }
  .hero-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 520px; }
  .hero-stats div { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 14px 18px; box-shadow: var(--shadow); }
  .hero-stats b { display: block; color: var(--gold-strong); font-size: 1.5rem; font-weight: 800; font-family: var(--serif); }
  .hero-stats span { color: var(--muted); font-size: 0.82rem; }

  /* Concierge */
  .concierge { background: linear-gradient(160deg, var(--navy), var(--navy-2)); border-radius: 22px; padding: 24px; color: #fff; box-shadow: 0 20px 60px rgba(11,27,90,0.30); }
  .cx-head { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .cx-avatar { width: 48px; height: 48px; border-radius: 50%; background: rgba(198,164,92,0.2); border: 1px solid rgba(198,164,92,0.5); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
  .cx-head b { display: block; font-size: 1.1rem; }
  .cx-head small { color: #b9c2ea; font-size: 0.82rem; }
  .cx-progress { height: 6px; background: rgba(255,255,255,0.12); border-radius: 999px; overflow: hidden; margin-bottom: 20px; }
  .cx-bar { height: 100%; width: 0; background: linear-gradient(90deg, var(--gold), var(--gold-strong)); transition: width .4s ease; }
  .cx-q { font-size: 1.15rem; font-weight: 700; margin-bottom: 16px; }
  .cx-options { display: flex; flex-direction: column; gap: 10px; }
  .cx-opt { display: flex; align-items: center; gap: 10px; text-align: start; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); color: #fff; border-radius: 12px; padding: 13px 16px; font-family: inherit; font-size: 0.95rem; cursor: pointer; transition: all .15s; }
  .cx-opt:hover { background: rgba(198,164,92,0.18); border-color: var(--gold); transform: translateX(-3px); }
  .cx-opt.sel { background: rgba(198,164,92,0.28); border-color: var(--gold); }
  .cx-opt .ic { font-size: 1.2rem; }
  .cx-actions { display: flex; gap: 10px; margin-top: 18px; }
  .cx-btn { flex: 1; padding: 12px; border-radius: 12px; font-family: inherit; font-weight: 700; cursor: pointer; border: none; font-size: 0.92rem; }
  .cx-next { background: linear-gradient(135deg, var(--gold), var(--gold-strong)); color: #1c1608; }
  .cx-back { background: rgba(255,255,255,0.1); color: #fff; flex: 0 0 auto; padding: 12px 18px; }
  .cx-next:disabled { opacity: .4; cursor: not-allowed; }
  .cx-result h3 { font-family: var(--serif); font-size: 1.4rem; margin-bottom: 10px; }
  .cx-result p { color: #c7cef0; margin-bottom: 8px; font-size: 0.95rem; }
  .cx-summary { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14); border-radius: 12px; padding: 14px 16px; margin: 14px 0; font-size: 0.9rem; }
  .cx-summary div { padding: 3px 0; }
  .cx-summary .k { color: var(--gold); font-weight: 700; }
  .cx-hint { color: #9fa9d6; font-size: 0.78rem; text-align: center; margin-top: 10px; }

  /* Trust */
  .trust { background: var(--navy); color: #fff; padding: 14px 0; }
  .trust-inner { display: flex; flex-wrap: wrap; gap: 10px 30px; justify-content: center; font-size: 0.85rem; font-weight: 600; color: #dfe4fb; }

  /* Sections */
  .section { padding: 84px 0; }
  .section-alt { background: var(--bg-alt); }
  .section-title { text-align: center; font-family: var(--serif); font-size: clamp(1.7rem, 3vw, 2.5rem); color: var(--navy); font-weight: 800; margin-bottom: 12px; }
  .section-sub { text-align: center; color: var(--muted); max-width: 720px; margin: 0 auto 48px; font-size: 1.05rem; }

  /* Services */
  .grid { display: grid; gap: 20px; }
  .grid-4 { grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
  .scard { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow); }
  .scard span { font-size: 2rem; display: block; margin-bottom: 12px; }
  .scard h3 { color: var(--navy); font-size: 1.12rem; margin-bottom: 8px; }
  .scard p { color: var(--muted); font-size: 0.92rem; }

  /* Cities */
  .city-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 22px; }
  .city-card { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); display: flex; flex-direction: column; }
  .city-banner { position: relative; height: 130px; background: linear-gradient(120deg, var(--navy), var(--navy-2)); background-size: cover; background-position: bottom; display: flex; align-items: flex-end; padding: 16px 20px; }
  .city-banner h3 { position: relative; z-index: 1; color: #fff; font-family: var(--serif); font-size: 1.5rem; }
  .city-banner .city-ar { position: relative; z-index: 1; color: var(--gold); font-size: 0.9rem; font-weight: 700; margin-inline-start: 8px; }
  .city-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
  .city-tag { color: var(--gold-strong); font-weight: 700; font-size: 0.9rem; margin-bottom: 10px; }
  .city-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); font-weight: 700; margin: 12px 0 6px; }
  .city-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .city-chips span { font-size: 0.78rem; background: var(--navy-soft); color: var(--navy); border-radius: 999px; padding: 3px 10px; font-weight: 600; }
  .city-entities { list-style: none; margin: 6px 0 0; }
  .city-entities li { position: relative; padding-inline-start: 18px; font-size: 0.86rem; color: var(--text); margin-bottom: 4px; }
  .city-entities li::before { content: '▹'; position: absolute; inset-inline-start: 0; color: var(--gold-strong); font-weight: 800; }
  .city-incl { list-style: none; margin: 6px 0 0; }
  .city-incl li { position: relative; padding-inline-start: 20px; font-size: 0.86rem; color: var(--muted); margin-bottom: 4px; }
  .city-incl li::before { content: '✓'; position: absolute; inset-inline-start: 0; color: var(--gold-strong); font-weight: 800; }
  .city-foot { margin-top: auto; padding-top: 16px; }
  .city-foot .btn { width: 100%; text-align: center; }

  /* Sectors */
  .sector-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 14px; }
  .sector { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 20px; text-align: center; box-shadow: var(--shadow); }
  .sector span { font-size: 1.9rem; display: block; margin-bottom: 8px; }
  .sector b { color: var(--navy); display: block; font-size: 0.98rem; }
  .sector small { color: var(--muted); font-size: 0.78rem; }

  /* Steps */
  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
  .step { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow); position: relative; }
  .step b { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--navy), var(--navy-2)); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 1.2rem; margin-bottom: 12px; }
  .step h3 { color: var(--navy); font-size: 1.05rem; margin-bottom: 6px; }
  .step p { color: var(--muted); font-size: 0.9rem; }

  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 24px; }

  /* Footer */
  .footer { background: var(--navy); color: #fff; padding: 40px 0 80px; text-align: center; }
  .foot-logo { height: 40px; filter: brightness(0) invert(1); opacity: .9; margin-bottom: 14px; }
  .footer p { margin-bottom: 6px; }
  .foot-legal { color: #aeb6e0; font-size: 0.85rem; }

  .wa-fab { position: fixed; bottom: 22px; inset-inline-start: 22px; z-index: 70; width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, #2bdc70, #1da851); display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 24px rgba(37,211,102,0.45); }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
