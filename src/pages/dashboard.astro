---
// لوحة تحكم الإيجنتس — صفحة مخفية للمالك (باهر).
// تحكم بكل موظف: تشغيل/إيقاف · مقفول/مدفوع · اختبار مباشر عبر /api/agent → n8n.
import { agents } from '../content/agents';
import '../styles/global.css';

export const prerender = false;

// نعرض كل الفريق. الوكلاء الأحياء في n8n (لهم ورك فلو منشور) قابلون للاختبار.
const LIVE = new Set(['badr', 'malak', 'ahmed', 'farah', 'mohammed', 'abdulaziz', 'mazen']);
const cards = agents.map((a) => ({ ...a, live: LIVE.has(a.slug) }));
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow, noarchive" />
  <title>لوحة تحكم الإيجنتس — Business Partner</title>
</head>
<body style="padding-top: 0;">
  <main class="db-wrap">
    <header class="db-head">
      <p class="db-badge">🔒 لوحة داخلية للمالك — تحكم واختبار كل موظف</p>
      <h1>🎛️ لوحة تحكم الفريق</h1>
      <p class="db-sub">
        كل موظف = إيجنت مستقل. تتحكم فيه هنا: <b>تشغيل/إيقاف</b>، <b>مقفول/مدفوع</b> (لا يخدم العميل إلا بعد الدفع)،
        و<b>تجربة مباشرة</b> عبر n8n. إعداداتك تُحفظ في هذا المتصفح.
      </p>
      <div class="db-modes">
        <span>وضع العرض:</span>
        <label class="db-seg"><input type="radio" name="mode" value="owner" checked /> 🧑‍💼 مالك (اختبار كل شيء)</label>
        <label class="db-seg"><input type="radio" name="mode" value="client" /> 👤 معاينة كعميل (يحترم القفل)</label>
      </div>
    </header>

    <div class="db-grid">
      {cards.map((a) => (
        <section class="db-card" data-agent={a.slug} data-live={a.live ? '1' : '0'}>
          <div class="db-card-top">
            <span class="db-emoji">{a.emoji}</span>
            <div class="db-title">
              <h2>{a.name} <span class="db-en">{a.nameEn}</span></h2>
              <p class="db-role">{a.role}</p>
            </div>
            <span class={`db-livebadge ${a.live ? 'on' : 'off'}`}>{a.live ? '🟢 حي في n8n' : '⏳ قيد البناء'}</span>
          </div>

          <div class="db-controls">
            <label class="db-toggle">
              <input type="checkbox" class="ctl-active" checked={a.live} />
              <span>مُفعّل</span>
            </label>
            <label class="db-toggle">
              <input type="checkbox" class="ctl-paid" />
              <span>مدفوع (مفتوح للعميل)</span>
            </label>
          </div>

          <div class="db-test">
            <div class="db-chat" aria-live="polite"></div>
            <div class="db-inrow">
              <input type="text" class="db-input" placeholder="اكتب رسالة تجريبية…" />
              <button class="db-send" type="button">إرسال</button>
            </div>
            <p class="db-hint"></p>
          </div>
        </section>
      ))}
    </div>

    <footer class="db-foot">
      <p>🔒 النموذج التشغيلي Concierge: الإيجنت يجهّز ويوصي — أي مخرج خارجي «بانتظار الموافقة» ولا يُرسل آلياً. لا OTP ولا كلمات مرور.</p>
      <p class="db-note">ملاحظة: حالة «مدفوع/مُفعّل» محفوظة في متصفحك للتحكم والاختبار. الربط بالدفع الفعلي (بوابة دفع + قاعدة بيانات) خطوة تالية لفرض القفل على العملاء الحقيقيين.</p>
    </footer>
  </main>

  <style>
    .db-wrap { max-width: 1150px; margin: 0 auto; padding: 2rem 1.1rem 4rem; }
    .db-head { text-align: center; margin-bottom: 1.8rem; }
    .db-badge { display: inline-block; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; border-radius: 999px; padding: 0.35rem 1rem; font-size: 0.85rem; margin-bottom: 0.8rem; }
    .db-head h1 { margin-bottom: 0.5rem; }
    .db-sub { color: var(--muted); max-width: 760px; margin: 0 auto 1rem; }
    .db-modes { display: inline-flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 0.5rem 0.9rem; font-size: 0.9rem; }
    .db-seg { cursor: pointer; display: inline-flex; gap: 0.3rem; align-items: center; }
    .db-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.15rem; }
    .db-card { background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 1.25rem; box-shadow: var(--shadow); display: flex; flex-direction: column; }
    .db-card.locked { opacity: 0.55; }
    .db-card-top { display: flex; gap: 0.7rem; align-items: flex-start; margin-bottom: 0.9rem; }
    .db-emoji { font-size: 1.9rem; }
    .db-title { flex: 1; }
    .db-title h2 { font-size: 1.2rem; margin-bottom: 0.1rem; }
    .db-en { color: var(--muted); font-size: 0.85rem; font-weight: 400; }
    .db-role { color: var(--brand); font-weight: 600; font-size: 0.85rem; }
    .db-livebadge { font-size: 0.72rem; padding: 0.2rem 0.55rem; border-radius: 999px; white-space: nowrap; font-weight: 600; }
    .db-livebadge.on { background: #d1fae5; color: #065f46; }
    .db-livebadge.off { background: #f1f5f9; color: #475569; }
    .db-controls { display: flex; gap: 1rem; flex-wrap: wrap; padding: 0.6rem 0; border-top: 1px dashed var(--line); border-bottom: 1px dashed var(--line); margin-bottom: 0.8rem; }
    .db-toggle { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; cursor: pointer; }
    .db-test { display: flex; flex-direction: column; gap: 0.55rem; }
    .db-chat { min-height: 44px; max-height: 240px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9rem; }
    .db-msg { padding: 0.55rem 0.75rem; border-radius: 12px; max-width: 92%; white-space: pre-wrap; line-height: 1.6; }
    .db-msg.me { background: var(--brand); color: #fff; align-self: flex-start; }
    .db-msg.bot { background: #fff; border: 1px solid var(--line); align-self: flex-end; }
    .db-msg.sys { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; align-self: center; font-size: 0.82rem; }
    .db-inrow { display: flex; gap: 0.5rem; }
    .db-input { flex: 1; border: 1px solid var(--line); border-radius: 10px; padding: 0.55rem 0.7rem; font: inherit; }
    .db-send { background: var(--brand); color: #fff; border: 0; border-radius: 10px; padding: 0 1rem; font-weight: 600; cursor: pointer; }
    .db-send:disabled { opacity: 0.5; cursor: not-allowed; }
    .db-hint { font-size: 0.75rem; color: var(--muted); min-height: 1em; }
    .db-foot { margin-top: 2.5rem; background: #fffbeb; border: 1px solid #fde68a; color: #92400e; border-radius: 12px; padding: 1rem 1.25rem; font-size: 0.88rem; }
    .db-note { margin-top: 0.5rem; color: #78716c; }
  </style>

  <script>
    const KEY = 'bp_agent_controls_v1';
    const load = () => { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; } };
    const save = (s) => localStorage.setItem(KEY, JSON.stringify(s));
    let state = load();
    let mode = 'owner';

    const cards = Array.from(document.querySelectorAll('.db-card'));

    function persist(slug, patch) {
      state[slug] = Object.assign({}, state[slug], patch);
      save(state);
    }

    function applyLock(card) {
      const paid = card.querySelector('.ctl-paid').checked;
      const active = card.querySelector('.ctl-active').checked;
      const clientBlocked = mode === 'client' && (!paid || !active);
      card.classList.toggle('locked', clientBlocked);
      const send = card.querySelector('.db-send');
      const live = card.dataset.live === '1';
      send.disabled = clientBlocked;
      const hint = card.querySelector('.db-hint');
      if (clientBlocked) hint.textContent = !active ? 'موقوف — العميل لا يصله رد.' : '🔒 مقفول — يتطلب الدفع لتفعيله للعميل.';
      else if (!live) hint.textContent = 'قيد البناء في n8n — التجربة ترجع رسالة توضيحية.';
      else hint.textContent = '';
    }

    function pushMsg(card, text, cls) {
      const box = card.querySelector('.db-chat');
      const el = document.createElement('div');
      el.className = 'db-msg ' + cls;
      el.textContent = text;
      box.appendChild(el);
      box.scrollTop = box.scrollHeight;
      return el;
    }

    async function send(card) {
      const input = card.querySelector('.db-input');
      const msg = input.value.trim();
      if (!msg) return;
      const slug = card.dataset.agent;
      input.value = '';
      pushMsg(card, msg, 'me');
      const thinking = pushMsg(card, '…', 'bot');
      try {
        const r = await fetch('/api/agent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ agent: slug, message: msg }),
        });
        const data = await r.json();
        thinking.textContent = data.reply || 'لا يوجد رد.';
        if (data.proposal_ready) pushMsg(card, '✅ أنشئ Draft Proposal بحالة «بانتظار الموافقة».', 'sys');
        if (data.engine_fallback) pushMsg(card, 'ℹ️ استُخدم الرد الاحتياطي (تعذّر Claude مؤقتاً).', 'sys');
      } catch (e) {
        thinking.textContent = 'تعذّر الاتصال بالخادم.';
      }
    }

    cards.forEach((card) => {
      const slug = card.dataset.agent;
      const active = card.querySelector('.ctl-active');
      const paid = card.querySelector('.ctl-paid');
      if (state[slug]) {
        if (typeof state[slug].active === 'boolean') active.checked = state[slug].active;
        if (typeof state[slug].paid === 'boolean') paid.checked = state[slug].paid;
      }
      active.addEventListener('change', () => { persist(slug, { active: active.checked }); applyLock(card); });
      paid.addEventListener('change', () => { persist(slug, { paid: paid.checked }); applyLock(card); });
      card.querySelector('.db-send').addEventListener('click', () => send(card));
      card.querySelector('.db-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') send(card); });
      applyLock(card);
    });

    document.querySelectorAll('input[name="mode"]').forEach((r) =>
      r.addEventListener('change', (e) => { mode = e.target.value; cards.forEach(applyLock); })
    );
  </script>
</body>
</html>
