---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CallFab from '../../../components/CallFab.astro';
import { getContent } from '../../../content/copy';

export const prerender = true;
const locale = 'en';
const t = getContent(locale);

const stages = [
  { key: 'cv', title: '📄 CV Selection', color: '#2563EB' },
  { key: 'screen', title: '🔎 Screening', color: '#7C3AED' },
  { key: 'interview', title: '💬 Interview', color: '#0891B2' },
  { key: 'offer', title: '📝 Offer', color: '#CA8A04' },
  { key: 'contract', title: '📜 Contract', color: '#DB2777' },
  { key: 'visa', title: '🛂 Visa/Sourcing', color: '#EA580C' },
  { key: 'entry', title: '✈️ Entry to KSA', color: '#059669' },
  { key: 'onboard', title: '🎯 Onboarding', color: '#16A34A' },
];
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="width:100%; padding:100px 20px 60px;">
    <div style="max-width:1400px; margin:0 auto;">
      <div style="display:flex; flex-wrap:wrap; gap:16px; align-items:center; justify-content:space-between; margin-bottom:10px;">
        <div>
          <h1 style="font-size:36px; color:#0F172A; font-weight:800; margin:0 0 6px;">📊 Recruitment Dashboard</h1>
          <p style="color:#64748B; font-size:17px; margin:0;">The full hiring cycle — from CV selection to onboarding inside Saudi Arabia.</p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <button id="addBtn" style="padding:12px 20px; background:#2563EB; color:#fff; border:0; border-radius:10px; font-weight:800; cursor:pointer;">➕ Add candidate</button>
          <a href="/en/employer" style="padding:12px 20px; background:#0F172A; color:#fff; border-radius:10px; font-weight:800; text-decoration:none;">🏢 Employer portal</a>
        </div>
      </div>

      <p style="color:#94A3B8; font-size:13px; margin:0 0 20px;">💡 Demo running locally in your browser (localStorage). Once the backend architecture (Supabase) is approved, data becomes live and shared across the team.</p>

      <div id="board" style="display:grid; grid-auto-flow:column; grid-auto-columns:minmax(260px,1fr); gap:14px; overflow-x:auto; padding-bottom:16px;"></div>
    </div>
  </main>

  <CallFab />
  <Footer lang={locale} t={t} />

  <script is:inline define:vars={{ stages }}>
    const KEY = 'bp_ats_board_en_v1';
    const board = document.getElementById('board');
    const seed = [
      { id: 1, name: 'Abdullah Moez', role: 'Sales Specialist', nat: 'Saudi', stage: 'screen' },
      { id: 2, name: 'Ahmed Elkerdawy', role: 'Accountant', nat: 'Non-Saudi', stage: 'cv' },
      { id: 3, name: 'Nasser Alharbi', role: 'Ops Supervisor', nat: 'Saudi', stage: 'interview' },
      { id: 4, name: 'Mohammed Firoz', role: 'Maintenance Tech', nat: 'Non-Saudi', stage: 'visa' },
    ];
    let cards = JSON.parse(localStorage.getItem(KEY) || 'null') || seed;
    const save = () => localStorage.setItem(KEY, JSON.stringify(cards));
    const idx = (k) => stages.findIndex(s => s.key === k);

    function move(id, dir) {
      const c = cards.find(x => x.id === id); if (!c) return;
      const i = idx(c.stage) + dir;
      if (i < 0 || i >= stages.length) return;
      c.stage = stages[i].key; save(); render();
    }
    function del(id) { cards = cards.filter(x => x.id !== id); save(); render(); }

    function render() {
      board.innerHTML = '';
      stages.forEach(s => {
        const col = document.createElement('div');
        col.style.cssText = 'background:#F1F5F9; border-radius:14px; padding:12px; min-height:200px;';
        const list = cards.filter(c => c.stage === s.key);
        col.innerHTML = `<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
          <span style="font-weight:800; color:#0F172A; font-size:14px;">${s.title}</span>
          <span style="background:${s.color}; color:#fff; border-radius:999px; padding:1px 9px; font-size:12px; font-weight:700;">${list.length}</span></div>`;
        list.forEach(c => {
          const card = document.createElement('div');
          card.style.cssText = 'background:#fff; border:1px solid #E2E8F0; border-radius:10px; padding:12px; margin-bottom:10px; box-shadow:0 1px 3px rgba(15,23,42,.05);';
          card.innerHTML = `<div style="font-weight:800; color:#0F172A; font-size:15px;">${c.name}</div>
            <div style="color:#64748B; font-size:13px; margin:2px 0 8px;">${c.role} · ${c.nat}</div>
            <div style="display:flex; gap:6px;">
              <button data-a="prev" data-id="${c.id}" style="flex:1; border:1px solid #CBD5E1; background:#fff; border-radius:7px; padding:5px; cursor:pointer;">◀</button>
              <button data-a="next" data-id="${c.id}" style="flex:1; border:0; background:${s.color}; color:#fff; border-radius:7px; padding:5px; cursor:pointer;">▶</button>
              <button data-a="del" data-id="${c.id}" style="border:1px solid #FCA5A5; color:#B91C1C; background:#fff; border-radius:7px; padding:5px 8px; cursor:pointer;">✕</button>
            </div>`;
          col.appendChild(card);
        });
        board.appendChild(col);
      });
      board.querySelectorAll('button[data-a]').forEach(b => b.addEventListener('click', () => {
        const id = +b.dataset.id;
        if (b.dataset.a === 'prev') move(id, -1);
        else if (b.dataset.a === 'next') move(id, 1);
        else del(id);
      }));
    }

    document.getElementById('addBtn').addEventListener('click', () => {
      const name = prompt('Candidate name:'); if (!name) return;
      const role = prompt('Role:') || '—';
      const nat = prompt('Nationality (Saudi/Non-Saudi):') || '—';
      cards.push({ id: Date.now(), name, role, nat, stage: 'cv' });
      save(); render();
    });

    render();
  </script>
</BaseLayout>
