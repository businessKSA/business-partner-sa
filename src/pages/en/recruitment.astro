---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = getContent(locale);

const WA = 'https://wa.me/966530540231';

const entries = [
  { icon: '🏢', title: 'Employers', desc: 'Register your company, create a job post with an AI copilot, and receive pre-screened, interview-ready candidates.', cta: 'Start as employer', href: '#employer' },
  { icon: '👤', title: 'Job Seekers', desc: 'Build your profile, upload your CV, and apply to jobs inside Saudi Arabia — with free AI assessment and coaching.', cta: 'Register as seeker', href: '#seeker' },
  { icon: '📊', title: 'Recruitment Dashboard', desc: 'One unified board: screening kanban, chat, interview scheduling, offers, and live Qiwa compliance tracking.', cta: 'Open dashboard', href: '#dashboard' },
];

const lifecycle = [
  { n: '1', icon: '📄', title: 'CV Selection', desc: 'Smart CV bank + AI matching shortlists the best fit from the candidate pool.' },
  { n: '2', icon: '🔎', title: 'Screening', desc: 'AI assessments and interviews before the candidate reaches the employer.' },
  { n: '3', icon: '💬', title: 'Interviews', desc: 'Google Calendar scheduling with Meet/Teams/Zoom links and notifications for all.' },
  { n: '4', icon: '📝', title: 'Job Offer', desc: 'An agent writes the offer on the company brand, with a 24-hour accept/decline timer.' },
  { n: '5', icon: '📜', title: 'Contracting', desc: 'Official contract authenticated in Qiwa under Saudi labor law.' },
  { n: '6', icon: '🛂', title: 'Visa & Sourcing', desc: 'Visa and work permit issuance via Qiwa for non-Saudis (external sourcing).' },
  { n: '7', icon: '✈️', title: 'Entry to the Kingdom', desc: 'Arrival, medical exam, Iqama, and service transfer via Qiwa.' },
  { n: '8', icon: '🎯', title: 'Onboarding', desc: 'Full onboarding inside Saudi Arabia: GOSI registration, Mudad wage protection, and go-live.' },
];

const tracks = [
  { icon: '🇸🇦', title: 'Hiring Saudis', desc: 'Our focus: raise Saudization and hit Qiwa Nitaqat bands with qualified Saudi talent.', featured: true },
  { icon: '⏱️', title: 'Flexible Work (hourly / daily)', desc: 'Flexible hourly or daily hiring under Saudi Arabia\'s approved flexible-work model in Qiwa.', featured: true },
  { icon: '🌐', title: 'Remote Work', desc: 'Remote employment contracts with full rights and wages under Saudi labor law.' },
  { icon: '🌍', title: 'Hiring Non-Saudis', desc: 'Sourcing and recruiting foreign talent with full work permits and compliance.' },
  { icon: '🏠', title: 'Internal Sourcing', desc: 'Hiring from within the Saudi market via the CV bank and Qiwa service transfer.' },
  { icon: '🛫', title: 'External Sourcing', desc: 'Overseas recruitment: visas, licensed agencies, and ready CVs from trusted partners.' },
  { icon: '🤝', title: 'EOR / Outsourcing', desc: 'Employer of Record and staffing without setting up an entity.' },
  { icon: '🗂️', title: 'CV Bank (external partners)', desc: 'Partners continuously feed CVs into the database to build a ready talent pool.' },
];

const automation = [
  { icon: '🤖', title: 'Job Description Agent', desc: 'Writes accurate, attractive job posts automatically.' },
  { icon: '⚡', title: 'Smart Auto-Screening', desc: 'Ranks candidates by match within minutes.' },
  { icon: '🎙️', title: 'AI Interviews', desc: 'Automated first-pass assessment before human interviews.' },
  { icon: '📅', title: 'Auto Scheduling & Alerts', desc: 'Appointments, reminders, and email notifications for everyone.' },
  { icon: '📄', title: 'Offer & Contract Generation', desc: 'Company-branded offers with a 24-hour acceptance timer.' },
  { icon: '🛡️', title: 'Automated Qiwa Compliance', desc: 'Qiwa / Muqeem / GOSI / Mudad + Saudization bands.' },
];
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="width:100%; overflow-x:hidden;">

    <section style="text-align:center; padding:120px 24px 80px; max-width:1200px; margin:0 auto;">
      <div style="display:inline-block; padding:8px 18px; background:#EFF6FF; color:#2563EB; border-radius:999px; font-size:16px; font-weight:700; margin-bottom:24px;">
        👥 HR & Recruitment by Business Partner
      </div>
      <h1 style="font-size:56px; line-height:1.2; margin-bottom:20px; color:#0F172A; font-weight:800;">
        The End-to-End Recruitment System
      </h1>
      <h2 style="font-size:26px; color:#475569; margin-bottom:28px; font-weight:600; line-height:1.5;">
        From CV selection to hiring, entry to the Kingdom, and full onboarding inside Saudi Arabia
      </h2>
      <p style="max-width:820px; margin:0 auto 40px; font-size:20px; line-height:1.9; color:#334155;">
        One fully-automated system uniting the employer, the job seeker, and the recruitment dashboard —
        with AI on par with the world's best recruitment platforms, and full Saudi government compliance via Qiwa.
      </p>
      <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <a href="#employer" style="padding:18px 34px; background:#2563EB; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">I'm an employer</a>
        <a href="#seeker" style="padding:18px 34px; background:#0F172A; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">I'm looking for work</a>
        <a href={WA} target="_blank" style="padding:18px 34px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">Talk to an advisor</a>
      </div>
    </section>

    <section id="entries" style="padding:70px 24px; background:#F8FAFC;">
      <div style="max-width:1200px; margin:0 auto;">
        <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">One System · Three Gateways</h2>
        <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:48px;">Everything about recruitment, merged inside HR.</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:28px;">
          {entries.map((e) => (
            <div style="background:white; border:1px solid #E2E8F0; border-radius:18px; padding:36px; text-align:center; box-shadow:0 2px 12px rgba(15,23,42,.04);">
              <div style="font-size:52px; margin-bottom:16px;">{e.icon}</div>
              <h3 style="font-size:26px; color:#0F172A; font-weight:800; margin-bottom:12px;">{e.title}</h3>
              <p style="color:#475569; font-size:17px; line-height:1.8; margin-bottom:24px;">{e.desc}</p>
              <a href={e.href} style="display:inline-block; padding:12px 26px; background:#2563EB; color:white; text-decoration:none; border-radius:10px; font-size:16px; font-weight:700;">{e.cta}</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="lifecycle" style="padding:90px 24px; max-width:1200px; margin:0 auto;">
      <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">The Full Hiring Journey — 8 Stages</h2>
      <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:52px;">From CV selection to onboarding inside Saudi Arabia — every stage automated and linked to government platforms.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:22px;">
        {lifecycle.map((s) => (
          <div style="position:relative; background:white; border:1px solid #E2E8F0; border-radius:16px; padding:28px;">
            <div style="position:absolute; top:-14px; inset-inline-start:24px; width:34px; height:34px; background:#2563EB; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:16px;">{s.n}</div>
            <div style="font-size:40px; margin-bottom:12px; margin-top:8px;">{s.icon}</div>
            <h3 style="font-size:21px; color:#0F172A; font-weight:800; margin-bottom:10px;">{s.title}</h3>
            <p style="color:#475569; font-size:16px; line-height:1.75;">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="tracks" style="padding:90px 24px; background:#0F172A;">
      <div style="max-width:1200px; margin:0 auto;">
        <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:white; font-weight:800;">Every Hiring Track Under One Roof</h2>
        <p style="text-align:center; color:#94A3B8; font-size:19px; margin-bottom:52px;">With a special focus on hiring Saudis and flexible hourly/daily work.</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px;">
          {tracks.map((tr) => (
            <div style={`border-radius:16px; padding:28px; border:1px solid ${tr.featured ? '#2563EB' : '#1E293B'}; background:${tr.featured ? 'linear-gradient(160deg,#1E3A8A,#1E293B)' : '#111827'};`}>
              <div style="font-size:40px; margin-bottom:12px;">{tr.icon}</div>
              <h3 style="font-size:21px; color:white; font-weight:800; margin-bottom:10px;">{tr.title}{tr.featured ? ' ⭐' : ''}</h3>
              <p style="color:#CBD5E1; font-size:16px; line-height:1.75;">{tr.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="automation" style="padding:90px 24px; max-width:1200px; margin:0 auto;">
      <h2 style="font-size:38px; text-align:center; margin-bottom:16px; color:#0F172A; font-weight:800;">World-Class Full Automation</h2>
      <p style="text-align:center; color:#64748B; font-size:19px; margin-bottom:52px;">Inspired by the world's best recruitment platforms (Deel · Greenhouse · Factorial), applied to the Saudi market.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px;">
        {automation.map((a) => (
          <div style="display:flex; gap:16px; align-items:flex-start; background:#F8FAFC; border:1px solid #E2E8F0; border-radius:14px; padding:24px;">
            <div style="font-size:34px; line-height:1;">{a.icon}</div>
            <div>
              <h3 style="font-size:19px; color:#0F172A; font-weight:800; margin-bottom:6px;">{a.title}</h3>
              <p style="color:#475569; font-size:15px; line-height:1.7;">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="padding:80px 24px; background:#F8FAFC;">
      <div style="max-width:1000px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:24px;">
        <div id="employer" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">🏢 Employers</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">Register your company, request staff or labor, and start sourcing with a full dashboard.</p>
          <a href={WA} target="_blank" style="display:inline-block; padding:12px 24px; background:#2563EB; color:white; text-decoration:none; border-radius:10px; font-weight:700;">Request staff now</a>
        </div>
        <div id="seeker" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">👤 Job Seekers</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">Upload your CV, join the CV bank, and get matched to opportunities inside Saudi Arabia.</p>
          <a href={WA} target="_blank" style="display:inline-block; padding:12px 24px; background:#0F172A; color:white; text-decoration:none; border-radius:10px; font-weight:700;">Send your CV</a>
        </div>
        <div id="dashboard" style="background:white; border:1px solid #E2E8F0; border-radius:16px; padding:34px;">
          <h3 style="font-size:24px; color:#0F172A; font-weight:800; margin-bottom:12px;">📊 Recruitment Dashboard</h3>
          <p style="color:#475569; font-size:16px; line-height:1.8; margin-bottom:20px;">Sourcing, screening, interviews, and offers control board — coming soon on the platform.</p>
          <span style="display:inline-block; padding:12px 24px; background:#E2E8F0; color:#475569; border-radius:10px; font-weight:700;">Launching soon</span>
        </div>
      </div>
    </section>

    <section style="padding:100px 24px; text-align:center; max-width:900px; margin:0 auto;">
      <h2 style="font-size:40px; color:#0F172A; font-weight:800; margin-bottom:18px;">Ready to hire the smarter way?</h2>
      <p style="color:#475569; font-size:20px; line-height:1.8; margin-bottom:34px;">Hire Saudis and non-Saudis, flexible or permanent, from inside or outside the Kingdom — we handle the automation and compliance.</p>
      <div style="display:flex; justify-content:center; gap:16px; flex-wrap:wrap;">
        <a href={WA} target="_blank" style="padding:18px 40px; background:#25D366; color:white; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">WhatsApp us</a>
        <a href="tel:+966530540231" style="padding:18px 40px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:19px; font-weight:700;">Call us</a>
      </div>
    </section>

  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>
