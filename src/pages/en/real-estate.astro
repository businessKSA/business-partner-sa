---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import RealEstateGrid from '../../components/RealEstateGrid.astro';
import RealEstateRequestForm from '../../components/RealEstateRequestForm.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = getContent(locale);
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main class="re-page">
    <section class="re-hero">
      <div class="container">
        <span class="re-hero-eyebrow">Business Partner · Real Estate & Commercial Spaces</span>
        <h1>Real Estate & Commercial Opportunities</h1>
        <p>
          A curated selection of serviced offices, coworking spaces, and commercial buildings
          in Riyadh — vetted from trusted vendors, with Business Partner's full support on
          contract review, Ejar documentation, and Balady / Civil Defense checks before you sign.
        </p>
      </div>
    </section>

    <section class="container re-content">
      <RealEstateGrid lang={locale} />
    </section>

    <div class="container">
      <RealEstateRequestForm lang={locale} />
    </div>

    <section class="re-note container">
      <p>
        📌 These opportunities are based on real vendor proposals — please confirm final availability and pricing
        with us directly before committing. We never approve a site before checking activity, municipal
        licensing, and safety requirements.
      </p>
    </section>
  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>

<style>
  .re-hero {
    padding: 140px 0 60px;
    text-align: center;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .re-hero-eyebrow {
    display: inline-block;
    color: #2563eb;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    margin-bottom: 1rem;
  }

  .re-hero h1 {
    font-size: 2.6rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1rem;
  }

  .re-hero p {
    max-width: 720px;
    margin: 0 auto;
    color: #475569;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .re-content {
    padding: 3rem 1.5rem 4rem;
  }

  .re-note {
    max-width: 900px;
    padding: 0 1.5rem 4rem;
    text-align: center;
  }

  .re-note p {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  @media (max-width: 640px) {
    .re-hero h1 {
      font-size: 2rem;
    }
  }
</style>
