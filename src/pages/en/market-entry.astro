---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = getContent(locale);
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="padding: 100px 40px; width: 100%; max-width: 100%; margin: 0 auto;">

    <!-- HERO -->
    <section style="text-align:center; padding:120px 0; max-width:1400px; margin:0 auto;">

      <h1 style="font-size:78px; line-height:1.1; margin-bottom:20px; color:#0F172A; font-weight:800;">
        Launch, License & Scale Your Business in Saudi Arabia
      </h1>

      <h2 style="font-size:30px; color:#475569; margin-bottom:30px; font-weight:600;">
        Your End-to-End Saudi Market Entry Partner
      </h2>

      <p style="max-width:1000px; margin:0 auto 40px; font-size:28px; line-height:1.8; color:#334155;">
        From MISA licensing and company formation to GRO services, compliance,
        HR outsourcing, office setup, and operational launch — Business Partner
        helps international companies enter Saudi Arabia faster, safer, and with
        full local execution support.
      </p>

      <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-bottom:50px;">

        <a
          href="#leadform"
          style="padding:20px 40px; background:#2563EB; color:white; text-decoration:none; border-radius:12px; font-size:20px; font-weight:700;"
        >
          Request Free Consultation
        </a>

        <a
          href="https://wa.me/966530540231"
          target="_blank"
          style="padding:20px 40px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:20px; font-weight:700;"
        >
          Talk to a Saudi Market Entry Advisor
        </a>

      </div>

      <div style="display:flex; justify-content:center; gap:80px; flex-wrap:wrap; text-align:center;">

        <div>
          <div style="font-size:34px; font-weight:800; color:#0F172A;">Saudi</div>
          <div style="color:#64748B; font-size:18px;">Business Specialists</div>
        </div>

        <div>
          <div style="font-size:34px; font-weight:800; color:#0F172A;">Compliance</div>
          <div style="color:#64748B; font-size:18px;">Government Experts</div>
        </div>

        <div>
          <div style="font-size:34px; font-weight:800; color:#0F172A;">End-to-End</div>
          <div style="color:#64748B; font-size:18px;">Execution Partner</div>
        </div>

      </div>

      <p style="margin-top:30px; color:#475569; font-size:18px;">
        Free initial assessment • Fast response • Direct advisor support
      </p>

    </section>

    <!-- LEAD FORM -->
    <section id="leadform" style="padding:120px 0; max-width:1000px; margin:0 auto;">

      <h2 style="font-size:48px; text-align:center; margin-bottom:20px; color:#0F172A;">
        Get Your Saudi Market Entry Assessment
      </h2>

      <p style="text-align:center; color:#64748B; margin-bottom:40px; font-size:18px;">
        Tell us about your business and our team will contact you.
      </p>

      <form action="mailto:business@businesspartner.sa" method="POST" style="display:flex; flex-direction:column; gap:20px;">

        <input type="text" placeholder="Full Name" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Company Name" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Country" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="email" placeholder="Email" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="WhatsApp Number" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Service Needed" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Investment Timeline" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;" />

        <textarea placeholder="Tell us about your project" rows="6" style="padding:22px; font-size:18px; border:1px solid #CBD5E1; border-radius:10px;"></textarea>

        <button
          type="submit"
          style="padding:22px; background:#2563EB; color:white; border:none; border-radius:12px; font-size:22px; font-weight:700; cursor:pointer;"
        >
          Request My Assessment
        </button>

      </form>

    </section>

    <!-- TRUST SECTION -->
    <section style="padding:80px 0; text-align:center;">

      <h2 style="font-size:48px; margin-bottom:40px; color:#0F172A;">
        Why International Companies Choose Business Partner
      </h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:24px;">

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3 style="font-size:24px;">MISA & Company Formation Experts</h3>
          <p style="font-size:18px;">End-to-end support for foreign company setup in Saudi Arabia.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3 style="font-size:24px;">Government Relations Execution</h3>
          <p style="font-size:18px;">Qiwa, GOSI, Balady, Muqeem, Mudad, ZATCA and compliance handling.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3 style="font-size:24px;">Operational Launch Support</h3>
          <p style="font-size:18px;">Recruitment, office setup, onboarding, payroll coordination and execution.</p>
        </div>

      </div>

    </section>

    <!-- SERVICES -->
    <section style="padding:80px 0;">

      <h2 style="font-size:48px; margin-bottom:40px; color:#0F172A;">
        What We Do
      </h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:24px;">

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Company Formation</h3>
          <p>MISA setup, CR issuance, legal entity formation, and licensing.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Government Relations (GRO)</h3>
          <p>Qiwa, GOSI, Muqeem, Balady, Mudad, ZATCA, and compliance support.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>HR & Workforce Solutions</h3>
          <p>Recruitment, onboarding, payroll coordination, and workforce outsourcing.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Office & Real Estate Setup</h3>
          <p>Workspace sourcing, furnished offices, compounds, and operational setup.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Business Advisory</h3>
          <p>Market entry strategy, partnerships, launch execution, and scaling support.</p>
        </div>

        <div style="padding:30px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Residency Pathway Advisory</h3>
          <p>Guidance for investor and entrepreneur residency pathways.</p>
        </div>

      </div>

    </section>

  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>