---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = getContent(locale);
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="padding: 80px 20px; max-width: 1200px; margin: 0 auto;">

    <!-- HERO -->
    <section style="text-align:center; padding:80px 0;">
      
      <h1 style="font-size:64px; line-height:1.1; margin-bottom:20px; color:#0F172A; font-weight:800;">
        Launch, License & Scale Your Business in Saudi Arabia
      </h1>

      <h2 style="font-size:30px; color:#475569; margin-bottom:30px; font-weight:600;">
        Your End-to-End Saudi Market Entry Partner
      </h2>

      <p style="max-width:900px; margin:0 auto 40px; font-size:22px; line-height:1.8; color:#334155;">
        From MISA licensing and company formation to GRO services, compliance,
        HR outsourcing, office setup, and operational launch — Business Partner
        helps international companies enter Saudi Arabia faster, safer, and with
        full local execution support.
      </p>

      <!-- CTA BUTTONS -->
      <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-bottom:50px;">
        
        <a
          href="#leadform"
          style="padding:18px 36px; background:#2563EB; color:white; text-decoration:none; border-radius:12px; font-size:18px; font-weight:600;"
        >
          Book Free Strategy Call
        </a>

        <a
          href="https://wa.me/966530540231"
          target="_blank"
          style="padding:18px 36px; border:2px solid #2563EB; color:#2563EB; text-decoration:none; border-radius:12px; font-size:18px; font-weight:600;"
        >
          Chat on WhatsApp
        </a>

      </div>

      <!-- STATS -->
      <div style="display:flex; justify-content:center; gap:70px; flex-wrap:wrap; text-align:center;">
        
        <div>
          <div style="font-size:30px; font-weight:800; color:#0F172A;">500+</div>
          <div style="color:#64748B;">Businesses Supported</div>
        </div>

        <div>
          <div style="font-size:30px; font-weight:800; color:#0F172A;">Saudi</div>
          <div style="color:#64748B;">Compliance Experts</div>
        </div>

        <div>
          <div style="font-size:30px; font-weight:800; color:#0F172A;">End-to-End</div>
          <div style="color:#64748B;">Execution Partner</div>
        </div>

      </div>

      <p style="margin-top:30px; color:#475569; font-size:16px;">
        Free initial assessment • Fast response • Direct advisor support
      </p>

    </section>

    <!-- LEAD FORM -->
    <section id="leadform" style="padding:80px 0; max-width:800px; margin:0 auto;">
      
      <h2 style="font-size:42px; text-align:center; margin-bottom:20px; color:#0F172A;">
        Get Your Saudi Market Entry Assessment
      </h2>

      <p style="text-align:center; color:#64748B; margin-bottom:40px;">
        Tell us about your business and our team will contact you.
      </p>

      <form style="display:flex; flex-direction:column; gap:18px;">
        
        <input type="text" placeholder="Full Name" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />
        
        <input type="text" placeholder="Company Name" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Country" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="email" placeholder="Email" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="WhatsApp Number" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Service Needed" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <input type="text" placeholder="Investment Timeline" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;" />

        <textarea placeholder="Tell us about your project" rows="6" style="padding:16px; border:1px solid #CBD5E1; border-radius:10px;"></textarea>

        <button
          type="submit"
          style="padding:18px; background:#2563EB; color:white; border:none; border-radius:12px; font-size:18px; font-weight:700; cursor:pointer;"
        >
          Request My Assessment
        </button>

      </form>

    </section>

    <!-- SERVICES -->
    <section style="padding:60px 0;">
      
      <h2 style="font-size:42px; margin-bottom:40px; color:#0F172A;">
        What We Do
      </h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px;">

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Company Formation</h3>
          <p>MISA setup, CR issuance, legal entity formation, and licensing.</p>
        </div>

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Government Relations (GRO)</h3>
          <p>Qiwa, GOSI, Muqeem, Balady, Mudad, ZATCA, and compliance support.</p>
        </div>

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>HR & Workforce Solutions</h3>
          <p>Recruitment, onboarding, payroll coordination, and workforce outsourcing.</p>
        </div>

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Office & Real Estate Setup</h3>
          <p>Workspace sourcing, furnished offices, compounds, and operational setup.</p>
        </div>

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Business Advisory</h3>
          <p>Market entry strategy, partnerships, launch execution, and scaling support.</p>
        </div>

        <div style="padding:25px; border:1px solid #E2E8F0; border-radius:16px;">
          <h3>Residency Pathway Advisory</h3>
          <p>Guidance for investor and entrepreneur residency pathways.</p>
        </div>

      </div>

    </section>

  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>