---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = getContent(locale);
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main style="padding: 80px 20px; max-width: 1200px; margin: 0 auto;">

    <section style="text-align:center; padding:80px 0;">
      <h1 style="font-size:56px; margin-bottom:20px; line-height:1.1;">
Launch, License & Scale Your Business in Saudi Arabia
</h1>

      <h2 style="font-size:28px; color:#4B5563; margin-bottom:30px;">
Your End-to-End Saudi Market Entry Partner
</h2>

      <p style="max-width:950px; margin:0 auto 40px; font-size:20px; line-height:1.8;">
From MISA licensing and company formation to GRO services, compliance, HR outsourcing, office setup, and operational launch — Business Partner helps international companies enter Saudi Arabia faster, safer, and with full local execution support.
</p>

      <div style="display:flex; gap:20px; justify-content:center; flex-wrap:wrap;">
        <a href="https://wa.me/966530540231?text=Hello%20Business%20Partner,%20I%20would%20like%20to%20book%20a%20discovery%20call%20for%20Saudi%20market%20entry."
           style="padding:16px 32px; background:#0B5FFF; color:white; text-decoration:none; border-radius:10px;">
          Request Free Consultation
        </a>
        <div style="display:flex; justify-content:center; gap:40px; margin-top:50px; flex-wrap:wrap;">
  <div><strong>500+</strong><br>Businesses Supported</div>
  <div><strong>Saudi</strong><br>Compliance Experts</div>
  <div><strong>End-to-End</strong><br>Execution Partner</div>
</div>

        <a href="https://wa.me/966530540231"
           target="_blank"
           style="padding:16px 32px; border:2px solid #0B5FFF; color:#0B5FFF; text-decoration:none; border-radius:10px;">
          Talk to a Saudi Market Entry Advisor
        </a>
      </div>
    </section>

    <section style="padding:60px 0;">
      <h2 style="font-size:36px; margin-bottom:30px;">What We Do</h2>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px;">

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>Company Formation</h3>
          <p>MISA setup, CR issuance, legal entity formation, and licensing.</p>
        </div>

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>Government Relations (GRO)</h3>
          <p>Qiwa, GOSI, Muqeem, Balady, Mudad, ZATCA, and compliance support.</p>
        </div>

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>HR & Workforce Solutions</h3>
          <p>Recruitment, onboarding, payroll coordination, and workforce outsourcing.</p>
        </div>

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>Office & Real Estate Setup</h3>
          <p>Workspace sourcing, furnished offices, compounds, and operational setup.</p>
        </div>

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>Business Advisory</h3>
          <p>Market entry strategy, partnerships, launch execution, and scaling support.</p>
        </div>

        <div style="padding:25px; border:1px solid #eee; border-radius:16px;">
          <h3>Premium Residency Support</h3>
          <p>Guidance for investor and entrepreneur residency pathways.</p>
        </div>

      </div>
    </section>

  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>