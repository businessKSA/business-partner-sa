---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import { getContent } from '../../content/copy';

export const prerender = true;

const locale = 'en';
const t = {
  ...getContent(locale),
  meta: {
    title: 'Deals & Smart Matchmaking | Business Partner',
    description: 'Offer a deal, look for a partner, or pitch an idea — we automatically match you with the closest opportunities by sector and city, and never reveal your details until both sides agree.',
  },
};
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <section id="home" class="hero">
    <div class="container hero-content">
      <div class="hero-badge">✨ New — Smart Matchmaking + Deals · 🆓 Free right now</div>
      <h1>We don't just list deals — we match you with the right partner</h1>
      <p>A seller or a buyer, a founder looking for an investor, or an investor looking for an opportunity — submit your profile once and we compare it instantly against every open opportunity by sector, city and deal type, then rank the closest matches for you by name. The service is free right now, and real introductions only happen once both sides agree.</p>
      <div class="hero-cta">
        <button class="btn btn-primary" id="openWizardHero" type="button">Submit Your Deal</button>
        <a href="#wall" class="btn btn-secondary">Browse Published Deals</a>
      </div>
      <div class="hero-stats">
        <div class="stat-card"><span class="stat-number" id="statTotal">0</span><span class="stat-label">Deals in the pool</span></div>
        <div class="stat-card"><span class="stat-number">&lt;24h</span><span class="stat-label">Review time</span></div>
        <div class="stat-card"><span class="stat-number">2×</span><span class="stat-label">Consent before any data is shared</span></div>
      </div>
    </div>
  </section>

  <!-- Launcher -->
  <section class="section">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: 0.75rem;">Choose what fits your situation</h2>
      <p style="text-align: center; color: var(--muted); max-width: 640px; margin: 0 auto 3rem;">Every path goes through the same submission, matching and review journey</p>

      <div class="grid grid-3">
        <button class="card launcher-tile" data-kind="offer" type="button">
          <span class="launcher-ico ico-offer">🤝</span>
          <h3>I have a deal to offer</h3>
          <p style="color: var(--muted);">Selling an existing business, a partnership, a franchise, or capital looking for an opportunity</p>
        </button>
        <button class="card launcher-tile" data-kind="seek" type="button">
          <span class="launcher-ico ico-seek">🔎</span>
          <h3>I'm looking for a partner</h3>
          <p style="color: var(--muted);">A funding partner, an investor, a buyer for an existing business, or a promising opportunity</p>
        </button>
        <button class="card launcher-tile" data-kind="idea" type="button">
          <span class="launcher-ico ico-idea">💡</span>
          <h3>I have a business idea</h3>
          <p style="color: var(--muted);">Looking for a co-founder or investor to build it with you</p>
        </button>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" style="background: var(--surface);">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: 3rem;">From submission to introduction</h2>
      <div class="grid grid-4">
        <div class="card how-card">
          <span class="how-num">1</span>
          <h3>Submit your profile</h3>
          <p style="color: var(--muted);">Deal type, sector, city and a short description — takes two minutes.</p>
        </div>
        <div class="card how-card">
          <span class="how-num">2</span>
          <h3>Instant matching</h3>
          <p style="color: var(--muted);">We compare your profile against every open opportunity and rank the closest matches.</p>
        </div>
        <div class="card how-card">
          <span class="how-num">3</span>
          <h3>Review & publish</h3>
          <p style="color: var(--muted);">Our team verifies seriousness and details before anything goes public.</p>
        </div>
        <div class="card how-card">
          <span class="how-num">4</span>
          <h3>Introduction by consent</h3>
          <p style="color: var(--muted);">Your contact details are never revealed until the other side agrees to connect.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Deal wall -->
  <section class="section" id="wall">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: 0.75rem;">Deals published this week</h2>
      <p style="text-align: center; color: var(--muted); margin-bottom: 2.5rem;">Browse for free, or submit your profile so the system can find your closest matches</p>

      <div class="filters">
        <button class="chip is-active" data-filter="all" type="button">All</button>
        <button class="chip" data-filter="offer" type="button">Offering a deal</button>
        <button class="chip" data-filter="seek" type="button">Seeking a partner</button>
        <button class="chip" data-filter="idea" type="button">Pitching an idea</button>
        <span class="filters-count"><span id="visibleCount">0</span> deals shown</span>
      </div>

      <div class="grid grid-3" id="wallGrid">

        <article class="card ticket" data-type="offer" data-sector="food" data-city="riyadh">
          <span class="ticket-badge badge-offer">🤝 Seller offering a business</span>
          <h3>Established specialty café — for sale in Riyadh</h3>
          <div class="ticket-meta"><span>📍 Riyadh</span><span>☕ Café & food</span></div>
          <p style="color: var(--muted);">A 2-year-old café with a prime location and a loyal customer base — the owner is selling the whole business to focus on another venture.</p>
          <div class="ticket-stat"><span>Asking price</span><b>SAR 250k</b></div>
          <div class="ticket-foot"><span>Posted 2 days ago</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

        <article class="card ticket" data-type="seek" data-sector="retail" data-city="jeddah">
          <span class="ticket-badge badge-seek">🔎 Buyer seeking a business</span>
          <h3>Investor looking to acquire an existing retail business</h3>
          <div class="ticket-meta"><span>📍 Jeddah</span><span>🛍️ Retail</span></div>
          <p style="color: var(--muted);">A ready investor with a set budget is looking to acquire an existing shop or small retail chain to take over and operate directly.</p>
          <div class="ticket-stat"><span>Budget available</span><b>Up to SAR 500k</b></div>
          <div class="ticket-foot"><span>Posted yesterday</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

        <article class="card ticket" data-type="seek" data-sector="services" data-city="riyadh">
          <span class="ticket-badge badge-seek">🔎 Seeking an investor</span>
          <h3>Founder seeking an investor to expand an existing business</h3>
          <div class="ticket-meta"><span>📍 Riyadh</span><span>🧾 Services</span></div>
          <p style="color: var(--muted);">A profitable, established services business is looking for an investor to fund expansion into a new city, in exchange for equity.</p>
          <div class="ticket-stat"><span>Funding needed</span><b>SAR 300k for 20%</b></div>
          <div class="ticket-foot"><span>Posted 3 days ago</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

        <article class="card ticket" data-type="seek" data-sector="other" data-city="dammam">
          <span class="ticket-badge badge-seek">🔎 Investor seeking an opportunity</span>
          <h3>Investor looking for a promising opportunity</h3>
          <div class="ticket-meta"><span>📍 Dammam</span><span>💼 General investment</span></div>
          <p style="color: var(--muted);">An investor with capital ready to deploy is looking for an existing business or a promising idea in any sector, for equity or partnership.</p>
          <div class="ticket-stat"><span>Capital available</span><b>SAR 1–3M</b></div>
          <div class="ticket-foot"><span>Posted 4 days ago</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

        <article class="card ticket" data-type="offer" data-sector="food" data-city="jeddah">
          <span class="ticket-badge badge-offer">🤝 Partnership offer</span>
          <h3>Restaurant chain offering a franchise</h3>
          <div class="ticket-meta"><span>📍 Jeddah</span><span>🍽️ Restaurants</span></div>
          <p style="color: var(--muted);">A successful local restaurant brand is offering a franchise to open new branches, with full training and ongoing operating support.</p>
          <div class="ticket-stat"><span>Franchise fee</span><b>SAR 150k</b></div>
          <div class="ticket-foot"><span>Posted a week ago</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

        <article class="card ticket" data-type="idea" data-sector="hr" data-city="riyadh">
          <span class="ticket-badge badge-idea">💡 Idea pitch</span>
          <h3>Remote hiring platform for Saudi talent</h3>
          <div class="ticket-meta"><span>📍 Riyadh</span><span>👥 HR</span></div>
          <p style="color: var(--muted);">A founder with 8 years of recruiting experience looking for a technical co-founder to build a platform connecting companies with remote talent.</p>
          <div class="ticket-stat"><span>Needs</span><b>Co-founder</b></div>
          <div class="ticket-foot"><span>Posted a week ago</span><button class="btn-ticket" type="button">Request intro</button></div>
        </article>

      </div>

      <div style="text-align: center; margin-top: 2.5rem;">
        <button class="btn btn-primary" id="openWizardBottom" type="button">Add Your Deal to the Wall</button>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="section" style="background: var(--surface); padding-block: 2.5rem;">
    <div class="container trust-strip">
      <span>🆓 Free right now — no commission</span>
      <span>🔒 Manually reviewed before publishing</span>
      <span>🎯 Match score computed automatically</span>
      <span>🤝 Introductions only by mutual consent</span>
    </div>
  </section>

  <CallFab />
  <Footer lang={locale} t={t} />

  <!-- Submission wizard -->
  <div class="scrim" id="scrim"></div>
  <aside class="drawer" id="drawer" role="dialog" aria-label="Submit a deal">
    <div class="drawer-head">
      <b>Submit your profile & get matches</b>
      <button class="drawer-close" id="drawerClose" type="button" aria-label="Close">✕</button>
    </div>
    <div class="drawer-progress"><div class="drawer-bar" id="drawerBar"></div></div>
    <div class="drawer-body">

      <div class="wiz-step is-active" data-step="1">
        <h4>Step 1 — Deal type</h4>
        <p class="hint">Choose what applies to your situation</p>
        <div class="type-pick">
          <label class="type-opt" data-kind="offer">
            <input type="radio" name="dealType" value="offer" checked />
            <span class="tico ico-offer">🤝</span>
            <span><b>I have a deal to offer</b><span>Partnership, distribution, ready funding</span></span>
          </label>
          <label class="type-opt" data-kind="seek">
            <input type="radio" name="dealType" value="seek" />
            <span class="tico ico-seek">🔎</span>
            <span><b>I'm looking for a partner</b><span>For an existing business needing funding or operations</span></span>
          </label>
          <label class="type-opt" data-kind="idea">
            <input type="radio" name="dealType" value="idea" />
            <span class="tico ico-idea">💡</span>
            <span><b>I have a business idea</b><span>Looking for a co-founder or investor</span></span>
          </label>
        </div>
      </div>

      <div class="wiz-step" data-step="2">
        <h4>Step 2 — Deal details</h4>
        <p class="hint">These fields are exactly what the matching engine uses</p>
        <div class="form-group"><label for="dTitle">Deal title</label><input type="text" id="dTitle" placeholder="e.g. Restaurant seeking a funding partner" /></div>
        <div class="grid grid-2" style="gap: 1rem;">
          <div class="form-group">
            <label for="dSector">Sector</label>
            <select id="dSector">
              <option value="food">Restaurants & food</option>
              <option value="retail">Retail</option>
              <option value="tech">Tech</option>
              <option value="services">Services</option>
              <option value="industry">Industry</option>
              <option value="logistics">Logistics</option>
              <option value="beauty">Beauty</option>
              <option value="hr">HR</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="dCity">City</label>
            <select id="dCity">
              <option value="riyadh">Riyadh</option>
              <option value="jeddah">Jeddah</option>
              <option value="dammam">Dammam</option>
              <option value="other">Other city</option>
            </select>
          </div>
        </div>
        <div class="form-group"><label for="dDesc">Deal description</label><textarea id="dDesc" rows="4" placeholder="Briefly explain the idea or deal..."></textarea></div>
      </div>

      <div class="wiz-step" data-step="3">
        <h4>Step 3 — Contact details</h4>
        <p class="hint">Never shown publicly — only revealed once the other side agrees to an introduction</p>
        <div class="grid grid-2" style="gap: 1rem;">
          <div class="form-group"><label for="dName">Name</label><input type="text" id="dName" placeholder="Your full name" /></div>
          <div class="form-group"><label for="dPhone">Phone</label><input type="tel" id="dPhone" pattern="^(?:\+?966|0)?5\d{8}$" placeholder="05xxxxxxxx" /></div>
        </div>
        <div class="form-group"><label for="dEmail">Email</label><input type="email" id="dEmail" placeholder="name@email.com" /></div>
        <label class="consent"><input type="checkbox" id="dConsent" checked /><span>I agree to have my profile reviewed by the Business Partner team before publishing, and to receive email about any match or introduction request.</span></label>
        <div id="wizMessage" class="wiz-message" style="display: none;"></div>
      </div>

      <div class="wiz-step" data-step="4">
        <h4>Step 4 — Your closest matches</h4>
        <p class="hint">Computed from sector, city and deal type — your details stay private unless they accept the introduction request</p>
        <div class="match-list" id="matchResults"></div>
      </div>

      <div class="wiz-step" data-step="5">
        <div class="wiz-success">
          <div class="wiz-check">✓</div>
          <h4>Your profile is in</h4>
          <p style="color: var(--muted);">Saved to our system — our team will review it within 24 hours, and we'll email you once it's published and whenever a new match appears.</p>
        </div>
      </div>

    </div>
    <div class="drawer-foot" id="drawerFoot">
      <button class="btn btn-secondary" id="stepBack" type="button">Back</button>
      <button class="btn btn-primary" id="stepNext" type="button">Next</button>
    </div>
  </aside>
</BaseLayout>

<style>
  /* ===== Launcher tiles ===== */
  .launcher-tile { text-align: center; cursor: pointer; font: inherit; color: inherit; }
  .launcher-ico { display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 14px; font-size: 1.6rem; margin-bottom: 1rem; }
  .ico-offer { background: rgba(217, 119, 6, 0.14); }
  .ico-seek { background: rgba(16, 185, 129, 0.14); }
  .ico-idea { background: rgba(124, 58, 237, 0.14); }
  .launcher-tile h3 { margin-bottom: 0.5rem; }

  /* ===== How it works ===== */
  .how-card { position: relative; }
  .how-num { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: var(--brand); color: #fff; font-weight: 700; font-size: 0.9rem; margin-bottom: 1rem; }

  /* ===== Filters ===== */
  .filters { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .chip { border: 1.5px solid var(--line); background: var(--surface); color: var(--muted); font-weight: 600; font-size: 0.85rem; padding: 0.5rem 1rem; border-radius: 999px; cursor: pointer; transition: all 0.2s ease; }
  .chip.is-active { background: var(--brand); border-color: var(--brand); color: #fff; }
  .filters-count { margin-inline-start: auto; font-size: 0.85rem; color: var(--muted); font-weight: 600; }

  /* ===== Ticket cards ===== */
  .ticket[hidden] { display: none; }
  .ticket-badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.25rem 0.7rem; border-radius: 999px; margin-bottom: 0.75rem; }
  .badge-offer { background: rgba(217, 119, 6, 0.14); color: #92400e; }
  .badge-seek { background: rgba(16, 185, 129, 0.14); color: #047857; }
  .badge-idea { background: rgba(124, 58, 237, 0.14); color: #5b21b6; }
  .ticket h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
  .ticket-meta { display: flex; gap: 1rem; font-size: 0.82rem; color: var(--muted); margin-bottom: 0.75rem; }
  .ticket-stat { display: flex; justify-content: space-between; background: var(--bg); border: 1px dashed var(--line); border-radius: 8px; padding: 0.5rem 0.75rem; margin-top: 0.9rem; font-size: 0.85rem; }
  .ticket-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--line); font-size: 0.78rem; color: var(--muted); }
  .btn-ticket { background: var(--brand); color: #fff; font-weight: 700; font-size: 0.78rem; padding: 0.45rem 0.9rem; border-radius: 999px; border: none; cursor: pointer; }
  .btn-ticket:hover { background: #0052a3; }

  .trust-strip { display: flex; flex-wrap: wrap; gap: 0.6rem 2rem; justify-content: center; font-size: 0.85rem; color: var(--muted); font-weight: 600; }

  /* ===== Drawer / wizard ===== */
  .scrim { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.5); opacity: 0; pointer-events: none; transition: opacity 0.25s ease; z-index: 200; }
  .scrim.is-open { opacity: 1; pointer-events: auto; }
  .drawer { position: fixed; top: 0; bottom: 0; inset-inline-end: 0; width: min(460px, 100%); background: var(--bg); z-index: 201; box-shadow: -20px 0 50px rgba(15, 23, 42, 0.2); transform: translateX(105%); transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1); display: flex; flex-direction: column; }
  .drawer.is-open { transform: translateX(0); }
  .drawer-head { padding: 1.25rem 1.4rem; border-bottom: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; flex: none; }
  .drawer-close { border: none; background: var(--surface); width: 34px; height: 34px; border-radius: 50%; cursor: pointer; font-size: 1rem; color: var(--muted); }
  .drawer-progress { height: 4px; background: var(--line); flex: none; }
  .drawer-bar { height: 100%; width: 25%; background: var(--brand); transition: width 0.3s ease; }
  .drawer-body { padding: 1.5rem 1.4rem; overflow-y: auto; flex: 1; }
  .wiz-step { display: none; }
  .wiz-step.is-active { display: block; }
  .wiz-step h4 { margin-bottom: 0.3rem; }
  .wiz-step p.hint { font-size: 0.82rem; color: var(--muted); margin: 0 0 1.2rem; }

  .type-pick { display: grid; gap: 0.6rem; }
  .type-opt { display: flex; align-items: center; gap: 0.8rem; border: 1.5px solid var(--line); border-radius: 10px; padding: 0.8rem 0.9rem; cursor: pointer; }
  .type-opt:has(input:checked) { border-color: var(--brand); background: rgba(0, 102, 204, 0.05); }
  .tico { width: 34px; height: 34px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex: none; }
  .type-opt b { display: block; font-size: 0.9rem; }
  .type-opt span span { display: block; font-size: 0.76rem; color: var(--muted); }

  .consent { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }
  .wiz-message { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; }
  .wiz-message.error { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

  .drawer-foot { padding: 1rem 1.4rem 1.4rem; border-top: 1px solid var(--line); display: flex; gap: 0.6rem; flex: none; }
  .drawer-foot .btn { flex: 1; justify-content: center; }
  .drawer-foot .btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .wiz-success { text-align: center; padding: 1.25rem 0; }
  .wiz-check { width: 60px; height: 60px; border-radius: 50%; background: rgba(16, 185, 129, 0.14); color: #047857; display: flex; align-items: center; justify-content: center; font-size: 1.7rem; margin: 0 auto 1.1rem; }

  .match-list { display: grid; gap: 0.75rem; }
  .match-card { border: 1.5px solid var(--line); border-radius: 10px; padding: 0.9rem 1rem; }
  .match-card-head { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.3rem; }
  .match-score { font-weight: 700; font-size: 0.85rem; padding: 0.2rem 0.7rem; border-radius: 999px; background: rgba(16, 185, 129, 0.14); color: #047857; flex: none; }
  .match-meta { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.5rem; }
  .match-reasons { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .match-reasons span { font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 999px; background: var(--surface); border: 1px solid var(--line); color: var(--muted); }
  .match-empty { text-align: center; padding: 1.5rem 0.75rem; color: var(--muted); font-size: 0.88rem; background: var(--surface); border: 1px dashed var(--line); border-radius: 10px; }

  @media (max-width: 640px) {
    .grid-2 { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function () {
    var tickets = document.querySelectorAll('.ticket');

    // filters
    var chips = document.querySelectorAll('.chip');
    var visibleCount = document.getElementById('visibleCount');
    function applyFilter(kind) {
      var count = 0;
      tickets.forEach(function (t) {
        var show = kind === 'all' || t.getAttribute('data-type') === kind;
        if (show) count++;
        t.toggleAttribute('hidden', !show);
      });
      if (visibleCount) visibleCount.textContent = String(count);
    }
    chips.forEach(function (c) {
      c.addEventListener('click', function () {
        chips.forEach(function (x) { x.classList.remove('is-active'); });
        c.classList.add('is-active');
        applyFilter(c.getAttribute('data-filter'));
      });
    });
    applyFilter('all');

    // animated total
    var statTotal = document.getElementById('statTotal');
    if (statTotal) {
      var target = tickets.length;
      var n = 0;
      var iv = setInterval(function () {
        n++; statTotal.textContent = String(n);
        if (n >= target) clearInterval(iv);
      }, 90);
    }

    // "Request intro" — double opt-in demo, no data revealed here
    document.querySelectorAll('.btn-ticket').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var original = btn.textContent;
        btn.textContent = 'Awaiting their consent ⏳';
        btn.setAttribute('disabled', 'true');
        setTimeout(function () { btn.textContent = original; btn.removeAttribute('disabled'); }, 2600);
      });
    });

    // wizard
    var scrim = document.getElementById('scrim');
    var drawer = document.getElementById('drawer');
    var bar = document.getElementById('drawerBar');
    var steps = drawer.querySelectorAll('.wiz-step');
    var back = document.getElementById('stepBack');
    var next = document.getElementById('stepNext');
    var foot = document.getElementById('drawerFoot');
    var wizMessage = document.getElementById('wizMessage');
    var current = 1;
    var TOTAL_INPUT_STEPS = 4;
    var NEXT_LABELS = { 1: 'Next', 2: 'Next', 3: 'Submit & match', 4: 'Done' };

    var COMPLEMENTS = {
      offer: { offer: 0, seek: 25, idea: 25 },
      seek: { offer: 25, seek: 0, idea: 15 },
      idea: { offer: 25, seek: 15, idea: 0 }
    };

    function currentProfile() {
      var typeEl = drawer.querySelector('input[name="dealType"]:checked');
      return {
        type: typeEl ? typeEl.value : 'seek',
        sector: document.getElementById('dSector').value,
        city: document.getElementById('dCity').value
      };
    }

    function renderMatches() {
      var profile = currentProfile();
      var results = document.getElementById('matchResults');
      var scored = Array.prototype.map.call(tickets, function (t) {
        var reasons = [];
        var score = 0;
        if (t.getAttribute('data-city') === profile.city) { score += 40; reasons.push('📍 Same city'); }
        if (t.getAttribute('data-sector') === profile.sector) { score += 35; reasons.push('🏷️ Same sector'); }
        var bonus = (COMPLEMENTS[profile.type] || {})[t.getAttribute('data-type')] || 0;
        if (bonus) { score += bonus; reasons.push('🔁 Complementary type'); }
        return { el: t, score: score, reasons: reasons };
      }).filter(function (m) { return m.score > 0; })
        .sort(function (a, b) { return b.score - a.score; })
        .slice(0, 3);

      if (!scored.length) {
        results.innerHTML = '<div class="match-empty">No strong match in the pool right now — we\'ll keep watching new deals and email you the moment a good match appears 🎯</div>';
        return;
      }
      results.innerHTML = scored.map(function (m) {
        var title = m.el.querySelector('h3').textContent;
        var meta = Array.prototype.map.call(m.el.querySelectorAll('.ticket-meta span'), function (s) { return s.textContent.trim(); }).join('  ·  ');
        return '<div class="match-card">' +
          '<div class="match-card-head"><b>' + title + '</b><span class="match-score">' + Math.min(m.score, 100) + '% match</span></div>' +
          '<div class="match-meta">' + meta + '</div>' +
          '<div class="match-reasons">' + m.reasons.map(function (r) { return '<span>' + r + '</span>'; }).join('') + '</div>' +
        '</div>';
      }).join('');
    }

    function openDrawer(kind) {
      scrim.classList.add('is-open');
      drawer.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      if (kind) {
        var radio = drawer.querySelector('input[name="dealType"][value="' + kind + '"]');
        if (radio) radio.checked = true;
      }
      goToStep(1);
    }
    function closeDrawer() {
      scrim.classList.remove('is-open');
      drawer.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function goToStep(n) {
      current = n;
      steps.forEach(function (s) { s.classList.toggle('is-active', Number(s.getAttribute('data-step')) === n); });
      bar.style.width = Math.min(n, TOTAL_INPUT_STEPS) / TOTAL_INPUT_STEPS * 100 + '%';
      back.style.visibility = n === 1 ? 'hidden' : 'visible';
      if (n === TOTAL_INPUT_STEPS) renderMatches();
      if (n > TOTAL_INPUT_STEPS) {
        foot.style.display = 'none';
      } else {
        foot.style.display = 'flex';
        next.textContent = NEXT_LABELS[n] || 'Next';
        next.removeAttribute('disabled');
      }
    }

    function showWizError(msg) {
      wizMessage.textContent = msg;
      wizMessage.className = 'wiz-message error';
      wizMessage.style.display = 'block';
    }

    async function submitDeal() {
      var payload = {
        dealType: currentProfile().type,
        title: (document.getElementById('dTitle') as HTMLInputElement).value,
        sector: currentProfile().sector,
        city: currentProfile().city,
        description: (document.getElementById('dDesc') as HTMLTextAreaElement).value,
        name: (document.getElementById('dName') as HTMLInputElement).value,
        phone: (document.getElementById('dPhone') as HTMLInputElement).value,
        email: (document.getElementById('dEmail') as HTMLInputElement).value,
        consent: (document.getElementById('dConsent') as HTMLInputElement).checked,
        lang: 'en',
        source: 'businesspartner.sa/en/deals',
        timestamp: new Date().toISOString()
      };

      if (!payload.name || !payload.phone || !payload.email) {
        showWizError('Please fill in your name, phone and email before continuing.');
        return false;
      }
      if (!payload.consent) {
        showWizError('You need to agree to the review and contact terms before submitting.');
        return false;
      }

      next.setAttribute('disabled', 'true');
      next.textContent = 'Sending...';
      try {
        const res = await fetch('/api/deals', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload)
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        wizMessage.style.display = 'none';
        return true;
      } catch (err) {
        showWizError('There was an error submitting your profile. Please try again or contact us directly.');
        next.removeAttribute('disabled');
        next.textContent = NEXT_LABELS[3];
        return false;
      }
    }

    document.getElementById('openWizardHero').addEventListener('click', function () { openDrawer(); });
    document.getElementById('openWizardBottom').addEventListener('click', function () { openDrawer(); });
    document.querySelectorAll('.launcher-tile').forEach(function (t) {
      t.addEventListener('click', function () { openDrawer(t.getAttribute('data-kind')); });
    });
    document.getElementById('drawerClose').addEventListener('click', closeDrawer);
    scrim.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeDrawer(); });

    back.addEventListener('click', function () { if (current > 1) goToStep(current - 1); });
    next.addEventListener('click', async function () {
      if (current === 3) {
        var ok = await submitDeal();
        if (!ok) return;
        goToStep(4);
      } else if (current === 4) {
        goToStep(5);
      } else {
        goToStep(current + 1);
      }
    });
  })();
</script>
