---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallFab from '../../components/CallFab.astro';
import WebinarRegisterForm from '../../components/webinar/WebinarRegisterForm.astro';
import SocialShare from '../../components/webinar/SocialShare.astro';
import { pickT } from '../../utils/i18n';

export const prerender = true;

const locale = 'en' as const;
const pageUrl = 'https://businesspartner.sa/en/webinar';
const pageTitle = 'Land Your First AI Automation Client in 30 Days';

const t = {
  ...pickT(locale),
  meta: {
    title: `${pageTitle} | Business Partner`,
    description:
      'A free live webinar for Saudi nationals and residents in the Kingdom who want to build extra income by offering AI automation services to local businesses. Register now.',
  },
};
---

<BaseLayout lang={locale} t={t}>
  <Header lang={locale} t={t} />

  <main class="webinar-page">
    <!-- HERO -->
    <section class="webinar-hero">
      <div class="container">
        <span class="badge">Free Live Webinar</span>
        <h1>{pageTitle}</h1>
        <p class="subtitle">
          Built for <strong>Saudi nationals and residents</strong> in the Kingdom who want to build
          extra income by offering AI automation services to local businesses — no prior coding
          experience required.
        </p>

        <div class="event-meta">
          <div class="meta-item">
            <span class="meta-label">📅 Date</span>
            <span class="meta-value">Sunday, July 26, 2026</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">🕖 Time</span>
            <span class="meta-value">7:00 PM (Riyadh Time)</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">💻 Platform</span>
            <span class="meta-value">Live on Zoom</span>
          </div>
        </div>

        <a href="#register" class="btn btn-primary hero-cta">Reserve My Free Seat</a>
      </div>
    </section>

    <!-- WHO IS THIS FOR -->
    <section class="section audience">
      <div class="container">
        <h2>Is this webinar for you?</h2>
        <div class="grid grid-3">
          <div class="card">
            <h3>🇸🇦 Saudi National</h3>
            <p>Looking for extra income or a flexible side project you can run from anywhere.</p>
          </div>
          <div class="card">
            <h3>🏠 Resident in the Kingdom</h3>
            <p>You have interest or experience in tech and want to serve local clients.</p>
          </div>
          <div class="card">
            <h3>💼 Employee or Freelancer</h3>
            <p>Want a practical, marketable skill without leaving your current job.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU'LL LEARN -->
    <section class="section agenda">
      <div class="container">
        <h2>What you'll learn</h2>
        <ul class="agenda-list">
          <li>✅ How to spot real automation opportunities inside small and mid-size businesses</li>
          <li>✅ The core tools to build your first automation solution without deep coding</li>
          <li>✅ How to pitch and price your services to land your first client in 30 days</li>
          <li>✅ Real examples from the Saudi market</li>
        </ul>
      </div>
    </section>

    <!-- REGISTRATION -->
    <section id="register" class="section register">
      <div class="container">
        <h2>Reserve your free seat</h2>
        <p class="register-subtitle">Seats are limited — registration is completely free.</p>
        <WebinarRegisterForm lang={locale} />
        <SocialShare lang={locale} url={pageUrl} title={pageTitle} />
      </div>
    </section>
  </main>

  <CallFab />
  <Footer lang={locale} t={t} />
</BaseLayout>

<style>
  .webinar-hero {
    background: var(--gradient, linear-gradient(135deg, #1e293b 0%, #334155 100%));
    color: white;
    padding: 5rem 0 4rem;
    text-align: center;
  }

  .webinar-hero .badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .webinar-hero h1 {
    font-size: 2.5rem;
    max-width: 900px;
    margin: 0 auto 1.5rem;
  }

  .webinar-hero .subtitle {
    max-width: 700px;
    margin: 0 auto 2.5rem;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.8;
  }

  .event-meta {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .meta-item {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    padding: 1rem 1.5rem;
    min-width: 180px;
  }

  .meta-label {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.25rem;
  }

  .meta-value {
    display: block;
    font-weight: 700;
    font-size: 1.05rem;
  }

  .hero-cta {
    font-size: 1.15rem;
    padding: 1rem 2.5rem;
  }

  .audience h2,
  .agenda h2,
  .register h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .agenda-list {
    max-width: 700px;
    margin: 0 auto;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 1.1rem;
  }

  .register {
    background: var(--surface, #f8fafc);
  }

  .register-subtitle {
    text-align: center;
    color: var(--muted, #64748b);
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .webinar-hero h1 {
      font-size: 1.9rem;
    }
  }
</style>
