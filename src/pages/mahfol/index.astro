  /* Region tabs */
  .region-tabs { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 14px; }
  .region-tabs button {
    background: var(--card); color: var(--text); border: 1px solid var(--card-border);
