  /* Contact & footer */
  .socials { display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-top: 24px; }
  .socials a { color: var(--gold-strong); text-decoration: none; font-weight: 700; border-bottom: 1px dashed rgba(238,106,77,0.45); }
  .footer { border-top: 1px solid var(--card-border); padding: 34px 0; background: #12142b; }
  .footer-inner { text-align: center; }
  .footer-inner p { font-weight: 700; margin-bottom: 6px; }
  .footer-legal { color: var(--muted); font-size: 0.85rem; font-weight: 400 !important; }

  @media (max-width: 760px) {
    .nav-links { display: none; }
    .hero { padding: 60px 0 50px; }
    .section { padding: 50px 0; }
    .trip-card h3 { padding-inline-end: 0; margin-top: 26px; }
  }
</style>

<script is:inline>
  (function () {
    const WEBHOOK_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/50c9e21d-294b-4d3e-8401-33be03c437d4/chat';
    const log = document.getElementById('chatLog');
    const form = document.getElementById('chatForm');
    const input = document.getElementById('chatText');
    const sendBtn = document.getElementById('chatSend');
    const suggests = document.getElementById('chatSuggests');
    const sid = 'mahfol-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
    let busy = false;

    function addMsg(text, who) {
      const el = document.createElement('div');
      el.className = 'msg ' + who;
      el.textContent = text;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    }

    async function send(message) {
      const msg = (message || '').trim();
      if (!msg || busy) return;
      busy = true;
      sendBtn.disabled = true;
      input.value = '';
      addMsg(msg, 'me');
      const thinking = addMsg('', 'bot');
      thinking.innerHTML = '<span class="dots"><span></span><span></span><span></span></span>';
      log.scrollTop = log.scrollHeight;

      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'sendMessage', sessionId: sid, chatInput: msg })
        });
        let reply = '';
        let isError = !res.ok;
        const raw = await res.text();
        try {
          const data = JSON.parse(raw);
          if (data && (data.output || data.text || data.reply || data.answer)) {
            reply = data.output ?? data.text ?? data.reply ?? data.answer;
          } else if (data && (data.message || data.code || data.error)) {
            isError = true;
          } else if (typeof data === 'string') {
            reply = data;
          }
        } catch (_) {
          if (/error in workflow|too many requests|<html/i.test(raw)) isError = true;
          else reply = raw;
        }
        reply = (typeof reply === 'string' ? reply : JSON.stringify(reply)).trim();
        if (isError || !reply) {
          thinking.textContent = 'المساعد مشغول حاليًا 🙏 جرب بعد لحظات، أو راسلنا مباشرة على info@mahmolmakfol.com';
        } else {
          thinking.textContent = reply;
        }
      } catch (e) {
        thinking.textContent = 'تعذر الاتصال بالمساعد. تأكد من الإنترنت وجرب مرة ثانية.';
      }
      log.scrollTop = log.scrollHeight;
      busy = false;
      sendBtn.disabled = false;
      input.focus();
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      send(input.value);
    });
    suggests.addEventListener('click', function (e) {
      const btn = e.target.closest('button[data-q]');
      if (btn) send(btn.getAttribute('data-q'));
    });
  })();

  // سوق الرحلات: بحث + فلاتر مدمجة (فئة، ميزانية، مدة) + تبويبات المناطق
  (function () {
    const filters = document.getElementById('marketFilters');
    const grid = document.getElementById('marketGrid');
    const search = document.getElementById('marketSearch');
    const budget = document.getElementById('marketBudget');
    const daysSel = document.getElementById('marketDays');
    const empty = document.getElementById('marketEmpty');
    const regionTabs = document.getElementById('regionTabs');
    const soonNote = document.getElementById('soonNote');
    if (!filters || !grid) return;
    let activeCat = 'all';

    function normalize(s) { return (s || '').toLowerCase().replace(/[أإآ]/g, 'ا').replace(/ة/g, 'ه'); }

    function apply() {
      const q = normalize(search.value.trim());
      const b = budget.value;
      const d = daysSel.value;
      let visible = 0;
      grid.querySelectorAll('.trip-tile').forEach(tile => {
        let show = true;
        if (activeCat !== 'all' && tile.getAttribute('data-cat') !== activeCat) show = false;
        if (show && q && !normalize(tile.getAttribute('data-search')).includes(q)) show = false;
        if (show && b !== 'all') {
          const p = parseFloat(tile.getAttribute('data-ppp'));
          if (!isNaN(p)) {
            if (b === 'lt1000' && p >= 1000) show = false;
            if (b === '1000-2500' && (p < 1000 || p > 2500)) show = false;
            if (b === 'gt2500' && p <= 2500) show = false;
          }
        }
        if (show && d !== 'all') {
          const days = parseInt(tile.getAttribute('data-days'), 10) || 1;
          if (d === '1' && days !== 1) show = false;
          if (d === '2' && days !== 2) show = false;
          if (d === '3' && days < 3) show = false;
        }
        tile.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      empty.hidden = visible > 0;
    }

    filters.addEventListener('click', function (e) {
      const btn = e.target.closest('button[data-f]');
      if (!btn) return;
      filters.querySelectorAll('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.getAttribute('data-f');
      apply();
    });
    search.addEventListener('input', apply);
    budget.addEventListener('change', apply);
    daysSel.addEventListener('change', apply);

    regionTabs.addEventListener('click', function (e) {
      const btn = e.target.closest('button[data-r]');
      if (!btn) return;
      soonNote.hidden = !btn.classList.contains('soon');
    });
  })();
</script>
</body>
</html>
