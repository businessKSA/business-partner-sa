  .service-card p { color: var(--muted); font-size: 0.95rem; }

  /* Trip cards */
  .trip-card { position: relative; display: flex; flex-direction: column; }
  .tag {
    position: absolute; top: 18px; inset-inline-end: 18px;
    background: rgba(217,164,65,0.15); color: var(--gold-strong);
    border: 1px solid rgba(217,164,65,0.4);
    padding: 3px 12px; border-radius: 999px; font-size: 0.8rem; font-weight: 700;
  }
  .trip-card h3 { font-size: 1.3rem; margin-bottom: 10px; padding-inline-end: 90px; }
  .trip-desc { color: var(--muted); font-size: 0.95rem; margin-bottom: 14px; }
  .check-list { list-style: none; margin-bottom: 14px; }
  .check-list li { padding-inline-start: 26px; position: relative; margin-bottom: 5px; font-size: 0.95rem; }
  .check-list li::before { content: '✓'; position: absolute; inset-inline-start: 0; color: var(--gold); font-weight: 900; }
  .trip-meta { display: flex; gap: 16px; flex-wrap: wrap; color: var(--muted); font-size: 0.88rem; margin-bottom: 16px; }
  .price-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 8px; }
  .price-box {
    flex: 1; min-width: 120px; background: rgba(217,164,65,0.08);
    border: 1px solid rgba(217,164,65,0.3); border-radius: 12px;
    padding: 10px 14px; text-align: center;
  }
  .price-label { display: block; color: var(--muted); font-size: 0.82rem; }
  .price-value { display: block; color: var(--gold-strong); font-weight: 900; font-size: 1.25rem; }
  .extras { list-style: none; color: var(--muted); font-size: 0.88rem; margin-bottom: 8px; }
  .vat-note { color: var(--muted); font-size: 0.78rem; margin-top: auto; }

  /* Camp */
  .camp-card h3 { font-size: 1.1rem; margin-bottom: 10px; }
  .camp-price { color: var(--gold-strong); font-weight: 900; font-size: 1.15rem; margin-bottom: 14px; }

  /* Tables */
  .table-wrap { overflow-x: auto; margin-bottom: 36px; border-radius: var(--radius); border: 1px solid var(--card-border); }
  .table-title { text-align: center; font-size: 1.3rem; font-weight: 800; margin: 10px 0 20px; color: var(--gold-strong); }
  .price-table { width: 100%; border-collapse: collapse; background: var(--card); min-width: 560px; }
  .price-table th, .price-table td { padding: 13px 16px; text-align: center; border-bottom: 1px solid var(--card-border); }
  .price-table th { background: #2b2214; font-weight: 800; font-size: 0.95rem; }
  .price-table td.dest { text-align: start; font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .price-table tr:hover td { background: rgba(217,164,65,0.05); }
  .col-vip { color: var(--gold-strong); font-weight: 800; }
  .col-silver { color: #c9ced6; }
  .col-bronze { color: #cd9a6b; }

  /* Chips */
  .chips { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 30px; }
  .chip {
    background: var(--card); border: 1px solid var(--card-border);
    padding: 9px 18px; border-radius: 999px; font-size: 0.95rem; font-weight: 600;
  }
  .chips-sm .chip { padding: 6px 14px; font-size: 0.85rem; }
  .chip-outline { background: transparent; color: var(--muted); }

  /* Custom questions */
  .q-card { display: flex; align-items: center; gap: 14px; padding: 18px 20px; }
  .q-icon { font-size: 1.6rem; }
  .q-card p { font-size: 0.95rem; }

  /* Accordion */
  .acc {
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: var(--radius); margin-bottom: 14px; overflow: hidden;
  }
  .acc summary {
    cursor: pointer; padding: 18px 22px; font-weight: 800; font-size: 1.05rem;
    list-style: none; position: relative;
  }
  .acc summary::-webkit-details-marker { display: none; }
  .acc summary::after { content: '+'; position: absolute; inset-inline-end: 22px; color: var(--gold); font-size: 1.3rem; }
  .acc[open] summary::after { content: '−'; }
  .acc ul { padding: 0 42px 20px 22px; color: var(--muted); font-size: 0.95rem; }
  .acc li { margin-bottom: 8px; }

  /* Contact & footer */
  .socials { display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-top: 24px; }
  .socials a { color: var(--gold-strong); text-decoration: none; font-weight: 700; border-bottom: 1px dashed rgba(217,164,65,0.4); }
  .footer { border-top: 1px solid var(--card-border); padding: 34px 0; background: #100d08; }
  .footer-inner { text-align: center; }
  .footer-inner p { font-weight: 700; margin-bottom: 6px; }
  .footer-legal { color: var(--muted); font-size: 0.85rem; font-weight: 400 !important; }

  @media (max-width: 760px) {
    .nav-links { display: none; }
    .hero { padding: 60px 0 50px; }
    .section { padding: 50px 0; }
    .trip-card h3 { padding-inline-end: 0; margin-top: 26px; }
  }
</style>
</body>
</html>
