---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>محمول مكفول للسياحة | رحلات وباقات سياحية في السعودية</title>
  <meta name="description" content="شركة محمول مكفول للسياحة — رحلات حافة العالم والتطعيس والتخييم، وباقات سياحية لثلاثة أيام إلى العلا ونيوم وجدة وينبع وجازان وأكثر. صمّم رحلتك على مقاسك." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐪</text></svg>" />
  <meta property="og:title" content="محمول مكفول للسياحة | رحلات وباقات سياحية في السعودية" />
  <meta property="og:description" content="رحلات حافة العالم والتطعيس والتخييم وباقات سياحية لكل مناطق المملكة — VIP، فضية، وبرونزية." />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ar_SA" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TravelAgency',
    name: 'شركة محمول مكفول للسياحة',
    alternateName: 'Mahmol Makfol Tourism Company',
    email: contact.email,
    url: contact.website,
    taxID: contact.vat,
    areaServed: 'SA',
    sameAs: [contact.instagram, contact.twitter, contact.tiktok, contact.snapchat],
  })} />
</head>
<body>

  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="brand">🐪 <span>محمول <b>مكفول</b></span></a>
      <nav class="nav-links">
        <a href="#day-trips">رحلات اليوم الواحد</a>
        <a href="#camp">المخيم الصحراوي</a>
        <a href="#packages">باقات المدن</a>
        <a href="#destinations">وجهاتنا</a>
        <a href="#alula">تجارب العلا</a>
        <a href="#custom">رحلة على مقاسك</a>
        <a href="#terms">الشروط</a>
      </nav>
      <a class="btn btn-gold" href={`mailto:${contact.email}?subject=${encodeURIComponent('طلب حجز رحلة')}`}>احجز الآن</a>
    </div>
  </header>

  <main id="top">

    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-badge">✦ عضو الاتحاد السعودي للسيارات والدراجات النارية</p>
        <h1>عيش المغامرة في <span class="gold">صحاري وجبال وبحار</span> المملكة</h1>
        <p class="hero-sub">
          شركة محمول مكفول للسياحة — رحلات سفاري وتخييم وتطعيس، فعاليات ومخيمات شركات،
          وباقات سياحية متكاملة لكل مناطق المملكة. برامج قابلة للتفصيل حسب رغبتك وميزانيتك.
        </p>
        <div class="hero-cta">
          <a class="btn btn-gold btn-lg" href="#day-trips">استكشف الرحلات</a>
          <a class="btn btn-outline btn-lg" href="#custom">صمّم رحلتك الخاصة</a>
        </div>
        <div class="hero-stats">
          <div><b>+15</b><span>وجهة سياحية</span></div>
          <div><b>3</b><span>فئات باقات: VIP · فضية · برونزية</span></div>
          <div><b>4-20</b><span>شخصًا في المجموعة</span></div>
          <div><b>2017</b><span>بداية شغفنا بالمغامرة</span></div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="section" id="services">
      <div class="container">
        <h2 class="section-title">ماذا نقدّم؟</h2>
        <p class="section-sub">ست خدمات متكاملة تحت سقف واحد</p>
        <div class="grid grid-3">
          {services.map((s) => (
            <div class="card service-card">
              <div class="service-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Day trips -->
    <section class="section section-alt" id="day-trips">
      <div class="container">
        <h2 class="section-title">رحلات اليوم الواحد والتخييم</h2>
        <p class="section-sub">انطلاقًا من الرياض — حافة العالم والتطعيس، بمجموعات من 3 إلى 12 شخصًا</p>
        <div class="grid grid-2">
          {dayTrips.map((t) => (
            <div class="card trip-card">
              <span class="tag">{t.tag}</span>
              <h3>{t.name}</h3>
              <p class="trip-desc">{t.desc}</p>
              <ul class="check-list">
                {t.features.map((f) => <li>{f}</li>)}
              </ul>
              <div class="trip-meta">
                <span>🗓️ {t.days}</span>
                <span>⏰ {t.time}</span>
              </div>
              <div class="price-row">
                {t.prices.map((p) => (
                  <div class="price-box">
                    <span class="price-label">{p.label}</span>
                    <span class="price-value">{p.value}</span>
                  </div>
                ))}
              </div>
              {t.extras && (
                <ul class="extras">
                  {t.extras.map((e) => <li>➕ {e}</li>)}
                </ul>
              )}
              <p class="vat-note">الأسعار غير شاملة ضريبة القيمة المضافة</p>
              <a class="btn btn-gold btn-block" href={`mailto:${contact.email}?subject=${encodeURIComponent('حجز: ' + t.name)}`}>احجز هذه الرحلة</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Camp package -->
    <section class="section" id="camp">
      <div class="container">
        <h2 class="section-title">{campPackage.name}</h2>
        <p class="section-sub">برنامج يومين متكامل: أنشطة، تخييم، مبيت، وهايكنج — بإشراف مرشد سياحي ومسعف</p>
        <div class="grid grid-3">
          {campPackage.options.map((o) => (
            <div class="card camp-card">
              <h3>{o.title}</h3>
              <p class="camp-price">{o.price}</p>
              <ul class="check-list">
                {o.features.map((f) => <li>{f}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- City packages -->
    <section class="section section-alt" id="packages">
      <div class="container">
        <h2 class="section-title">باقات المدن — 3 أيام</h2>
        <p class="section-sub">ثلاث فئات لكل وجهة: VIP، فضية، وبرونزية — السعر للشخص وغير شامل الضريبة</p>

        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>الوجهة</th>
                <th class="col-vip">VIP</th>
                <th class="col-silver">فضية</th>
                <th class="col-bronze">برونزية</th>
              </tr>
            </thead>
            <tbody>
              {cityPackages.map((r) => (
                <tr>
                  <td class="dest">{r.dest}</td>
                  <td class="col-vip">{r.vip} ر.س</td>
                  <td class="col-silver">{r.silver} ر.س</td>
                  <td class="col-bronze">{r.bronze} ر.س</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="table-title">باقات الجنوب والطائف</h3>
        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>الوجهة</th>
                <th>المدة</th>
                <th class="col-vip">VIP</th>
                <th class="col-silver">فضية</th>
                <th class="col-bronze">برونزية</th>
              </tr>
            </thead>
            <tbody>
              {southPackages.map((r) => (
                <tr>
                  <td class="dest">{r.dest}</td>
                  <td>{r.days}</td>
                  <td class="col-vip">{r.vip} ر.س</td>
                  <td class="col-silver">{r.silver} ر.س</td>
                  <td class="col-bronze">{r.bronze} ر.س</td>
                </tr>
