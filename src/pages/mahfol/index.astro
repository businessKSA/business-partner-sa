    transition: transform 0.15s, box-shadow 0.15s; white-space: nowrap;
    border: none; cursor: pointer; font-family: inherit;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-gold { background: linear-gradient(135deg, var(--gold), #d14a30); color: #fff6ef; box-shadow: 0 4px 18px rgba(238,106,77,0.40); }
  .btn-outline { border: 1.5px solid var(--gold); color: var(--gold-strong); background: transparent; }
  .btn-wa { background: linear-gradient(135deg, #2bdc70, #1da851); color: #fff; box-shadow: 0 4px 18px rgba(37,211,102,0.35); }
  .btn-lg { padding: 15px 34px; font-size: 1.05rem; }
  .btn-sm { padding: 8px 18px; font-size: 0.85rem; }

  /* Hero */
  .hero { position: relative; overflow: hidden; padding: 100px 0 80px; text-align: center; }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.30; animation: heroZoom 26s ease-in-out infinite alternate; }
  .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,22,48,0.55), rgba(23,25,51,0.94)); }
  .hero-inner { position: relative; z-index: 1; }
  @keyframes heroZoom { from { transform: scale(1); } to { transform: scale(1.12); } }
  .hero-badge {
    display: inline-block; padding: 7px 20px; border-radius: 999px;
    border: 1px solid var(--card-border); color: var(--gold-strong);
    font-size: 0.9rem; margin-bottom: 26px; background: rgba(238,106,77,0.10);
  }
  .hero h1 { font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 900; line-height: 1.35; max-width: 900px; margin: 0 auto 18px; }
  .gold { color: var(--gold); }
  .hero-sub { color: var(--muted); max-width: 720px; margin: 0 auto 34px; font-size: 1.15rem; }
  .hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 50px; }
  .hero-stats { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
