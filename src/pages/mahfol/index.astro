  { icon: '🚘', text: 'تجون بسيارتكم أو معنا؟' },
  { icon: '🥘', text: 'وجبات كاملة، سناكس، أو دليفري؟' },
  { icon: '🛥️', text: 'رحلة برية أو بحرية؟ يخت، قارب، أو بوت؟' },
  { icon: '💰', text: 'حدد ميزانيتك ونفصّل لك باقة على مقاسك' },
];
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>محفول مكفول | منصة الرحلات السياحية وإدارة الوحدات العقارية</title>
  <meta name="description" content="منصة محفول مكفول — سوق رحلات سياحية من موردين معتمدين في كل مناطق المملكة، إدارة وحدات عقارية سياحية على جاذرن وAirbnb، ومصمم رحلات بالذكاء الاصطناعي." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐪</text></svg>" />
  <meta property="og:title" content="محفول مكفول للسياحة | رحلات وباقات سياحية في السعودية" />
  <meta property="og:description" content="رحلات حافة العالم والتطعيس والتخييم وباقات سياحية لكل مناطق المملكة — VIP، فضية، وبرونزية." />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ar_SA" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TravelAgency',
    name: 'شركة محفول مكفول للسياحة',
    alternateName: 'Mahmol Makfol Tourism Company',
    email: contact.email,
    url: contact.website,
    taxID: contact.vat,
    areaServed: 'SA',
    sameAs: [contact.instagram, contact.twitter, contact.tiktok, contact.snapchat],
  })} />
</head>
<body>

  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="brand">🐪 <span>محفول <b>مكفول</b></span></a>
      <nav class="nav-links">
        <a href="#market">سوق الرحلات</a>
        <a href="#units">إدارة الوحدات</a>
        <a href="#packages">باقات المدن</a>
        <a href="#alula">تجارب العلا</a>
        <a href="#designer">المصمم الذكي</a>
        <a href="#vendors">كن موردًا</a>
      </nav>
      <a class="btn btn-gold" href={`mailto:${contact.email}?subject=${encodeURIComponent('طلب حجز رحلة')}`}>احجز الآن</a>
    </div>
  </header>

  <main id="top">

    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <p class="hero-badge">✦ عضو الاتحاد السعودي للسيارات والدراجات النارية</p>
        <h1>منصة <span class="gold">محفول مكفول</span> — رحلات من موردين معتمدين وإدارة وحدات سياحية</h1>
        <p class="hero-sub">
          سوق سفر ورحلات يجمع أفضل الباقات من موردين معتمدين — نبدأ من السعودية،
          وقريبًا: الخليج ومصر وتركيا وشرق آسيا. مع إدارة كاملة لوحدتك العقارية السياحية على جاذرن وAirbnb،
          ومصمم رحلات بالذكاء الاصطناعي يفصّل رحلتك على ميزانيتك.
        </p>
        <div class="hero-cta">
          <a class="btn btn-gold btn-lg" href="#designer">🤖 صمّم رحلتك بالذكاء الاصطناعي</a>
          <a class="btn btn-outline btn-lg" href="#day-trips">استكشف الرحلات</a>
        </div>
        <div class="hero-stats">
          <div><b>+18</b><span>رحلة من موردين معتمدين</span></div>
          <div><b>+15</b><span>وجهة داخل السعودية</span></div>
          <div><b>5</b><span>أسواق في خارطة التوسع 🌍</span></div>
          <div><b>🏠</b><span>إدارة وحدات على جاذرن وAirbnb</span></div>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <div class="trust-strip">
      <div class="container trust-inner">
        {trustPoints.map((p) => <span>{p.icon} {p.text}</span>)}
      </div>
    </div>

    <!-- Trips marketplace -->
    <section class="section" id="market">
      <div class="container">
        <h2 class="section-title">🛒 سوق الرحلات</h2>
        <p class="section-sub">كل رحلة يقدمها مورد معتمد ومدقق من منصة محفول مكفول — ابحث وفلتر واحجز</p>

        <div class="region-tabs" id="regionTabs">
          <button type="button" class="active" data-r="sa">🇸🇦 السعودية</button>
          <button type="button" class="soon" data-r="gcc">🇦🇪 الخليج <small>قريبًا</small></button>
          <button type="button" class="soon" data-r="eg">🇪🇬 مصر <small>قريبًا</small></button>
          <button type="button" class="soon" data-r="tr">🇹🇷 تركيا <small>قريبًا</small></button>
          <button type="button" class="soon" data-r="asia">🌏 شرق آسيا <small>قريبًا</small></button>
        </div>
        <p class="soon-note" id="soonNote" hidden>
          🚀 هذه الوجهة قريبًا في المنصة — <a href={`mailto:${contact.email}?subject=${encodeURIComponent('سجلوني باهتمامات الوجهات الجديدة')}`}>سجّل اهتمامك</a> وكن أول من يعرف عند الإطلاق
        </p>

        <div class="market-search">
          <input type="search" id="marketSearch" placeholder="🔍 ابحث: العلا، تخييم، يخت، شهر عسل…" />
          <select id="marketBudget">
            <option value="all">💰 كل الميزانيات</option>
            <option value="lt1000">أقل من 1,000 ر.س/شخص</option>
            <option value="1000-2500">1,000 – 2,500 ر.س/شخص</option>
            <option value="gt2500">أكثر من 2,500 ر.س/شخص</option>
          </select>
          <select id="marketDays">
            <option value="all">🗓️ أي مدة</option>
            <option value="1">يوم واحد</option>
            <option value="2">يومان</option>
            <option value="3">3 أيام وأكثر</option>
          </select>
        </div>

        <div class="market-filters" id="marketFilters">
          <button type="button" class="active" data-f="all">الكل</button>
          <button type="button" data-f="day">يوم واحد</button>
          <button type="button" data-f="camp">تخييم</button>
          <button type="button" data-f="city">باقات مدن</button>
          <button type="button" data-f="sea">بحرية</button>
          <button type="button" data-f="alula">العلا</button>
        </div>

        <div class="market-grid" id="marketGrid">
          {marketTrips.map((t) => (
            <div class="trip-tile" data-cat={t.cat} data-ppp={t.ppp ?? ''} data-days={t.days} data-search={`${t.name} ${t.city} ${t.catLabel} ${t.provider} ${t.tags}`}>
              <div class="tile-head"><span class="tile-icon">{t.icon}</span><span class="tile-cat">{t.catLabel}</span></div>
              <h3>{t.name}</h3>
              <div class="tile-meta">
                <span>📍 {t.city}</span>
                <span>⏱️ {t.dur}</span>
              </div>
              <div class="tile-price">{t.price}</div>
              <div class="tile-provider">✓ مورد معتمد · {t.provider}</div>
              <div class="tile-actions">
                <a class="btn btn-gold btn-sm" href={`mailto:${contact.email}?subject=${encodeURIComponent('حجز: ' + t.name)}`}>احجز</a>
                <a class="btn btn-outline btn-sm" href="#designer">فصّلها بالذكاء</a>
              </div>
            </div>
          ))}
        </div>
        <p class="market-empty" id="marketEmpty" hidden>ما لقينا رحلة تطابق بحثك 🤔 — جرّب فلاتر أوسع، أو <a href="#designer">خلّ الذكاء الاصطناعي يفصّل لك رحلة خاصة</a></p>
        <p class="market-note">الأسعار المبدئية غير شاملة الضريبة ما لم يُذكر خلاف ذلك · التفاصيل الكاملة في أقسام الباقات أدناه</p>
      </div>
    </section>

    <!-- Services -->
    <section class="section section-alt" id="services">
      <div class="container">
        <h2 class="section-title">ماذا نقدّم؟</h2>
        <p class="section-sub">ست خدمات متكاملة تحت سقف واحد</p>
        <div class="grid grid-3">
          {services.map((s) => (
            <div class="card service-card">
              <div class="service-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Property management -->
    <section class="section" id="units">
      <div class="container">
        <h2 class="section-title">🏠 إدارة الوحدات العقارية السياحية</h2>
        <p class="section-sub">
          عندك شاليه، مخيم، مزرعة، كرفان أو شقة مفروشة؟ ندريها لك بالكامل على
          <b> جاذرن، Airbnb، Booking </b> — أنت تستلم العائد ونحن نتكفل بالباقي
        </p>
        <div class="grid grid-3">
          {unitServices.map((u) => (
            <div class="card service-card">
              <div class="service-icon">{u.icon}</div>
              <h3>{u.title}</h3>
              <p>{u.desc}</p>
            </div>
          ))}
        </div>
        <div class="units-cta">
          <div class="units-steps">
            <span><b>1</b> سجّل وحدتك</span>
            <span class="step-arrow">←</span>
            <span><b>2</b> نعاينها ونجهزها وندرجها</span>
            <span class="step-arrow">←</span>
            <span><b>3</b> تستلم عائدك الشهري وتقريرك</span>
          </div>
          <a class="btn btn-gold btn-lg" href={`mailto:${contact.email}?subject=${encodeURIComponent('تسجيل وحدة عقارية سياحية للإدارة')}&body=${encodeURIComponent('نوع الوحدة (شاليه/مخيم/مزرعة/كرفان/شقة):\nالمدينة:\nعدد الغرف/السعة:\nهل الوحدة مرخصة؟')}`}>سجّل وحدتك الآن</a>
        </div>
      </div>
    </section>

    <!-- Day trips -->
    <section class="section section-alt" id="day-trips">
      <div class="container">
        <h2 class="section-title">رحلات اليوم الواحد والتخييم</h2>
        <p class="section-sub">انطلاقًا من الرياض — حافة العالم والتطعيس، بمجموعات من 3 إلى 12 شخصًا</p>
        <div class="grid grid-2">
          {dayTrips.map((t) => (
            <div class="card trip-card">
              <span class="tag">{t.tag}</span>
              <h3>{t.name}</h3>
              <p class="trip-desc">{t.desc}</p>
              <ul class="check-list">
                {t.features.map((f) => <li>{f}</li>)}
              </ul>
              <div class="trip-meta">
                <span>🗓️ {t.days}</span>
                <span>⏰ {t.time}</span>
              </div>
              <div class="price-row">
                {t.prices.map((p) => (
                  <div class="price-box">
                    <span class="price-label">{p.label}</span>
                    <span class="price-value">{p.value}</span>
                  </div>
                ))}
              </div>
              {t.extras && (
                <ul class="extras">
                  {t.extras.map((e) => <li>➕ {e}</li>)}
                </ul>
              )}
              <p class="vat-note">الأسعار غير شاملة ضريبة القيمة المضافة</p>
              <a class="btn btn-gold btn-block" href={`mailto:${contact.email}?subject=${encodeURIComponent('حجز: ' + t.name)}`}>احجز هذه الرحلة</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Camp package -->
    <section class="section" id="camp">
      <div class="container">
        <h2 class="section-title">{campPackage.name}</h2>
        <p class="section-sub">برنامج يومين متكامل: أنشطة، تخييم، مبيت، وهايكنج — بإشراف مرشد سياحي ومسعف</p>
        <div class="grid grid-3">
          {campPackage.options.map((o) => (
            <div class="card camp-card">
              <h3>{o.title}</h3>
              <p class="camp-price">{o.price}</p>
              <ul class="check-list">
                {o.features.map((f) => <li>{f}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- City packages -->
    <section class="section section-alt" id="packages">
      <div class="container">
        <h2 class="section-title">باقات المدن — 3 أيام</h2>
        <p class="section-sub">ثلاث فئات لكل وجهة: VIP، فضية، وبرونزية — السعر للشخص وغير شامل الضريبة</p>

        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>الوجهة</th>
                <th class="col-vip">VIP</th>
                <th class="col-silver">فضية</th>
                <th class="col-bronze">برونزية</th>
              </tr>
            </thead>
            <tbody>
              {cityPackages.map((r) => (
                <tr>
                  <td class="dest">{r.dest}</td>
                  <td class="col-vip">{r.vip} ر.س</td>
                  <td class="col-silver">{r.silver} ر.س</td>
                  <td class="col-bronze">{r.bronze} ر.س</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="table-title">باقات الجنوب والطائف</h3>
        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>الوجهة</th>
                <th>المدة</th>
                <th class="col-vip">VIP</th>
                <th class="col-silver">فضية</th>
                <th class="col-bronze">برونزية</th>
              </tr>
            </thead>
            <tbody>
              {southPackages.map((r) => (
                <tr>
                  <td class="dest">{r.dest}</td>
                  <td>{r.days}</td>
                  <td class="col-vip">{r.vip} ر.س</td>
                  <td class="col-silver">{r.silver} ر.س</td>
                  <td class="col-bronze">{r.bronze} ر.س</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="table-title">باقات الوجهات المتعددة</h3>
        <div class="table-wrap">
          <table class="price-table">
            <thead>
              <tr>
                <th>المسار</th>
                <th>المدة</th>
                <th class="col-vip">VIP</th>
                <th class="col-silver">فضية</th>
                <th class="col-bronze">برونزية</th>
              </tr>
            </thead>
            <tbody>
              {comboPackages.map((r) => (
                <tr>
                  <td class="dest">{r.dest}</td>
                  <td>{r.days}</td>
                  <td class="col-vip">{r.vip} ر.س</td>
                  <td class="col-silver">{r.silver} ر.س</td>
                  <td class="col-bronze">{r.bronze} ر.س</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="center">
          <a class="btn btn-gold btn-lg" href={`mailto:${contact.email}?subject=${encodeURIComponent('استفسار عن باقات المدن')}`}>اطلب عرض سعر لباقتك</a>
        </div>
      </div>
    </section>

    <!-- Destinations & experiences -->
    <section class="section" id="destinations">
      <div class="container">
        <h2 class="section-title">وجهاتنا</h2>
        <p class="section-sub">من حافة العالم إلى جزر فرسان — المملكة كلها ملعبنا</p>
        <div class="chips">
          {destinations.map((d) => <span class="chip">{d}</span>)}
        </div>
        <h3 class="table-title">تجارب نقدمها</h3>
        <div class="chips chips-sm">
          {experiences.map((e) => <span class="chip chip-outline">{e}</span>)}
        </div>
      </div>
    </section>

    <!-- AlUla experiences -->
    <section class="section section-alt" id="alula">
      <div class="container">
        <h2 class="section-title">تجارب العلا ✨</h2>
        <p class="section-sub">
          بصفتنا مقدم خدمات رحلات، نوفر لك حجز تجارب العلا الرسمية (Experience AlUla) ضمن باقتك مع محفول مكفول —
          احجزها معنا مع النقل والسكن والبرنامج كاملًا
        </p>
        {alulaExperiences.map((g) => (
          <div class="alula-group">
            <h3 class="table-title">{g.group}</h3>
            <div class="chips chips-sm">
              {g.items.map((i) => <span class="chip">{i}</span>)}
            </div>
          </div>
        ))}
        <div class="center">
          <a class="btn btn-gold btn-lg" href={`mailto:${contact.email}?subject=${encodeURIComponent('حجز تجارب العلا')}`}>احجز تجربتك في العلا</a>
        </div>
      </div>
    </section>

    <!-- AI Trip Designer -->
    <section class="section section-dark" id="designer">
      <div class="container">
        <h2 class="section-title">🤖 مصمم الرحلات الذكي</h2>
        <p class="section-sub">
          مساعد ذكاء اصطناعي يفصّل رحلتك من باقاتنا الحقيقية بأسعارها الحقيقية —
          كلمه بالعامية، حدد ميزانيتك، وبيصمم لك برنامجًا يوم-بيوم مع ملخص حجز جاهز
        </p>
        <div class="chat-shell">
          <div class="chat-log" id="chatLog">
            <div class="msg bot">هلا وسهلا! 👋 أنا مصمم رحلات محفول مكفول الذكي.<br />قل لي: وين ودك تروح؟ كم عددكم؟ ومتى؟ — وأفصّل لك رحلة على مقاسك بأسعارنا الحقيقية.</div>
          </div>
          <div class="chat-suggests" id="chatSuggests">
            <button type="button" data-q="ابغى رحلة حافة العالم لستة أشخاص مع تخييم">🏔️ حافة العالم مع تخييم</button>
            <button type="button" data-q="صمم لي رحلة العلا 3 أيام لأربعة أشخاص بميزانية متوسطة">🏜️ العلا 3 أيام</button>
            <button type="button" data-q="ابغى رحلة بحرية في جدة مع يخت وسنوركل ليوم واحد">🛥️ رحلة بحرية بجدة</button>
            <button type="button" data-q="اقترح لي رحلة عائلية مبتكرة بميزانية 5000 ريال">👨‍👩‍👧‍👦 رحلة عائلية بـ5000</button>
          </div>
          <form class="chat-input" id="chatForm">
            <input type="text" id="chatText" placeholder="اكتب طلبك… مثال: ابغى رحلة نهاية الأسبوع لعائلتي" autocomplete="off" />
            <button type="submit" class="btn btn-gold" id="chatSend">إرسال</button>
          </form>
          <p class="chat-note">الأسعار من باقاتنا المعتمدة · تأكيد الحجز النهائي يتم مع فريق المبيعات</p>
        </div>
      </div>
    </section>

    <!-- Custom trip -->
    <section class="section section-dark" id="custom">
      <div class="container">
        <h2 class="section-title">رحلة على مقاسك 💫</h2>
        <p class="section-sub">أخبرنا برغباتك ونفصّل لك باقة خاصة — أفراد، عوائل، أو مجموعات</p>
        <div class="grid grid-3">
          {customQuestions.map((q) => (
            <div class="card q-card">
              <span class="q-icon">{q.icon}</span>
              <p>{q.text}</p>
            </div>
          ))}
        </div>
        <div class="center">
          <a class="btn btn-gold btn-lg" href={`mailto:${contact.email}?subject=${encodeURIComponent('طلب تصميم رحلة خاصة')}`}>ابدأ تصميم رحلتك</a>
        </div>
      </div>
    </section>

    <!-- Expansion roadmap -->
    <section class="section section-alt" id="expansion">
      <div class="container">
        <h2 class="section-title">🌍 خارطة التوسع</h2>
        <p class="section-sub">نبدأ من السعودية ونتوسع سوقًا بعد سوق — في كل سوق جديد ننضم مع موردين محليين معتمدين</p>
        <div class="grid grid-3">
          {regions.map((r) => (
            <div class={`card region-card ${r.status}`}>
              <div class="region-head">
                <span class="region-flag">{r.flag}</span>
