  .units-cta { text-align: center; margin-top: 34px; }
  .units-steps { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; align-items: center; color: var(--muted); font-size: 0.95rem; margin-bottom: 24px; }
  .units-steps b {
    display: inline-flex; width: 26px; height: 26px; border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #d14a30); color: #fff6ef;
    align-items: center; justify-content: center; margin-inline-end: 6px; font-size: 0.85rem;
  }
  .step-arrow { color: var(--gold); font-weight: 900; }

  /* Activities */
  .act-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
  .act-card {
    background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius);
    overflow: hidden; text-decoration: none; color: var(--text);
    display: flex; flex-direction: column; transition: transform 0.15s, border-color 0.15s;
  }
  .act-card:hover { transform: translateY(-4px); border-color: var(--wa); }
  .act-media { position: relative; height: 130px; background: linear-gradient(135deg, #2d3166, #3b3f8f 60%, rgba(238,106,77,0.5)); }
  .act-media img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
  .act-media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(37,41,82,0.65)); }
  .act-emoji { position: absolute; bottom: 6px; inset-inline-start: 12px; font-size: 1.6rem; z-index: 2; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.6)); }
  .act-card h3 { padding: 12px 16px 0; font-size: 1rem; }
  .act-card p { padding: 2px 16px 0; color: var(--muted); font-size: 0.84rem; flex: 1; }
  .act-price { padding: 8px 16px 14px; color: var(--gold-strong); font-weight: 800; font-size: 0.8rem; }

  /* AI chat */
  .chat-shell { max-width: 780px; margin: 0 auto; background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius); padding: 18px; }
  .chat-log { height: 380px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; padding: 8px 4px; scroll-behavior: smooth; }
  .msg { max-width: 85%; padding: 12px 16px; border-radius: 16px; line-height: 1.7; font-size: 0.95rem; white-space: pre-wrap; word-wrap: break-word; }
  .msg.bot { background: #2d3166; border: 1px solid var(--card-border); align-self: flex-start; border-start-start-radius: 4px; }
  .msg.me { background: linear-gradient(135deg, var(--gold), #d14a30); color: #fff6ef; align-self: flex-end; border-start-end-radius: 4px; }
  .msg .dots span { display: inline-block; width: 7px; height: 7px; margin: 0 2px; border-radius: 50%; background: var(--gold-strong); animation: blink 1.2s infinite; }
  .msg .dots span:nth-child(2) { animation-delay: 0.2s; }
  .msg .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%, 80%, 100% { opacity: 0.25; } 40% { opacity: 1; } }
  .chat-suggests { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0; }
  .chat-suggests button {
    background: rgba(238,106,77,0.10); color: var(--text);
    border: 1px solid rgba(238,106,77,0.35); border-radius: 999px;
    padding: 7px 14px; font-size: 0.85rem; cursor: pointer; font-family: inherit;
  }
  .chat-suggests button:hover { background: rgba(238,106,77,0.22); }
  .chat-input { display: flex; gap: 10px; }
  .chat-input input {
    flex: 1; background: #1c1f42; border: 1px solid var(--card-border);
    border-radius: 999px; padding: 12px 18px; color: var(--text);
    font-family: inherit; font-size: 0.95rem; outline: none;
  }
  .chat-input input:focus { border-color: var(--gold); }
  .chat-input .btn:disabled { opacity: 0.5; cursor: wait; transform: none; }
  .chat-note { text-align: center; color: var(--muted); font-size: 0.78rem; margin-top: 10px; }

  /* Regions */
  .regions-row { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-bottom: 26px; }
  .region-pill {
    background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius);
    padding: 18px 22px; min-width: 190px; text-align: center;
  }
  .region-pill.soon { opacity: 0.8; }
  .region-flag { display: block; font-size: 2rem; margin-bottom: 4px; }
  .region-pill b { display: block; font-size: 1.05rem; }
  .region-pill small { display: block; color: var(--muted); font-size: 0.78rem; margin: 4px 0 8px; }
  .region-badge { font-size: 0.72rem; font-weight: 800; padding: 3px 12px; border-radius: 999px; }
  .region-badge.live { background: rgba(74,222,128,0.12); color: #6fe89e; border: 1px solid rgba(74,222,128,0.4); }
  .region-badge.soon { background: rgba(238,106,77,0.10); color: var(--gold-strong); border: 1px solid rgba(238,106,77,0.35); }

  /* Chips */
  .chips { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 24px; }
  .chip { background: var(--card); border: 1px solid var(--card-border); padding: 8px 16px; border-radius: 999px; font-size: 0.9rem; font-weight: 600; }
  .chips-sm .chip { padding: 6px 14px; font-size: 0.85rem; }
  .chip-outline { background: transparent; color: var(--muted); }

  /* Accordion */
  .acc { background: var(--card); border: 1px solid var(--card-border); border-radius: var(--radius); margin-bottom: 14px; overflow: hidden; }
  .acc summary { cursor: pointer; padding: 18px 22px; font-weight: 800; font-size: 1.05rem; list-style: none; position: relative; }
  .acc summary::-webkit-details-marker { display: none; }
  .acc summary::after { content: '+'; position: absolute; inset-inline-end: 22px; color: var(--gold); font-size: 1.3rem; }
  .acc[open] summary::after { content: '−'; }
  .acc ul { padding: 0 42px 20px 22px; color: var(--muted); font-size: 0.95rem; }
  .acc li { margin-bottom: 8px; }

  /* Contact & footer */
  .socials { display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-top: 26px; }
  .socials a { color: var(--gold-strong); text-decoration: none; font-weight: 700; border-bottom: 1px dashed rgba(238,106,77,0.45); }
  .footer { border-top: 1px solid var(--card-border); padding: 34px 0 90px; background: #12142b; }
  .footer-inner { text-align: center; }
  .footer-inner p { font-weight: 700; margin-bottom: 6px; }
  .footer-legal { color: var(--muted); font-size: 0.85rem; font-weight: 400 !important; }
  .market-note { text-align: center; color: var(--muted); font-size: 0.82rem; margin-top: 28px; }

  /* WhatsApp FAB */
  .wa-fab {
    position: fixed; bottom: 22px; inset-inline-start: 22px; z-index: 60;
    width: 58px; height: 58px; border-radius: 50%;
    background: linear-gradient(135deg, #2bdc70, #1da851);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 24px rgba(37,211,102,0.45);
    animation: waPulse 2.4s infinite;
  }
  @keyframes waPulse {
    0%, 100% { box-shadow: 0 6px 24px rgba(37,211,102,0.45); }
    50% { box-shadow: 0 6px 34px rgba(37,211,102,0.75); }
  }

  /* Reveal */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .hero-bg img { animation: none; }
    .wa-fab { animation: none; }
    .reveal { opacity: 1; transform: none; transition: none; }
  }

  @media (max-width: 900px) {
    .dest-card, .dest-card.flip { grid-template-columns: 1fr; }
    .dest-card.flip .dest-media { order: 0; }
    .dest-media { min-height: 220px; }
    .prog-row { grid-template-columns: 1fr auto; }
    .prog-dur { display: none; }
  }
  @media (max-width: 760px) {
    .nav-links { display: none; }
    .hero { padding: 70px 0 55px; }
    .section { padding: 56px 0; }
  }
</style>

<script is:inline>
  (function () {
    const WEBHOOK_URL = 'https://businesspartnerai.app.n8n.cloud/webhook/9913c585-eca8-41f6-b2b1-e1cc22bfbb12/chat';
    const log = document.getElementById('chatLog');
    const form = document.getElementById('chatForm');
    const input = document.getElementById('chatText');
    const sendBtn = document.getElementById('chatSend');
    const suggests = document.getElementById('chatSuggests');
    const sid = 'mahfol-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
    let busy = false;

    function addMsg(text, who) {
      const el = document.createElement('div');
      el.className = 'msg ' + who;
      el.textContent = text;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    }

    async function send(message) {
      const msg = (message || '').trim();
      if (!msg || busy) return;
      busy = true;
      sendBtn.disabled = true;
      input.value = '';
      addMsg(msg, 'me');
      const thinking = addMsg('', 'bot');
      thinking.innerHTML = '<span class="dots"><span></span><span></span><span></span></span>';
      log.scrollTop = log.scrollHeight;

      try {
        const res = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'sendMessage', sessionId: sid, chatInput: msg })
        });
        let reply = '';
        let isError = !res.ok;
        const raw = await res.text();
        try {
          const data = JSON.parse(raw);
          if (data && (data.output || data.text || data.reply || data.answer)) {
            reply = data.output ?? data.text ?? data.reply ?? data.answer;
          } else if (data && (data.message || data.code || data.error)) {
            isError = true;
          } else if (typeof data === 'string') {
            reply = data;
          }
        } catch (_) {
          if (/error in workflow|too many requests|<html/i.test(raw)) isError = true;
          else reply = raw;
        }
        reply = (typeof reply === 'string' ? reply : JSON.stringify(reply)).trim();
        if (isError || !reply) {
          thinking.textContent = 'المساعد مشغول حاليًا 🙏 كلمنا مباشرة على الواتساب +966 50 138 6327';
        } else {
          thinking.textContent = reply;
        }
      } catch (e) {
        thinking.textContent = 'تعذر الاتصال بالمساعد. جرب مرة ثانية أو كلمنا واتساب.';
      }
      log.scrollTop = log.scrollHeight;
      busy = false;
      sendBtn.disabled = false;
      input.focus();
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      send(input.value);
    });
    suggests.addEventListener('click', function (e) {
      const btn = e.target.closest('button[data-q]');
      if (btn) send(btn.getAttribute('data-q'));
    });
  })();

  // ظهور تدريجي للأقسام أثناء التمرير
  (function () {
    const targets = document.querySelectorAll('.dest-card, .card, .act-card, .section-title, .section-sub, .acc, .chat-shell, .region-pill');
    targets.forEach(el => el.classList.add('reveal'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.06 });
    targets.forEach(el => io.observe(el));
  })();
</script>
