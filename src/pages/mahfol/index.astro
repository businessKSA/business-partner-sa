<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>محفول مكفول | اكتشف السعودية — رحلات ووجهات وإقامة وتجارب</title>
  <meta name="description" content="منصة محفول مكفول السياحية: وجهات السعودية ببرامج جاهزة وأسعار واضحة — الرياض، العلا، جدة، نيوم، أملج، عسير، فرسان، الطائف — مع مخيمات ووحدات إقامة وأنشطة وتجارب، وحجز فوري عبر الواتساب." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐪</text></svg>" />
  <meta property="og:title" content="محفول مكفول | اكتشف السعودية" />
  <meta property="og:description" content="وجهات وبرامج وأسعار واضحة + مخيمات ووحدات + أنشطة وتجارب — احجز عبر الواتساب أو صمم رحلتك بالذكاء الاصطناعي." />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ar_SA" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TravelAgency',
    name: 'محفول مكفول',
    legalName: 'شركة محفول مكفول للسياحة',
    alternateName: 'Mahfol Makfol',
    email: contact.email,
    telephone: '+966501386327',
    taxID: contact.vat,
    areaServed: 'SA',
    sameAs: [contact.instagram, contact.twitter, contact.tiktok, contact.snapchat],
  })} />
</head>
<body>

  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="brand">🐪 <span>محفول <b>مكفول</b></span></a>
      <nav class="nav-links">
        <a href="#destinations">الوجهات</a>
        <a href="#stays">الوحدات والمخيمات</a>
        <a href="#activities">الأنشطة والتجارب</a>
        <a href="#designer">المصمم الذكي</a>
        <a href="#owners">إدارة أملاكك</a>
      </nav>
      <a class="btn btn-wa" href={wa('أبغى أستفسر عن رحلة')} target="_blank" rel="noopener">💬 واتساب</a>
    </div>
  </header>

  <main id="top">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg"><img src={BR.discover} alt="" loading="eager" onerror="this.remove()" /></div>
      <div class="container hero-inner">
        <p class="hero-badge">✦ منصة سعودية · موردون معتمدون · حجز فوري بالواتساب</p>
        <h1>اكتشف السعودية <span class="gold">كما لم تعرفها</span></h1>
        <p class="hero-sub">
          من جروف حافة العالم إلى شعاب أملج المرجانية، ومن حِجر العلا إلى ضباب السودة —
          برامج جاهزة بأسعار واضحة، مخيمات ووحدات إقامة، وتجارب تروى للأحفاد.
        </p>
        <div class="hero-cta">
          <a class="btn btn-gold btn-lg" href="#destinations">استكشف الوجهات</a>
          <a class="btn btn-wa btn-lg" href={wa('أبغى أحجز رحلة')} target="_blank" rel="noopener">💬 احجز واتساب</a>
        </div>
        <div class="hero-stats">
          <div><b>9</b><span>وجهات ببرامج جاهزة</span></div>
          <div><b>+30</b><span>برنامجًا ونشاطًا</span></div>
          <div><b>3</b><span>فئات: VIP · فضية · برونزية</span></div>
          <div><b>24/7</b><span>واتساب ومصمم ذكي</span></div>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <div class="trust-strip">
      <div class="container trust-inner">
        {trustPoints.map((p) => <span>{p.icon} {p.text}</span>)}
      </div>
    </div>

    <!-- Destinations -->
    <section class="section" id="destinations">
      <div class="container">
        <h2 class="section-title">وجهاتك في السعودية</h2>
        <p class="section-sub">كل وجهة ببرامجها الجاهزة وأسعارها الواضحة — اختر مدينتك وخل الباقي علينا</p>

        <div class="dest-list">
          {destinations.map((d, i) => (
            <article class={`dest-card ${i % 2 ? 'flip' : ''}`} id={`dest-${d.id}`}>
              <div class="dest-media">
                <img src={d.img} alt={d.name} loading="lazy" onerror="this.remove()" />
                <span class="dest-emoji">{d.emoji}</span>
              </div>
              <div class="dest-body">
                <h3>{d.name}</h3>
                <p class="dest-tagline">{d.tagline}</p>
                <p class="dest-desc">{d.desc}</p>
                <div class="dest-highlights">
                  {d.highlights.map((h) => <span>{h}</span>)}
                </div>
                <div class="dest-programs">
                  {d.programs.map((p) => (
                    <a class="prog-row" href={wa(`أبغى أحجز: ${p.name} (${d.name})`)} target="_blank" rel="noopener">
                      <span class="prog-name">{p.name}</span>
                      <span class="prog-dur">{p.dur}</span>
                      <span class="prog-price">{p.price}</span>
                      <span class="prog-go">احجز ←</span>
                    </a>
                  ))}
                </div>
                <div class="dest-actions">
                  <a class="btn btn-wa" href={wa(`أبغى برنامج كامل لوجهة ${d.name}`)} target="_blank" rel="noopener">💬 استفسر واتساب</a>
                  <a class="btn btn-outline" href="#designer">🤖 فصّلها على مقاسك</a>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="market-note">الأسعار للشخص وغير شاملة الضريبة ما لم يُذكر خلاف ذلك · المجموعات من 4 إلى 20 شخصًا · البرامج قابلة للتخصيص</p>
      </div>
    </section>

    <!-- Stays -->
    <section class="section section-alt" id="stays">
      <div class="container">
        <h2 class="section-title">وحدات ومخيمات تنام فيها المغامرة</h2>
        <p class="section-sub">من مخيم على حافة العالم إلى شاليه على البحر — إقامات مختارة عبر موردين معتمدين</p>
        <div class="grid grid-3">
          {stays.map((st) => (
            <div class="card stay-card">
              <div class="stay-media">
                <img src={st.img} alt={st.name} loading="lazy" onerror="this.remove()" />
                <span class="stay-emoji">{st.emoji}</span>
              </div>
              <h3>{st.name}</h3>
              <p class="stay-where">📍 {st.where}</p>
              <p class="stay-desc">{st.desc}</p>
              <div class="stay-foot">
                <span class="stay-price">{st.price}</span>
                <a class="btn btn-wa btn-sm" href={wa(`أبغى أحجز إقامة: ${st.name}`)} target="_blank" rel="noopener">احجز</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Owners: property management -->
    <section class="section" id="owners">
      <div class="container">
        <h2 class="section-title">🏠 عندك وحدة؟ خلها تشتغل لك</h2>
        <p class="section-sub">
          ندير شاليهك أو مخيمك أو مزرعتك أو شقتك بالكامل على <b>جاذرن وAirbnb وBooking</b> —
          أنت تستلم العائد ونحن نتكفل بالباقي
        </p>
        <div class="grid grid-3">
          {unitServices.map((u) => (
            <div class="card service-card">
              <div class="service-icon">{u.icon}</div>
              <h3>{u.title}</h3>
              <p>{u.desc}</p>
            </div>
          ))}
        </div>
        <div class="units-cta">
          <div class="units-steps">
            <span><b>1</b> سجّل وحدتك</span>
            <span class="step-arrow">←</span>
            <span><b>2</b> نعاينها ونجهزها وندرجها</span>
            <span class="step-arrow">←</span>
            <span><b>3</b> تستلم عائدك وتقريرك شهريًا</span>
          </div>
          <a class="btn btn-wa btn-lg" href={wa('عندي وحدة عقارية وأبغاكم تديرونها لي.\nنوع الوحدة: \nالمدينة: \nالسعة: ')} target="_blank" rel="noopener">💬 سجّل وحدتك واتساب</a>
        </div>
      </div>
    </section>

    <!-- Activities -->
    <section class="section section-alt" id="activities">
      <div class="container">
        <h2 class="section-title">أنشطة وتجارب تعيشها</h2>
        <p class="section-sub">اختر التجربة وندمجها لك في برنامجك — أو نصمم يومًا كاملاً حولها</p>
        <div class="act-grid">
          {activities.map((a) => (
            <a class="act-card" href={wa(`أبغى تجربة: ${a.name}`)} target="_blank" rel="noopener">
              <div class="act-media">
                <img src={a.img} alt={a.name} loading="lazy" onerror="this.remove()" />
                <span class="act-emoji">{a.emoji}</span>
              </div>
              <h3>{a.name}</h3>
              <p>{a.desc}</p>
              <span class="act-price">{a.price}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- AI Trip Designer -->
    <section class="section section-dark" id="designer">
      <div class="container">
        <h2 class="section-title">🤖 مصمم الرحلات الذكي</h2>
        <p class="section-sub">
          كلمه بالعامية، حدد ميزانيتك، وبيصمم لك برنامجًا يوم-بيوم من برامجنا الحقيقية بأسعارها —
          ثم أكمل الحجز بالواتساب
        </p>
        <div class="chat-shell">
          <div class="chat-log" id="chatLog">
            <div class="msg bot">هلا وسهلا! 👋 أنا مصمم رحلات محفول مكفول الذكي.<br />قل لي: وين ودك تروح؟ كم عددكم؟ ومتى؟ — وأفصّل لك رحلة على مقاسك بأسعارنا الحقيقية.</div>
          </div>
          <div class="chat-suggests" id="chatSuggests">
            <button type="button" data-q="ابغى رحلة حافة العالم لستة أشخاص مع تخييم">🏔️ حافة العالم مع تخييم</button>
            <button type="button" data-q="صمم لي رحلة العلا 3 أيام لأربعة أشخاص بميزانية متوسطة">🏛️ العلا 3 أيام</button>
            <button type="button" data-q="ابغى رحلة بحرية في جدة مع يخت وسنوركل ليوم واحد">🛥️ رحلة بحرية بجدة</button>
            <button type="button" data-q="اقترح لي رحلة عائلية مبتكرة بميزانية 5000 ريال">👨‍👩‍👧‍👦 رحلة عائلية بـ5000</button>
          </div>
          <form class="chat-input" id="chatForm">
            <input type="text" id="chatText" placeholder="اكتب طلبك… مثال: ابغى رحلة نهاية الأسبوع لعائلتي" autocomplete="off" />
            <button type="submit" class="btn btn-gold" id="chatSend">إرسال</button>
          </form>
          <p class="chat-note">الأسعار من باقاتنا المعتمدة · تأكيد الحجز النهائي عبر الواتساب مع فريق المبيعات</p>
        </div>
      </div>
    </section>

    <!-- Expansion -->
    <section class="section" id="expansion">
      <div class="container">
        <h2 class="section-title">🌍 قريبًا: العالم من بوابة محفول مكفول</h2>
        <p class="section-sub">نبدأ من السعودية ونتوسع سوقًا بعد سوق مع موردين محليين معتمدين</p>
        <div class="regions-row">
          {regions.map((r) => (
            <div class={`region-pill ${r.status}`}>
              <span class="region-flag">{r.flag}</span>
              <b>{r.name}</b>
              <small>{r.desc}</small>
              <span class={`region-badge ${r.status}`}>{r.status === 'live' ? 'متاح الآن' : 'قريبًا'}</span>
            </div>
          ))}
        </div>
        <div class="center">
          <a class="btn btn-outline" href={wa('سجلوني باهتمامات الوجهات الدولية القادمة 🌍')} target="_blank" rel="noopener">🔔 سجّل اهتمامك بالوجهات القادمة</a>
        </div>
      </div>
    </section>

    <!-- Vendors -->
    <section class="section section-alt" id="vendors">
      <div class="container narrow center">
        <h2 class="section-title">🤝 كن موردًا في المنصة</h2>
        <p class="section-sub">
          مرشد سياحي، صاحب يخت، منظم رحلات، أسرة منتجة، أو مقدم أنشطة؟
          اعرض خدمتك عندنا — نتولى التسويق والحجوزات وأنت تنفذ
        </p>
        <div class="chips chips-sm">
          <span class="chip chip-outline">شركات سياحة</span>
          <span class="chip chip-outline">فنادق وبيوت سياحية</span>
          <span class="chip chip-outline">مرشدون</span>
          <span class="chip chip-outline">قروبات جيب</span>
          <span class="chip chip-outline">مراسي يخوت</span>
          <span class="chip chip-outline">باصات</span>
          <span class="chip chip-outline">أسر منتجة</span>
          <span class="chip chip-outline">مقدمو أنشطة</span>
        </div>
        <div class="center">
          <a class="btn btn-wa btn-lg" href={wa('أبغى أنضم كمورد في منصتكم.\nنوع الخدمة: \nالمدينة: ')} target="_blank" rel="noopener">💬 قدّم طلب انضمام</a>
        </div>
      </div>
    </section>

    <!-- Terms -->
    <section class="section" id="terms">
      <div class="container narrow">
        <h2 class="section-title">الشروط والأحكام</h2>
        <details class="acc">
          <summary>الشروط الأساسية</summary>
          <ul>
            <li>الحد الأدنى للمجموعة: 4 أشخاص، والحد الأقصى: 20 شخصًا.</li>
            <li>عدد الأشخاص في السيارة الواحدة: 4 أشخاص.</li>
            <li>البرنامج قابل للتغيير حسب رغبة العميل.</li>
            <li>الشركة غير مسؤولة عن تغيير مسار الرحلة لظروف خارجة عن الإرادة أو ظروف قاهرة.</li>
          </ul>
        </details>
        <details class="acc">
          <summary>سياسة الإلغاء والاسترجاع</summary>
          <ul>
            <li>الإلغاء قبل 14 يومًا أو أكثر: يُحفظ المبلغ كاملًا كرصيد لمدة سنة، أو يُسترجع بعد خصم 10% رسومًا إدارية خلال 20 يوم عمل.</li>
            <li>الإلغاء بين 7 و14 يومًا: تحتفظ الشركة بـ 50% من قيمة الرحلة ويُعاد الباقي خلال 20 يوم عمل.</li>
            <li>الإلغاء بين 72 ساعة و7 أيام: تحتفظ الشركة بـ 50% ويُحفظ الباقي كرصيد لمدة سنة.</li>
            <li>الإلغاء قبل أقل من 72 ساعة: تحتفظ الشركة بالمبلغ كاملًا دون تعويض أو استبدال.</li>
            <li>استبدال عميل بآخر دون إلغاء الرحلة: رسوم إدارية 10% من قيمة الرحلة.</li>
            <li>إذا ألغت الجهة المنظمة الرحلة: يُسترجع المبلغ كاملًا (100%) خلال 20 يوم عمل.</li>
          </ul>
        </details>
      </div>
    </section>

    <!-- Contact -->
    <section class="section section-alt" id="contact">
      <div class="container narrow center">
        <h2 class="section-title">خلنا نرتب لك الرحلة</h2>
        <p class="section-sub">فريقنا جاهز على الواتساب — رد سريع وتفصيل على مقاسك</p>
        <div class="hero-cta">
          <a class="btn btn-wa btn-lg" href={wa('أبغى أستفسر عن رحلة')} target="_blank" rel="noopener">💬 +966 50 138 6327</a>
          <a class="btn btn-outline btn-lg" href={`mailto:${contact.email}`}>{contact.email}</a>
        </div>
        <div class="socials">
          <a href={contact.instagram} target="_blank" rel="noopener">إنستقرام</a>
          <a href={contact.twitter} target="_blank" rel="noopener">تويتر (X)</a>
          <a href={contact.tiktok} target="_blank" rel="noopener">تيك توك</a>
          <a href={contact.snapchat} target="_blank" rel="noopener">سناب شات</a>
        </div>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>🐪 شركة محفول مكفول للسياحة — Mahfol Makfol Tourism</p>
      <p class="footer-legal">سجل تجاري: {contact.cr} · الرقم الضريبي: {contact.vat}</p>
      <p class="footer-legal">جميع الحقوق محفوظة © 2026</p>
    </div>
  </footer>

  <!-- WhatsApp FAB -->
  <a class="wa-fab" href={wa('أبغى أستفسر عن رحلة')} target="_blank" rel="noopener" aria-label="تواصل واتساب">
    <svg viewBox="0 0 24 24" width="30" height="30" fill="#fff"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm5.83 14.12c-.25.7-1.44 1.34-1.98 1.39-.54.05-1.04.24-3.5-.73-2.96-1.17-4.83-4.2-4.98-4.39-.14-.19-1.18-1.57-1.18-3s.75-2.13 1.02-2.42c.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.25.58.84 2 .91 2.15.07.14.12.31.02.5-.09.19-.14.31-.28.48-.14.17-.3.37-.42.5-.14.14-.29.29-.13.57.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.41.29.14.45.12.62-.07.17-.19.71-.83.9-1.11.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.18 1.39z"/></svg>
  </a>

<style is:global>
  :root {
    --bg: #171933;
    --bg-alt: #1e2142;
    --card: #252952;
    --card-border: #3b3f8f;
    --text: #f6f1e7;
    --muted: #b4b8e0;
    --gold: #ee6a4d;
    --gold-strong: #ff8f70;
    --wa: #25d366;
    --radius: 18px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Tajawal', 'Segoe UI', Tahoma, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
  }
  .container { max-width: 1120px; margin: 0 auto; padding: 0 20px; }
  .container.narrow { max-width: 820px; }
  .center { text-align: center; margin-top: 26px; }

  /* Nav */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(23, 25, 51, 0.94);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--card-border);
  }
  .nav-inner { display: flex; align-items: center; gap: 20px; padding: 14px 20px; }
  .brand { font-size: 1.3rem; font-weight: 900; color: var(--text); text-decoration: none; white-space: nowrap; }
  .brand b { color: var(--gold); }
  .nav-links { display: flex; gap: 20px; margin-inline-start: auto; flex-wrap: wrap; }
  .nav-links a { color: var(--muted); text-decoration: none; font-weight: 700; font-size: 0.95rem; }
  .nav-links a:hover { color: var(--gold-strong); }

  /* Buttons */
  .btn {
    display: inline-block; padding: 11px 24px; border-radius: 999px;
