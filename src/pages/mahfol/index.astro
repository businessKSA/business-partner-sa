  { icon: '✅', text: 'موردون معتمدون ومدقّقون' },
  { icon: '💬', text: 'حجز فوري عبر الواتساب' },
  { icon: '🤖', text: 'مصمم رحلات بالذكاء الاصطناعي' },
  { icon: '🕐', text: 'دعم على مدار الساعة' },
  { icon: '🏛️', text: 'شركة سعودية مسجلة · س.ت 4030416435' },
];

const regions = [
  { flag: '🇸🇦', name: 'السعودية', status: 'live', desc: 'كل المناطق — متاح الآن' },
  { flag: '🇦🇪', name: 'الخليج', status: 'soon', desc: 'دبي · البحرين · قطر · عُمان' },
  { flag: '🇪🇬', name: 'مصر', status: 'soon', desc: 'القاهرة · الساحل · شرم الشيخ' },
  { flag: '🇹🇷', name: 'تركيا', status: 'soon', desc: 'إسطنبول · طرابزون · كابادوكيا' },
  { flag: '🌏', name: 'شرق آسيا', status: 'soon', desc: 'تايلاند · ماليزيا · إندونيسيا' },
];
