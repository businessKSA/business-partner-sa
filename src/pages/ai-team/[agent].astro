---
// صفحة إيجنت مخفية — لا تُربط من أي قائمة، noindex، ومستبعدة من الـ sitemap.
import { agents, statusStyle } from '../../content/agents';
import '../../styles/global.css';

export const prerender = true;

export function getStaticPaths() {
  return agents.map((a) => ({ params: { agent: a.slug }, props: { agent: a } }));
}

const { agent: a } = Astro.props;
const badge = statusStyle[a.status];
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow, noarchive" />
  <title>{a.name} — {a.role} | فريق الإيجنتس</title>
</head>
<body style="padding-top: 0;">
  <main class="ag-wrap">
    <nav class="ag-back"><a href="/ai-team/">← كل الإيجنتس</a></nav>

    <header class="ag-head">
      <div class="ag-emoji">{a.emoji}</div>
      <div>
        <h1>{a.name} <span class="ag-en">{a.nameEn}</span></h1>
        <p class="ag-role">{a.role}</p>
        <span class="ag-status" style={`background:${badge.bg};color:${badge.color}`}>{a.statusLabel}</span>
      </div>
    </header>

    <p class="ag-summary">{a.summary}</p>

    <div class="ag-cols">
      <section class="ag-box ag-can">
        <h2>✅ وش يسوي</h2>
        <ul>{a.can.map((x) => <li>{x}</li>)}</ul>
      </section>
      <section class="ag-box ag-cannot">
        <h2>🚫 وش ما يسويه أبداً</h2>
        <ul>{a.cannot.map((x) => <li>{x}</li>)}</ul>
      </section>
    </div>

    <section class="ag-box ag-test">
      <h2>🧪 كيف تتأكد أنه يشتغل</h2>
      <ol>{a.testSteps.map((x) => <li>{x}</li>)}</ol>
      {a.testMessages.length > 0 && (
        <div class="ag-msgs">
          <h3>رسائل اختبار والنتيجة المتوقعة</h3>
          <table>
            <thead><tr><th>جرّب ترسل</th><th>المفروض يصير</th></tr></thead>
            <tbody>
              {a.testMessages.map((m) => (
                <tr><td>{m.input}</td><td>{m.expected}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <div class="ag-cols">
      <section class="ag-box">
        <h2>🔀 التحويلات (Routing)</h2>
        <ul>{a.routing.map((x) => <li>{x}</li>)}</ul>
      </section>
      <section class="ag-box">
        <h2>📁 الملفات المصدرية</h2>
        <ul class="ag-files">
          {a.files.map((f) => (
            <li>{f.label}: <code>{f.path}</code></li>
          ))}
        </ul>
        <p class="ag-note">في فرع <code>claude/bp-specialized-team-agents-lt392y</code></p>
      </section>
    </div>

    <footer class="ag-foot">
      <p>🔒 النموذج التشغيلي Concierge: الإيجنت يجهز ويوصي فقط — أي مخرج خارجي يُنشأ بحالة «بانتظار الموافقة» ولا يُرسل آلياً. لا يتعامل أي إيجنت مع OTP أو كلمات مرور نهائياً.</p>
    </footer>
  </main>

  <style>
    .ag-wrap { max-width: 900px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
    .ag-back a { color: var(--brand); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
    .ag-head { display: flex; gap: 1.25rem; align-items: center; margin: 1.5rem 0 1rem; }
    .ag-emoji { font-size: 3rem; background: var(--surface); border: 1px solid var(--line); border-radius: 20px; width: 84px; height: 84px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ag-head h1 { font-size: 2rem; margin-bottom: 0.1rem; }
    .ag-en { color: var(--muted); font-size: 1rem; font-weight: 400; }
    .ag-role { color: var(--brand); font-weight: 600; margin-bottom: 0.4rem; }
    .ag-status { font-size: 0.8rem; padding: 0.25rem 0.8rem; border-radius: 999px; font-weight: 600; display: inline-block; }
    .ag-summary { color: var(--muted); font-size: 1.05rem; margin-bottom: 1.75rem; }
    .ag-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
    @media (max-width: 700px) { .ag-cols { grid-template-columns: 1fr; } }
    .ag-box { background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 1.4rem; }
    .ag-box h2 { font-size: 1.15rem; margin-bottom: 0.9rem; }
    .ag-box ul, .ag-box ol { padding-inline-start: 1.25rem; display: grid; gap: 0.45rem; font-size: 0.93rem; }
    .ag-can { border-inline-start: 4px solid var(--accent); }
    .ag-cannot { border-inline-start: 4px solid #ef4444; }
    .ag-test { border-inline-start: 4px solid var(--brand); margin-bottom: 1.25rem; }
    .ag-msgs { margin-top: 1.25rem; }
    .ag-msgs h3 { font-size: 1rem; margin-bottom: 0.6rem; }
    .ag-msgs table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    .ag-msgs th, .ag-msgs td { border: 1px solid var(--line); padding: 0.55rem 0.7rem; text-align: start; background: #fff; }
    .ag-msgs th { background: var(--surface); }
    .ag-files code, .ag-note code { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: 0.1rem 0.35rem; font-size: 0.8rem; direction: ltr; unicode-bidi: embed; }
    .ag-note { color: var(--muted); font-size: 0.8rem; margin-top: 0.75rem; }
    .ag-foot { margin-top: 2rem; background: #fffbeb; border: 1px solid #fde68a; color: #92400e; border-radius: 12px; padding: 1rem 1.25rem; font-size: 0.88rem; }
  </style>
</body>
</html>
