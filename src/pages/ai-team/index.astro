---
// صفحة مخفية — لا تُربط من أي قائمة، noindex، ومستبعدة من الـ sitemap.
import { agents, statusStyle } from '../../content/agents';
import '../../styles/global.css';

export const prerender = true;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow, noarchive" />
  <title>فريق الإيجنتس — لوحة داخلية | Business Partner</title>
</head>
<body style="padding-top: 0;">
  <main class="ai-wrap">
    <header class="ai-head">
      <p class="ai-badge">🔒 صفحة داخلية — غير معروضة في الموقع ولا محركات البحث</p>
      <h1>🤖 فريق الإيجنتس المتخصص</h1>
      <p class="ai-sub">
        المكتب = نوشن · المخ = n8n · المحرّك = Claude · النموذج التشغيلي: <strong>Concierge</strong> —
        الإيجنت يجهز ويوصي، والتنفيذ النهائي دائماً بعد موافقة بشرية «بانتظار الموافقة».
      </p>
    </header>

    <div class="ai-grid">
      {agents.map((a) => (
        <a class="ai-card" href={`/ai-team/${a.slug}/`}>
          <div class="ai-card-top">
            <span class="ai-emoji">{a.emoji}</span>
            <span class="ai-status" style={`background:${statusStyle[a.status].bg};color:${statusStyle[a.status].color}`}>{a.statusLabel}</span>
          </div>
          <h2>{a.name} <span class="ai-en">{a.nameEn}</span></h2>
          <p class="ai-role">{a.role}</p>
          <p class="ai-summary">{a.summary}</p>
          <span class="ai-more">التفاصيل وطريقة الاختبار ←</span>
        </a>
      ))}
    </div>

    <footer class="ai-foot">
      <p>المصدر: مجلد <code>bp-specialized-team/</code> في فرع <code>claude/bp-specialized-team-agents-lt392y</code> · البريف: <code>BP-Specialized-Team-Build-Brief.md</code></p>
    </footer>
  </main>

  <style>
    .ai-wrap { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    .ai-head { text-align: center; margin-bottom: 2.5rem; }
    .ai-badge { display: inline-block; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; border-radius: 999px; padding: 0.35rem 1rem; font-size: 0.85rem; margin-bottom: 1rem; }
    .ai-head h1 { color: var(--text); margin-bottom: 0.75rem; }
    .ai-sub { color: var(--muted); max-width: 720px; margin: 0 auto; }
    .ai-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
    .ai-card { display: block; background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 1.5rem; text-decoration: none; color: var(--text); box-shadow: var(--shadow); transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .ai-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
    .ai-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
    .ai-emoji { font-size: 1.8rem; }
    .ai-status { font-size: 0.75rem; padding: 0.25rem 0.7rem; border-radius: 999px; font-weight: 600; }
    .ai-card h2 { font-size: 1.35rem; margin-bottom: 0.15rem; }
    .ai-en { color: var(--muted); font-size: 0.9rem; font-weight: 400; }
    .ai-role { color: var(--brand); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.6rem; }
    .ai-summary { color: var(--muted); font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .ai-more { display: inline-block; margin-top: 0.9rem; color: var(--brand); font-size: 0.9rem; font-weight: 600; }
    .ai-foot { margin-top: 3rem; text-align: center; color: var(--muted); font-size: 0.8rem; }
    .ai-foot code { background: var(--surface); border: 1px solid var(--line); border-radius: 6px; padding: 0.1rem 0.4rem; direction: ltr; unicode-bidi: embed; }
  </style>
</body>
</html>
