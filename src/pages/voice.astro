---
// صفحة المحادثة الصوتية — الفريق التنفيذي الذكي (خالد)
// مستقلة ولا تستخدم BaseLayout حتى لا تؤثر على بقية الموقع.
const WEBHOOK_URL =
  'https://businesspartnerai.app.n8n.cloud/webhook/f08bf4a4-62e9-4aa6-9a44-bf3080682fb3/chat';
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>المكتب الافتراضي — محادثة صوتية</title>
    <style>
      :root {
        --bg: #0b1220;
        --panel: #111c2e;
        --panel-2: #16233a;
        --brand: #0e9f9a;
        --brand-2: #12b3ad;
        --user: #1f6feb;
        --text: #e8eef7;
        --muted: #93a4bd;
        --ring: rgba(18, 179, 173, 0.35);
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        background: radial-gradient(1200px 600px at 50% -10%, #16324a 0%, var(--bg) 55%);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Tahoma, "Helvetica Neue", Arial, sans-serif;
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
      }
      header {
        text-align: center;
        padding: 22px 16px 10px;
      }
      header .brand { color: var(--brand-2); font-weight: 800; letter-spacing: .5px; font-size: 13px; }
      header h1 { margin: 6px 0 2px; font-size: 22px; }
      header p { margin: 0; color: var(--muted); font-size: 13px; }

      main {
        flex: 1;
        width: 100%;
        max-width: 720px;
        margin: 0 auto;
        padding: 10px 14px 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }
      #log {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 10px 4px 16px;
      }
      .bubble {
        max-width: 85%;
        padding: 12px 14px;
        border-radius: 16px;
        line-height: 1.7;
        font-size: 15px;
        white-space: pre-wrap;
        word-wrap: break-word;
        animation: pop .18s ease;
      }
      @keyframes pop { from { transform: translateY(6px); opacity: 0; } to { transform: none; opacity: 1; } }
      .me { align-self: flex-start; background: var(--user); border-bottom-right-radius: 6px; }
      .bot { align-self: flex-end; background: var(--panel-2); border: 1px solid #24344f; border-bottom-left-radius: 6px; }
      .sys { align-self: center; background: transparent; color: var(--muted); font-size: 13px; max-width: 92%; text-align: center; }

      .dots span { display:inline-block; width:7px;height:7px;margin:0 2px;border-radius:50%;background:var(--muted);animation:blink 1.2s infinite both; }
      .dots span:nth-child(2){animation-delay:.2s}.dots span:nth-child(3){animation-delay:.4s}
      @keyframes blink { 0%,80%,100%{opacity:.25} 40%{opacity:1} }

      footer {
        position: sticky;
        bottom: 0;
        background: linear-gradient(180deg, rgba(11,18,32,0) 0%, var(--bg) 30%);
        padding: 8px 14px 18px;
      }
      .controls { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 10px; }
      #status { color: var(--muted); font-size: 13px; min-height: 18px; text-align: center; }
      #status.live { color: var(--brand-2); }

      .mic {
        width: 84px; height: 84px; border-radius: 50%;
        border: none; cursor: pointer;
        background: linear-gradient(180deg, var(--brand-2), var(--brand));
        color: #fff; font-size: 32px;
        display: grid; place-items: center;
        box-shadow: 0 10px 30px rgba(14,159,154,.35);
        transition: transform .12s ease, box-shadow .2s ease;
        -webkit-tap-highlight-color: transparent;
      }
      .mic:active { transform: scale(.96); }
      .mic.listening { animation: pulse 1.4s infinite; background: linear-gradient(180deg,#ef5b5b,#d33); box-shadow: 0 0 0 0 var(--ring); }
      @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(211,51,51,.45)} 70%{box-shadow:0 0 0 22px rgba(211,51,51,0)} 100%{box-shadow:0 0 0 0 rgba(211,51,51,0)} }
      .mic:disabled { opacity: .5; cursor: not-allowed; }

      .row { width: 100%; max-width: 560px; display: flex; gap: 8px; }
      .row input {
        flex: 1; background: var(--panel); border: 1px solid #24344f; color: var(--text);
        border-radius: 12px; padding: 12px 14px; font-size: 15px; font-family: inherit; text-align: right;
      }
      .row input:focus { outline: none; border-color: var(--brand); }
      .row button {
        background: var(--panel-2); border: 1px solid #24344f; color: var(--text);
        border-radius: 12px; padding: 0 16px; cursor: pointer; font-family: inherit; font-size: 15px;
      }
      .toolbar { display: flex; gap: 14px; align-items: center; }
      .toolbar button {
        background: none; border: none; color: var(--muted); cursor: pointer; font-size: 13px; font-family: inherit; padding: 4px;
      }
      .toolbar button:hover { color: var(--text); }
      .toolbar .on { color: var(--brand-2); }
      a.back { position: fixed; top: 14px; inset-inline-start: 16px; color: var(--muted); text-decoration: none; font-size: 13px; }
      a.back:hover { color: var(--text); }
    </style>
  </head>
  <body>
    <a class="back" href="/">‹ الموقع</a>
    <header>
      <div class="brand">BUSINESS PARTNER · الفريق التنفيذي الذكي</div>
      <h1>🎙️ المكتب الافتراضي — بالصوت</h1>
      <p>اضغط الميكروفون وتكلّم بالعربي مع خالد وفريقه. يفهمون، ينفّذون، ويردّون صوتياً.</p>
    </header>

    <main>
      <div id="log">
        <div class="bubble sys">مرحباً 👋 أنا خالد، قائد فريقك التنفيذي. اضغط الميكروفون واطلب أي شيء — حكومي، تسويق، مبيعات، تقنية، مشتريات، أو دعم إداري.</div>
      </div>
    </main>

    <footer>
      <div class="controls">
        <div id="status">اضغط للتحدث</div>
        <button id="mic" class="mic" aria-label="تحدث">🎤</button>
        <div class="row">
          <input id="text" type="text" placeholder="أو اكتب طلبك هنا…" autocomplete="off" />
          <button id="send">إرسال</button>
        </div>
        <div class="toolbar">
          <button id="ttsToggle" class="on">🔊 الرد الصوتي: مفعّل</button>
          <button id="stopBtn">■ إيقاف الصوت</button>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const WEBHOOK_URL =
          'https://businesspartnerai.app.n8n.cloud/webhook/f08bf4a4-62e9-4aa6-9a44-bf3080682fb3/chat';
        const log = document.getElementById('log');
        const micBtn = document.getElementById('mic');
        const statusEl = document.getElementById('status');
        const textInput = document.getElementById('text');
        const sendBtn = document.getElementById('send');
        const ttsToggle = document.getElementById('ttsToggle');
        const stopBtn = document.getElementById('stopBtn');

        let ttsOn = true;
        let busy = false;

        // Session id ثابت للمحادثة (ذاكرة الفريق)
        let sid = sessionStorage.getItem('bp_voice_sid');
        if (!sid) {
          sid = 'voice-' + (crypto.randomUUID ? crypto.randomUUID() : Date.now() + '-' + Math.random().toString(16).slice(2));
          sessionStorage.setItem('bp_voice_sid', sid);
        }

        function addBubble(text, cls) {
          const el = document.createElement('div');
          el.className = 'bubble ' + cls;
          el.textContent = text;
          log.appendChild(el);
          log.scrollTop = log.scrollHeight;
          return el;
        }
        function setStatus(t, live) {
          statusEl.textContent = t;
          statusEl.classList.toggle('live', !!live);
        }

        // ——— تنظيف النص قبل النطق ———
        function cleanForSpeech(t) {
          return String(t)
            .replace(/[#*_`>]/g, '')
            .replace(/\[(.*?)\]\((.*?)\)/g, '$1')
            .replace(/https?:\/\/\S+/g, '')
            .replace(/\n{2,}/g, '. ')
            .replace(/\n/g, '. ')
            .trim();
        }

        // ——— النطق (TTS) ———
        let arVoice = null;
        function pickVoice() {
          const voices = window.speechSynthesis ? speechSynthesis.getVoices() : [];
          arVoice = voices.find(v => /ar(-|_)/i.test(v.lang)) || voices.find(v => /arab/i.test(v.name)) || null;
        }
        if (window.speechSynthesis) {
          pickVoice();
          speechSynthesis.onvoiceschanged = pickVoice;
        }
        function speak(text) {
          if (!ttsOn || !window.speechSynthesis) return;
          try {
            speechSynthesis.cancel();
            const u = new SpeechSynthesisUtterance(cleanForSpeech(text));
            u.lang = 'ar-SA';
            if (arVoice) u.voice = arVoice;
            u.rate = 1; u.pitch = 1;
            speechSynthesis.speak(u);
          } catch (e) {}
        }

        // ——— إرسال الرسالة لخالد ———
        async function sendMessage(message) {
          const msg = (message || '').trim();
          if (!msg || busy) return;
          busy = true;
          micBtn.disabled = true;
          addBubble(msg, 'me');
          const thinking = addBubble('', 'bot');
          thinking.innerHTML = '<span class="dots"><span></span><span></span><span></span></span>';
          setStatus('الفريق يعمل على طلبك…', true);

          try {
            const res = await fetch(WEBHOOK_URL, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ action: 'sendMessage', sessionId: sid, chatInput: msg })
            });
            let reply = '';
            const raw = await res.text();
            try {
              const data = JSON.parse(raw);
              reply = data.output ?? data.text ?? data.reply ?? data.message ?? data.answer ?? '';
              if (!reply && typeof data === 'object') reply = '';
            } catch (_) {
              reply = raw;
            }
            reply = (typeof reply === 'string' ? reply : JSON.stringify(reply)).trim();
            if (!reply) reply = 'تم استلام طلبك. لحظة وأرجع لك.';
            thinking.textContent = reply;
            log.scrollTop = log.scrollHeight;
            speak(reply);
            setStatus('اضغط للتحدث');
          } catch (err) {
            thinking.textContent = 'تعذّر الاتصال بالفريق حالياً. تأكد من الاتصال بالإنترنت وحاول مرة ثانية.';
            setStatus('خطأ في الاتصال');
          } finally {
            busy = false;
            micBtn.disabled = false;
          }
        }

        // ——— التعرّف على الصوت (STT) ———
        const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        let recognition = null;
        let listening = false;

        if (SR) {
          recognition = new SR();
          recognition.lang = 'ar-SA';
          recognition.interimResults = true;
          recognition.continuous = false;
          recognition.maxAlternatives = 1;

          let finalText = '';
          recognition.onstart = function () {
            listening = true;
            finalText = '';
            micBtn.classList.add('listening');
            micBtn.textContent = '■';
            setStatus('أستمع إليك… تكلّم الآن', true);
          };
          recognition.onresult = function (e) {
            let interim = '';
            for (let i = e.resultIndex; i < e.results.length; i++) {
              const tr = e.results[i][0].transcript;
              if (e.results[i].isFinal) finalText += tr;
              else interim += tr;
            }
            setStatus((finalText || interim || '…'), true);
          };
          recognition.onerror = function (e) {
            listening = false;
            micBtn.classList.remove('listening');
            micBtn.textContent = '🎤';
            if (e.error === 'not-allowed' || e.error === 'service-not-allowed') {
              setStatus('تحتاج تسمح بالوصول للميكروفون من المتصفح');
            } else if (e.error === 'no-speech') {
              setStatus('ما سمعت صوت — حاول مرة ثانية');
            } else {
              setStatus('اضغط للتحدث');
            }
          };
          recognition.onend = function () {
            listening = false;
            micBtn.classList.remove('listening');
            micBtn.textContent = '🎤';
            const said = finalText.trim();
            if (said) sendMessage(said);
            else if (!busy) setStatus('اضغط للتحدث');
          };

          micBtn.addEventListener('click', function () {
            if (busy) return;
            if (window.speechSynthesis) speechSynthesis.cancel();
            if (listening) { recognition.stop(); return; }
            try { recognition.start(); } catch (e) {}
          });
        } else {
          // متصفح لا يدعم التعرّف الصوتي — نخفي الميكروفون ونكتفي بالكتابة + الرد الصوتي
          micBtn.disabled = true;
          micBtn.title = 'المتصفح لا يدعم إدخال الصوت — استخدم كروم أو سفاري';
          setStatus('متصفحك لا يدعم إدخال الصوت — اكتب طلبك (الرد يبقى صوتياً). للأفضل استخدم كروم.');
        }

        // ——— أزرار ———
        sendBtn.addEventListener('click', function () {
          const v = textInput.value; textInput.value = ''; sendMessage(v);
        });
        textInput.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') { const v = textInput.value; textInput.value = ''; sendMessage(v); }
        });
        ttsToggle.addEventListener('click', function () {
          ttsOn = !ttsOn;
          ttsToggle.textContent = ttsOn ? '🔊 الرد الصوتي: مفعّل' : '🔇 الرد الصوتي: مغلق';
          ttsToggle.classList.toggle('on', ttsOn);
          if (!ttsOn && window.speechSynthesis) speechSynthesis.cancel();
        });
        stopBtn.addEventListener('click', function () {
          if (window.speechSynthesis) speechSynthesis.cancel();
        });
      })();
    </script>
  </body>
</html>
