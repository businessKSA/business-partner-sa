      const HALL_TITLES = {
        cars: 'مقتنيات قاعة السيارات الخارقة',
        marina: 'مقتنيات المارينا الملكية',
      };
      const SVG_BY_TYPE = { car: CAR_SVG, yacht: YACHT_SVG, jetski: JETSKI_SVG };

      // ======== عناصر الصفحة ========
      const $ = (id) => document.getElementById(id);
      const scene = $('scene'), stage = $('stage'), pedestal = $('pedestal');
      const vehicleEl = $('vehicle'), reflectionEl = $('reflection'), hotspotsEl = $('hotspots');
      const thumbsEl = $('thumbs');
      const fmt = new Intl.NumberFormat('en-US');

      let current = null;
      let spinning = true;

      function renderThumbs(hall) {
        thumbsEl.innerHTML = '';
        ITEMS.filter((i) => i.hall === hall).forEach((item) => {
          const t = document.createElement('button');
          t.className = 'thumb' + (current && current.id === item.id ? ' on' : '');
          t.style.setProperty('--paint', item.paints[0]);
          t.innerHTML = SVG_BY_TYPE[item.type](item.accent) +
            `<b>${item.name}</b><small>${item.en}</small>`;
          t.addEventListener('click', () => select(item.id));
          thumbsEl.appendChild(t);
        });
        $('hallTitle').textContent = HALL_TITLES[hall];
      }

      function animateNumber(el, target, dec) {
        const dur = 700, start = performance.now();
        function tick(now) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (target * eased).toFixed(dec || 0);
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      function select(id) {
        const item = ITEMS.find((i) => i.id === id);
        if (!item || (current && current.id === id)) return;
        current = item;

        // المشهد: قاعة سيارات أم مارينا
        scene.classList.toggle('marina', item.hall === 'marina');

        // المركبة + الانعكاس
        const svg = SVG_BY_TYPE[item.type](item.accent);
        vehicleEl.innerHTML = svg;
        reflectionEl.innerHTML = svg;
        pedestal.style.setProperty('--paint', item.paints[0]);
        vehicleEl.classList.remove('enter');
        void vehicleEl.offsetWidth; // إعادة تشغيل حركة الدخول
        vehicleEl.classList.add('enter');

        // نقاط الاستكشاف
        hotspotsEl.innerHTML = '';
        item.spots.forEach((s) => {
          const h = document.createElement('button');
          h.className = 'hotspot';
          h.style.right = s.x + '%';
          h.style.top = s.y + '%';
          h.setAttribute('aria-label', s.t);
          h.innerHTML = `<span class="tip">${s.t}</span>`;
          hotspotsEl.appendChild(h);
        });

        // اللوحة
        $('pCat').textContent = '◆ ' + item.cat;
        $('pName').textContent = item.name;
        $('pEn').textContent = item.en;
        $('pDesc').textContent = item.desc;

        const statsEl = $('pStats');
        statsEl.innerHTML = '';
        item.stats.forEach((s) => {
          const d = document.createElement('div');
          d.className = 'stat';
          d.innerHTML = `<b>0</b><span style="color:var(--muted);font-size:0.72rem"> ${s.u}</span><small style="display:block">${s.l}</small>`;
          statsEl.appendChild(d);
          animateNumber(d.querySelector('b'), s.v, s.dec);
        });

        // الألوان
        const paintsEl = $('pPaints');
        paintsEl.innerHTML = '<span>الطلاء:</span>';
        item.paints.forEach((c, idx) => {
          const s = document.createElement('button');
          s.className = 'swatch' + (idx === 0 ? ' on' : '');
          s.style.background = c;
          s.setAttribute('aria-label', 'لون ' + (idx + 1));
          s.addEventListener('click', () => {
            pedestal.style.setProperty('--paint', c);
            paintsEl.querySelectorAll('.swatch').forEach((x) => x.classList.remove('on'));
            s.classList.add('on');
          });
          paintsEl.appendChild(s);
        });

        $('pPrice').textContent = fmt.format(item.price);
        $('pBook').href = WHATSAPP + '?text=' + encodeURIComponent('أرغب بحجز معاينة خاصة: ' + item.name);

        renderThumbs(item.hall);
        document.querySelectorAll('.hall-tab').forEach((b) =>
          b.classList.toggle('active', b.dataset.hall === item.hall)
        );
      }

      // تبويبات القاعات
      document.querySelectorAll('.hall-tab').forEach((btn) => {
        btn.addEventListener('click', () => {
          const first = ITEMS.find((i) => i.hall === btn.dataset.hall);
          if (first) select(first.id);
        });
      });

      // زاوية العرض اليدوية
      $('angle').addEventListener('input', (e) => {
        spinning = false;
        pedestal.classList.remove('spin');
        $('spinBtn').textContent = '▶️ تشغيل الدوران';
        pedestal.style.transform = `rotateY(${e.target.value}deg) rotateX(4deg)`;
      });
      $('spinBtn').addEventListener('click', () => {
        spinning = !spinning;
        pedestal.classList.toggle('spin', spinning);
        if (spinning) pedestal.style.transform = '';
        $('spinBtn').textContent = spinning ? '⏸️ إيقاف الدوران' : '▶️ تشغيل الدوران';
      });

      // إمالة تتبع المؤشر (عند إيقاف الدوران التلقائي)
      stage.addEventListener('mousemove', (e) => {
        if (spinning) return;
        const r = stage.getBoundingClientRect();
        const dx = (e.clientX - r.left) / r.width - 0.5;
        const dy = (e.clientY - r.top) / r.height - 0.5;
        const base = Number($('angle').value);
        pedestal.style.transform = `rotateY(${base + dx * 14}deg) rotateX(${4 - dy * 8}deg)`;
      });

      // البوابة (مع قفل التمرير حتى الدخول)
      document.body.style.overflow = 'hidden';
      $('enterBtn').addEventListener('click', () => {
        $('gate').classList.add('open');
        document.body.style.overflow = '';
      });

      // البداية
      select('bugatti');
    </script>
