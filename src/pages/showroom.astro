---
// «القصر» — معرض افتراضي للسلع الفاخرة (سيارات خارقة، يخوت، دبابات بحرية)
// صفحة مستقلة ولا تستخدم BaseLayout حتى لا تؤثر على بقية الموقع (مثل صفحة /voice).
// الصور فوتوغرافية حقيقية عبر Unsplash (ترخيص مجاني للاستخدام التجاري).
const WHATSAPP = 'https://wa.me/966503793356';
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>القصر | معرض الفخامة الافتراضي</title>
    <meta name="description" content="معرض افتراضي فاخر: بوقاتي، فيراري، لامبورجيني، يخوت ودبابات بحرية — تجربة عرض مبتكرة داخل قصر رقمي." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://unsplash.com" />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;600;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #07080c;
        --bg-2: #0d1017;
        --panel: rgba(18, 21, 30, 0.86);
        --gold: #d4af37;
        --gold-2: #f3d98b;
        --gold-dim: rgba(212, 175, 55, 0.35);
        --text: #f4efe3;
        --muted: #a89f8c;
        --line: rgba(212, 175, 55, 0.22);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Cairo', 'Segoe UI', Tahoma, sans-serif;
        min-height: 100dvh;
        overflow-x: hidden;
      }
      h1, h2, h3, .serif { font-family: 'Amiri', 'Cairo', serif; }
      img { max-width: 100%; }

      /* ======== بوابة القصر (شاشة الدخول) ======== */
      #gate {
        position: fixed; inset: 0; z-index: 100;
        display: flex; align-items: center; justify-content: center;
        transition: opacity 0.9s ease 0.9s, visibility 0s linear 1.8s;
      }
      #gate .door {
        position: absolute; top: 0; bottom: 0; width: 50.5%;
        background:
          radial-gradient(140px 140px at 50% 30%, rgba(212,175,55,0.14), transparent 70%),
          repeating-linear-gradient(90deg, #0e1118 0 46px, #131722 46px 92px),
          #0e1118;
        border-top: 6px solid var(--gold-dim);
        transition: transform 1.4s cubic-bezier(0.7, 0, 0.3, 1);
      }
      #gate .door.right { right: 0; border-inline-start: 2px solid var(--gold-dim); }
      #gate .door.left  { left: 0;  border-inline-end: 2px solid var(--gold-dim); }
      #gate.open .door.right { transform: translateX(102%); }
      #gate.open .door.left  { transform: translateX(-102%); }
      #gate.open { opacity: 0; visibility: hidden; pointer-events: none; }
      #gate .emblem {
        position: relative; z-index: 2; text-align: center; padding: 2rem;
        transition: opacity 0.5s ease;
      }
      #gate.open .emblem { opacity: 0; }
      #gate .emblem .crown { font-size: 3rem; }
      #gate .emblem h1 {
        font-size: clamp(2.2rem, 6vw, 4rem); color: var(--gold-2);
        letter-spacing: 0.05em; margin: 0.4rem 0 0.2rem;
        text-shadow: 0 0 40px rgba(212, 175, 55, 0.45);
      }
      #gate .emblem p { color: var(--muted); font-size: 1.05rem; margin-bottom: 1.8rem; }
      #enterBtn {
        font-family: 'Cairo', sans-serif; font-weight: 800; font-size: 1.1rem;
        color: #14100a; background: linear-gradient(135deg, var(--gold-2), var(--gold));
        border: none; border-radius: 999px; padding: 0.9rem 3.2rem; cursor: pointer;
        box-shadow: 0 0 35px rgba(212, 175, 55, 0.35);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      #enterBtn:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 0 55px rgba(212, 175, 55, 0.55); }

      /* ======== الترويسة ======== */
      header.top {
        position: sticky; top: 0; z-index: 50;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: 0.8rem 1.4rem;
        background: rgba(7, 8, 12, 0.82); backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--line);
      }
      .brand { display: flex; align-items: center; gap: 0.6rem; }
      .brand .mark { font-size: 1.5rem; }
      .brand b { color: var(--gold-2); font-size: 1.25rem; letter-spacing: 0.03em; }
      .brand span { color: var(--muted); font-size: 0.78rem; display: block; line-height: 1; }
      nav.halls { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .hall-tab {
        font-family: inherit; font-size: 0.95rem; font-weight: 600; cursor: pointer;
        color: var(--muted); background: transparent;
        border: 1px solid transparent; border-radius: 999px; padding: 0.45rem 1.1rem;
        transition: all 0.25s ease;
      }
      .hall-tab:hover { color: var(--gold-2); }
      .hall-tab.active {
        color: var(--gold-2); border-color: var(--gold-dim);
        background: rgba(212, 175, 55, 0.08);
      }

      /* ======== المسرح (منصة العرض) ======== */
      .atrium {
        position: relative; max-width: 1280px; margin: 0 auto; padding: 1.6rem 1.2rem 0;
      }
      .scene {
        position: relative; overflow: hidden;
        border: 1px solid var(--line); border-radius: 22px;
        background:
          radial-gradient(900px 420px at 50% -8%, rgba(212, 175, 55, 0.13), transparent 60%),
          linear-gradient(180deg, #0c0f16 0%, #07080c 78%, #0a0c11 100%);
        display: grid; grid-template-columns: 1.5fr 1fr; gap: 0;
        transition: background 0.8s ease;
      }
      .scene.marina {
        background:
          radial-gradient(900px 420px at 50% -8%, rgba(90, 170, 210, 0.16), transparent 60%),
          linear-gradient(180deg, #0a1420 0%, #071019 62%, #0b2233 100%);
      }
      /* أعمدة القصر الزخرفية */
      .scene::before, .scene::after {
        content: ''; position: absolute; top: 0; bottom: 0; width: 42px; opacity: 0.5; z-index: 1;
        background:
          linear-gradient(90deg, transparent, rgba(212,175,55,0.10), transparent),
          repeating-linear-gradient(180deg, rgba(212,175,55,0.10) 0 3px, transparent 3px 26px);
        pointer-events: none;
      }
      .scene::before { right: 1.4%; }
      .scene::after  { left: 1.4%; }

      .stage {
        position: relative; display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: 1rem;
        padding: 2.4rem 2.6rem 2rem; perspective: 1200px; min-height: 520px;
      }
      /* شعاع الإضاءة المسرحية */
      .spotlight {
        position: absolute; top: -6%; left: 50%; transform: translateX(-50%);
        width: 74%; height: 70%; pointer-events: none; z-index: 3;
        background: conic-gradient(from 180deg at 50% 0%, transparent 42%, rgba(244, 233, 200, 0.09) 47%, rgba(244, 233, 200, 0.14) 50%, rgba(244, 233, 200, 0.09) 53%, transparent 58%);
        filter: blur(2px);
        animation: sway 9s ease-in-out infinite alternate;
      }
      @keyframes sway {
        from { transform: translateX(-56%) rotate(-2deg); }
        to   { transform: translateX(-44%) rotate(2deg); }
      }

      /* إطار الصورة الملكي */
      .frame-tilt { width: 100%; transform-style: preserve-3d; transition: transform 0.3s ease-out; }
      .frame-tilt.spin { animation: turntable 16s ease-in-out infinite alternate; }
      @keyframes turntable {
        from { transform: rotateY(-9deg) rotateX(2deg); }
        to   { transform: rotateY(9deg) rotateX(2deg); }
      }
      .photo-frame {
        position: relative; width: 100%; aspect-ratio: 16 / 10;
        border-radius: 16px; overflow: hidden;
        border: 1px solid rgba(212, 175, 55, 0.55);
        box-shadow:
          0 0 0 5px rgba(14, 16, 22, 0.9),
          0 0 0 6px rgba(212, 175, 55, 0.5),
          0 30px 60px rgba(0, 0, 0, 0.65),
          0 0 60px rgba(212, 175, 55, 0.10);
        background: #0b0e14;
      }
      .photo-frame img.hero {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; display: block;
        animation: kenburns 18s ease-in-out infinite alternate;
      }
      @keyframes kenburns {
        from { transform: scale(1) translateX(0); }
        to   { transform: scale(1.12) translateX(-2%); }
      }
      /* توهج ذهبي خفيف أعلى الصورة */
      .photo-frame::after {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background: linear-gradient(200deg, rgba(212, 175, 55, 0.10), transparent 30%),
                    linear-gradient(0deg, rgba(7, 8, 12, 0.35), transparent 35%);
      }
      /* في حال تعذّر تحميل الصورة */
      .photo-frame .noimg-fallback {
        position: absolute; inset: 0; display: none;
        align-items: center; justify-content: center; flex-direction: column; gap: 0.6rem;
        background: radial-gradient(500px 260px at 50% 20%, rgba(212, 175, 55, 0.15), transparent 65%), #0b0e14;
        color: var(--gold-2); text-align: center; padding: 1rem;
      }
      .photo-frame.noimg img.hero { display: none; }
      .photo-frame.noimg .noimg-fallback { display: flex; }
      .noimg-fallback .big { font-size: 2.4rem; }

      /* انعكاس الإطار على أرضية القاعة */
      .frame-reflection {
        width: 100%; height: 90px; margin-top: 8px; pointer-events: none;
        border-radius: 16px; overflow: hidden; opacity: 0.25;
        transform: scaleY(-1);
        -webkit-mask-image: linear-gradient(0deg, transparent 25%, #000 100%);
        mask-image: linear-gradient(0deg, transparent 25%, #000 100%);
      }
      .frame-reflection img { width: 100%; height: 320px; object-fit: cover; object-position: top; display: block; filter: blur(1px); }
      .photo-frame.noimg + .frame-reflection { visibility: hidden; }

      /* زوايا العرض (تبديل الصور) */
      .angles { display: flex; gap: 0.6rem; z-index: 4; flex-wrap: wrap; justify-content: center; }
      .angle-thumb {
        width: 92px; height: 58px; border-radius: 10px; overflow: hidden; cursor: pointer;
        border: 2px solid var(--line); background: #0b0e14; padding: 0;
        transition: all 0.2s ease; position: relative;
      }
      .angle-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .angle-thumb:hover { border-color: var(--gold-dim); transform: translateY(-2px); }
      .angle-thumb.on { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.22); }
      .angle-thumb .lbl {
        position: absolute; inset-inline: 0; bottom: 0; font-size: 0.6rem; font-weight: 700;
        color: var(--gold-2); background: rgba(7, 8, 12, 0.72); padding: 1px 0;
      }

      /* أدوات المسرح */
      .stage-tools {
        position: absolute; top: 1rem; inset-inline-start: 1.2rem; z-index: 6;
        display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start;
      }
      .tool {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.82rem; color: var(--muted);
        background: rgba(10, 12, 18, 0.7); border: 1px solid var(--line);
        border-radius: 999px; padding: 0.35rem 0.9rem; backdrop-filter: blur(6px);
      }
      .tool input[type='range'] { accent-color: var(--gold); width: 130px; }
      .tool button {
        all: unset; cursor: pointer; color: var(--gold-2); font-weight: 700; font-size: 0.82rem;
      }

      /* ======== لوحة التفاصيل ======== */
      .panel {
        border-inline-start: 1px solid var(--line);
        padding: 2rem 1.8rem; display: flex; flex-direction: column; gap: 1rem;
        background: linear-gradient(200deg, rgba(212, 175, 55, 0.05), transparent 40%);
        position: relative; z-index: 2;
      }
      .panel .cat {
        color: var(--gold); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.14em;
      }
      .panel h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); color: var(--text); line-height: 1.3; }
      .panel .en-name { color: var(--muted); font-size: 0.92rem; letter-spacing: 0.06em; }
      .panel .desc { color: var(--muted); font-size: 0.96rem; line-height: 1.9; }

      .features { display: flex; flex-wrap: wrap; gap: 0.45rem; }
      .feature {
        font-size: 0.78rem; font-weight: 600; color: var(--gold-2);
        border: 1px solid var(--gold-dim); border-radius: 999px; padding: 0.28rem 0.8rem;
        background: rgba(212, 175, 55, 0.07);
      }

      .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem; }
      .stat {
        border: 1px solid var(--line); border-radius: 14px; padding: 0.7rem 0.6rem;
        text-align: center; background: rgba(255, 255, 255, 0.02);
      }
      .stat b { display: block; font-size: 1.35rem; color: var(--gold-2); font-weight: 800; }
      .stat small { color: var(--muted); font-size: 0.72rem; }

      .price-row { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
      .price-row .price { font-size: 1.7rem; font-weight: 800; color: var(--text); }
      .price-row .cur { color: var(--muted); font-size: 0.9rem; }
      .ctas { display: flex; gap: 0.7rem; flex-wrap: wrap; }
      .btn-gold {
        text-decoration: none; text-align: center; font-weight: 800; font-size: 1rem;
        color: #14100a; background: linear-gradient(135deg, var(--gold-2), var(--gold));
        border-radius: 999px; padding: 0.75rem 1.7rem;
        box-shadow: 0 6px 22px rgba(212, 175, 55, 0.28);
        transition: transform 0.2s ease;
      }
      .btn-gold:hover { transform: translateY(-2px); }
      .btn-ghost {
        text-decoration: none; text-align: center; font-weight: 600; font-size: 1rem;
        color: var(--gold-2); border: 1px solid var(--gold-dim); border-radius: 999px;
        padding: 0.75rem 1.7rem; transition: background 0.2s ease;
      }
      .btn-ghost:hover { background: rgba(212, 175, 55, 0.08); }

      /* ======== شريط المقتنيات ======== */
      .gallery { max-width: 1280px; margin: 1.1rem auto 0; padding: 0 1.2rem; }
      .gallery h3 { color: var(--muted); font-size: 0.95rem; font-weight: 600; margin-bottom: 0.7rem; }
      .thumbs { display: flex; gap: 0.8rem; overflow-x: auto; padding-bottom: 0.8rem; }
      .thumb {
        flex: 0 0 210px; cursor: pointer; text-align: center;
        border: 1px solid var(--line); border-radius: 16px; padding: 0; overflow: hidden;
        background: var(--panel); transition: all 0.25s ease;
      }
      .thumb:hover { border-color: var(--gold-dim); transform: translateY(-3px); }
      .thumb.on { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.18); }
      .thumb .ph { width: 100%; height: 110px; background: #0b0e14; overflow: hidden; }
      .thumb .ph img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
      .thumb:hover .ph img { transform: scale(1.08); }
      .thumb b { display: block; font-size: 0.85rem; color: var(--text); margin: 0.45rem 0.5rem 0; }
      .thumb small { color: var(--muted); font-size: 0.72rem; display: block; margin: 0 0.5rem 0.55rem; }

      /* ======== لماذا القصر ======== */
      .why { max-width: 1100px; margin: 3.5rem auto 0; padding: 0 1.2rem; text-align: center; }
      .why h2 { color: var(--gold-2); font-size: clamp(1.6rem, 4vw, 2.4rem); margin-bottom: 0.4rem; }
      .why > p { color: var(--muted); max-width: 640px; margin: 0 auto 2rem; line-height: 1.9; }
      .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1rem; text-align: right; }
      .why-card {
        border: 1px solid var(--line); border-radius: 18px; padding: 1.3rem;
        background: linear-gradient(160deg, rgba(212, 175, 55, 0.06), transparent 55%);
      }
      .why-card .ic { font-size: 1.6rem; }
      .why-card h4 { color: var(--text); margin: 0.5rem 0 0.3rem; font-size: 1.05rem; }
      .why-card p { color: var(--muted); font-size: 0.88rem; line-height: 1.8; }

      footer.bottom {
        margin-top: 3.5rem; padding: 2rem 1.2rem 2.6rem; text-align: center;
        border-top: 1px solid var(--line); color: var(--muted); font-size: 0.9rem;
      }
      footer.bottom .serif { color: var(--gold-2); font-size: 1.3rem; display: block; margin-bottom: 0.4rem; }
      footer.bottom .credit { font-size: 0.72rem; opacity: 0.7; display: block; margin-top: 0.5rem; }

      @media (max-width: 900px) {
        .scene { grid-template-columns: 1fr; }
        .stage { min-height: unset; padding: 4.2rem 1.2rem 1.6rem; }
        .panel { border-inline-start: none; border-top: 1px solid var(--line); }
        .stage-tools { flex-direction: row; flex-wrap: wrap; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation: none !important; transition: none !important; }
      }
    </style>
  </head>
  <body>
    <!-- بوابة القصر -->
    <div id="gate">
      <div class="door left"></div>
      <div class="door right"></div>
      <div class="emblem">
        <div class="crown">👑</div>
        <h1>القـصـر</h1>
        <p>معرض الفخامة الافتراضي — سيارات خارقة · يخوت · دبابات بحرية</p>
        <button id="enterBtn">ادخل القصر</button>
      </div>
    </div>

    <header class="top">
      <div class="brand">
        <div class="mark">👑</div>
        <div>
          <b>القصر</b>
          <span>THE PALACE — LUXURY GALLERY</span>
        </div>
      </div>
      <nav class="halls" aria-label="قاعات القصر">
        <button class="hall-tab active" data-hall="cars">🏎️ قاعة السيارات الخارقة</button>
        <button class="hall-tab" data-hall="marina">⚓ المارينا الملكية</button>
        <a class="hall-tab" href="/motors" style="text-decoration:none">🛒 سوق القصر موتورز</a>
      </nav>
    </header>

    <main>
      <section class="atrium" aria-label="منصة العرض">
        <div class="scene" id="scene">
          <div class="stage" id="stage">
            <div class="spotlight"></div>
            <div class="stage-tools">
              <label class="tool">🎛️ إمالة اللوحة
                <input type="range" id="angle" min="-14" max="14" value="0" step="1" />
              </label>
              <div class="tool"><button id="spinBtn">⏸️ إيقاف الحركة</button></div>
            </div>
            <div class="frame-tilt spin" id="frameTilt">
              <figure class="photo-frame" id="photoFrame">
                <img class="hero" id="heroImg" alt="" />
                <div class="noimg-fallback">
                  <div class="big">👑</div>
                  <b id="fallbackName"></b>
                  <small>تعذّر تحميل الصورة — تفقد اتصالك بالإنترنت</small>
                </div>
              </figure>
              <div class="frame-reflection" aria-hidden="true"><img id="reflImg" alt="" /></div>
            </div>
            <div class="angles" id="angles"></div>
          </div>

          <aside class="panel" id="panel">
            <span class="cat" id="pCat"></span>
            <h2 id="pName"></h2>
            <div class="en-name" id="pEn"></div>
            <p class="desc" id="pDesc"></p>
            <div class="features" id="pFeatures"></div>
            <div class="stats" id="pStats"></div>
            <div class="price-row">
              <span class="price" id="pPrice"></span>
              <span class="cur">ريال سعودي</span>
            </div>
            <div class="ctas">
              <a class="btn-gold" id="pBook" target="_blank" rel="noopener">احجز معاينة خاصة</a>
              <a class="btn-ghost" href="tel:+966503793356">تحدث مع مستشار</a>
            </div>
          </aside>
        </div>
      </section>

      <section class="gallery">
        <h3 id="hallTitle">مقتنيات قاعة السيارات الخارقة</h3>
        <div class="thumbs" id="thumbs"></div>
      </section>

      <section class="why">
        <h2>تجربة اقتناء لا تشبه غيرها</h2>
        <p>القصر ليس معرضًا تقليديًا — إنه صالة عرض رقمية تجمع كل ما هو فاخر تحت سقف واحد، وتقدّمه بأسلوب مسرحي مبتكر قبل أن تلمسه على أرض الواقع.</p>
        <div class="why-grid">
          <div class="why-card">
            <div class="ic">📸</div>
            <h4>عرض مسرحي بصور حقيقية</h4>
            <p>لوحات ملكية بإضاءة مسرحية وزوايا عرض متعددة لكل قطعة — كما لو كنت واقفًا أمامها.</p>
          </div>
          <div class="why-card">
            <div class="ic">🛥️</div>
            <h4>كل الفخامة في مكان واحد</h4>
            <p>سيارات خارقة، يخوت، ودبابات بحرية — من البوابة إلى المارينا دون مغادرة القصر.</p>
          </div>
          <div class="why-card">
            <div class="ic">🤝</div>
            <h4>معاينة خاصة</h4>
            <p>احجز موعدًا شخصيًا لمعاينة أي قطعة على أرض الواقع مع مستشار مختص.</p>
          </div>
          <div class="why-card">
            <div class="ic">🔒</div>
            <h4>خصوصية تامة</h4>
            <p>تفاوض وإتمام صفقات بسرية كاملة تليق بمقتنيات استثنائية.</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="bottom">
