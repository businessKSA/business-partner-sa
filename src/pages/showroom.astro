          desc: 'أقوى فيراري إنتاجية على الإطلاق — هايبرد بثلاثة محركات كهربائية ومحرك V8 تيربو، بروح حلبات الفورمولا 1.',
          features: ['هايبرد V8 تيربو', '3 محركات كهربائية', 'دفع رباعي ذكي', 'تقنيات F1'],
          stats: [
            { v: 340, u: 'كم/س', l: 'السرعة القصوى' },
            { v: 1000, u: 'حصان', l: 'القوة' },
            { v: 2.5, u: 'ثانية', l: '0-100 كم/س', dec: 1 },
          ],
          price: 2800000,
          photos: [
            { id: 'h5gJSIV6I-U', lbl: 'عرض ليلي' },
            { id: 'lqMbPztrjL8', lbl: 'الصالة' },
            { id: 'k7dxIXWg61A', lbl: 'خارجية' },
          ],
        },
        {
          id: 'lambo', hall: 'cars',
          cat: 'قاعة السيارات الخارقة', name: 'لامبورجيني هوراكان بيرفورمانتي', en: 'LAMBORGHINI HURACÁN PERFORMANTE',
          desc: 'وحش إيطالي بمحرك V10 يصرخ حتى 8500 دورة — هوائيات ALA النشطة وهيكل كربوني يجعلانه ملك الحلبات والشوارع معًا.',
          features: ['محرك V10 — 5.2 لتر', 'هوائيات ALA النشطة', 'كربون فورجد', 'أبواب رياضية'],
          stats: [
            { v: 325, u: 'كم/س', l: 'السرعة القصوى' },
            { v: 640, u: 'حصان', l: 'القوة' },
            { v: 2.9, u: 'ثانية', l: '0-100 كم/س', dec: 1 },
          ],
          price: 1600000,
          photos: [
            { id: 'y0pXihFOly0', lbl: 'جانبية' },
            { id: 'RLBOVaOJkWk', lbl: 'الصالة' },
            { id: 'C4QtfuEJMFU', lbl: 'خلفية' },
          ],
        },
        {
          id: 'yacht-royal', hall: 'marina',
          cat: 'المارينا الملكية', name: 'اليخت الملكي — فلاي بريدج 32م', en: 'ROYAL FLYBRIDGE YACHT 32M',
          desc: 'يخت فاخر بطول 32 مترًا بأربع كبائن وصالة بانورامية وسطح شمسي — تشطيبات ذهبية وأثاث إيطالي حسب الطلب.',
          features: ['4 كبائن VIP', 'سطح شمسي', 'صالة بانورامية 270°', 'منصة سباحة خلفية'],
          stats: [
            { v: 32, u: 'متر', l: 'الطول' },
            { v: 28, u: 'عقدة', l: 'السرعة' },
            { v: 10, u: 'ضيوف', l: 'الإقامة' },
          ],
          price: 18500000,
          photos: [
            { id: 'bt-AYttMuww', lbl: 'إبحار' },
            { id: 'qToVxSYXPYU', lbl: 'عرض البحر' },
          ],
        },
        {
          id: 'superyacht', hall: 'marina',
          cat: 'المارينا الملكية', name: 'سوبر يخت — جناح المالك 45م', en: 'SUPERYACHT OWNER SUITE 45M',
          desc: 'قصر يبحر — 45 مترًا من الفخامة المطلقة بخمسة أجنحة وجاكوزي على السطح ونادٍ شاطئي قابل للفتح على البحر.',
          features: ['5 أجنحة فاخرة', 'جاكوزي على السطح', 'نادٍ شاطئي', 'طاقم كامل'],
          stats: [
            { v: 45, u: 'متر', l: 'الطول' },
            { v: 24, u: 'عقدة', l: 'السرعة' },
            { v: 12, u: 'ضيفًا', l: 'الإقامة' },
          ],
          price: 42000000,
          photos: [
            { id: '6qSgfIAmkYU', lbl: 'إبحار' },
            { id: 'cFUZmntOXcc', lbl: 'المارينا' },
          ],
        },
        {
          id: 'jetski-sport', hall: 'marina',
          cat: 'المارينا الملكية', name: 'دباب بحري رياضي — سوبرتشارج 325', en: 'SUPERCHARGED PERFORMANCE JET SKI 325',
          desc: 'أقوى فئة في عالم الدبابات البحرية — 325 حصانًا بمحرك سوبرتشارج وهيكل مصمم للانعطافات الحادة والأدرينالين الخالص.',
          features: ['سوبرتشارج 325 حصان', 'مقعد رياضي Ergolock', 'وضعية سباق', 'نظام مكابح ذكي'],
          stats: [
            { v: 130, u: 'كم/س', l: 'السرعة القصوى' },
            { v: 325, u: 'حصان', l: 'القوة' },
            { v: 1630, u: 'سي سي', l: 'المحرك' },
          ],
          price: 95000,
          photos: [
            { id: 'gb3Edm0JNxo', lbl: 'أكشن' },
            { id: 'Rx0bUZHHU3A', lbl: 'انعطاف' },
          ],
        },
        {
          id: 'jetski-gp', hall: 'marina',
          cat: 'المارينا الملكية', name: 'دباب بحري سباق — GP إصدار خاص', en: 'GP RACE EDITION JET SKI',
          desc: 'أسطورة السباقات البحرية — خفيف، حاد، ولا يرحم في المنافسات. الخيار الأول لأبطال الجولات العالمية.',
          features: ['هيكل سباق خفيف', 'وضعيات قيادة متعددة', 'محرك سوبرتشارج', 'مخصص للمحترفين'],
          stats: [
            { v: 110, u: 'كم/س', l: 'السرعة القصوى' },
            { v: 250, u: 'حصان', l: 'القوة' },
            { v: 1812, u: 'سي سي', l: 'المحرك' },
          ],
          price: 78000,
          photos: [
            { id: 'xrT7OLlDm5g', lbl: 'أكشن' },
            { id: 'IIyqivFm7eM', lbl: 'إبحار' },
          ],
        },
      ];

      const HALL_TITLES = {
        cars: 'مقتنيات قاعة السيارات الخارقة',
        marina: 'مقتنيات المارينا الملكية',
      };

      // ======== عناصر الصفحة ========
      const $ = (id) => document.getElementById(id);
      const scene = $('scene'), stage = $('stage'), frameTilt = $('frameTilt');
      const photoFrame = $('photoFrame'), heroImg = $('heroImg'), reflImg = $('reflImg');
      const anglesEl = $('angles'), thumbsEl = $('thumbs');
      const fmt = new Intl.NumberFormat('en-US');

      let current = null;
      let spinning = true;

      heroImg.addEventListener('error', () => photoFrame.classList.add('noimg'));
      heroImg.addEventListener('load', () => photoFrame.classList.remove('noimg'));

      function setHero(item, photoIdx) {
        const p = item.photos[photoIdx];
        photoFrame.classList.remove('noimg');
        heroImg.src = IMG(p.id, 1600);
        heroImg.alt = item.name + ' — ' + p.lbl;
        reflImg.src = IMG(p.id, 1600);
        $('fallbackName').textContent = item.name;
        // إعادة تشغيل حركة الزوم السينمائي
        heroImg.style.animation = 'none';
        void heroImg.offsetWidth;
        heroImg.style.animation = '';
        anglesEl.querySelectorAll('.angle-thumb').forEach((a, i) =>
          a.classList.toggle('on', i === photoIdx)
        );
      }

      function renderAngles(item) {
        anglesEl.innerHTML = '';
        item.photos.forEach((p, i) => {
          const b = document.createElement('button');
          b.className = 'angle-thumb' + (i === 0 ? ' on' : '');
          b.setAttribute('aria-label', 'زاوية: ' + p.lbl);
          b.innerHTML = `<img src="${IMG(p.id, 300)}" alt="" loading="lazy" onerror="this.style.display='none'" /><span class="lbl">${p.lbl}</span>`;
          b.addEventListener('click', () => setHero(item, i));
          anglesEl.appendChild(b);
        });
      }

      function renderThumbs(hall) {
        thumbsEl.innerHTML = '';
        ITEMS.filter((i) => i.hall === hall).forEach((item) => {
          const t = document.createElement('button');
          t.className = 'thumb' + (current && current.id === item.id ? ' on' : '');
          t.innerHTML =
            `<div class="ph"><img src="${IMG(item.photos[0].id, 640)}" alt="${item.name}" loading="lazy" onerror="this.style.display='none'" /></div>` +
            `<b>${item.name}</b><small>${item.en}</small>`;
          t.addEventListener('click', () => select(item.id));
          thumbsEl.appendChild(t);
        });
        $('hallTitle').textContent = HALL_TITLES[hall];
      }

      function animateNumber(el, target, dec) {
        const dur = 700, start = performance.now();
        function tick(now) {
          const p = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (target * eased).toFixed(dec || 0);
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      function select(id) {
        const item = ITEMS.find((i) => i.id === id);
        if (!item || (current && current.id === id)) return;
        current = item;

        // المشهد: قاعة سيارات أم مارينا
        scene.classList.toggle('marina', item.hall === 'marina');

        setHero(item, 0);
        renderAngles(item);
        // إعادة ضبط اختيار الزاوية الأولى بعد إعادة البناء
        anglesEl.querySelectorAll('.angle-thumb').forEach((a, i) =>
          a.classList.toggle('on', i === 0)
        );

        // اللوحة
        $('pCat').textContent = '◆ ' + item.cat;
        $('pName').textContent = item.name;
        $('pEn').textContent = item.en;
        $('pDesc').textContent = item.desc;

        const featEl = $('pFeatures');
        featEl.innerHTML = '';
        item.features.forEach((f) => {
          const s = document.createElement('span');
          s.className = 'feature';
          s.textContent = '✦ ' + f;
          featEl.appendChild(s);
        });

        const statsEl = $('pStats');
        statsEl.innerHTML = '';
        item.stats.forEach((s) => {
          const d = document.createElement('div');
          d.className = 'stat';
          d.innerHTML = `<b>0</b><span style="color:var(--muted);font-size:0.72rem"> ${s.u}</span><small style="display:block">${s.l}</small>`;
          statsEl.appendChild(d);
          animateNumber(d.querySelector('b'), s.v, s.dec);
        });

        $('pPrice').textContent = fmt.format(item.price);
        $('pBook').href = WHATSAPP + '?text=' + encodeURIComponent('أرغب بحجز معاينة خاصة: ' + item.name);

        renderThumbs(item.hall);
        document.querySelectorAll('.hall-tab').forEach((b) =>
          b.classList.toggle('active', b.dataset.hall === item.hall)
        );
      }

      // تبويبات القاعات
      document.querySelectorAll('.hall-tab').forEach((btn) => {
        btn.addEventListener('click', () => {
          const first = ITEMS.find((i) => i.hall === btn.dataset.hall);
          if (first) select(first.id);
        });
      });

      // إمالة اللوحة اليدوية
      $('angle').addEventListener('input', (e) => {
        spinning = false;
        frameTilt.classList.remove('spin');
        $('spinBtn').textContent = '▶️ تشغيل الحركة';
        frameTilt.style.transform = `rotateY(${e.target.value}deg) rotateX(2deg)`;
      });
      $('spinBtn').addEventListener('click', () => {
        spinning = !spinning;
        frameTilt.classList.toggle('spin', spinning);
        if (spinning) frameTilt.style.transform = '';
        $('spinBtn').textContent = spinning ? '⏸️ إيقاف الحركة' : '▶️ تشغيل الحركة';
      });

      // إمالة تتبع المؤشر (عند إيقاف الحركة التلقائية)
      stage.addEventListener('mousemove', (e) => {
        if (spinning) return;
        const r = stage.getBoundingClientRect();
        const dx = (e.clientX - r.left) / r.width - 0.5;
        const dy = (e.clientY - r.top) / r.height - 0.5;
        const base = Number($('angle').value);
        frameTilt.style.transform = `rotateY(${base + dx * 10}deg) rotateX(${2 - dy * 6}deg)`;
      });

      // البوابة (مع قفل التمرير حتى الدخول)
      document.body.style.overflow = 'hidden';
      $('enterBtn').addEventListener('click', () => {
        $('gate').classList.add('open');
        document.body.style.overflow = '';
      });

      // البداية
      select('bugatti');
    </script>
  </body>
</html>
