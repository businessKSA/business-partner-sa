  tabFees: '💰 حاسبة التكاليف',
  nitTitle: 'حاسبة نطاقات السعودة',
  nitSub: 'أدخل أعداد الموظفين ويحدد النظام حجم منشأتك ونطاقها المتوقع تلقائياً.',
  totalEmployees: 'إجمالي الموظفين',
  saudiEmployees: 'عدد الموظفين السعوديين',
  activity: 'النشاط (اختياري)',
  activityPh: 'مثال: تجارة تجزئة، مقاولات، صناعة…',
  calc: 'احسب',
  sizeLabel: 'حجم المنشأة',
  pctLabel: 'نسبة التوطين',
  bandLabel: 'النطاق المتوقع',
  compliantYes: 'منشأتك ضمن النطاق الآمن ✅',
  needForCompliance: 'تحتاج توظيف {n} سعودي للخروج من النطاق الأحمر',
  needForNext: 'توظيف {n} سعودي إضافي يرفعك إلى: {band}',
  topBand: 'أنت في أعلى نطاق — حافظ عليه 👏',
  feesTitle: 'حاسبة التكاليف الحكومية',
  feesSub: 'رخصة العمل (قوى) + الإقامة (مقيم) + التأمين الطبي + الغرامات — لكل عامل، ربعياً وسنوياً.',
  profession: 'المهنة',
  professionPh: 'مثال: عامل، فني، مهندس…',
  status: 'الحالة',
  statusExisting: 'قائم (على رأس العمل)',
  statusNew: 'جديد (أول دخول للمملكة)',
  count: 'العدد',
  late: 'تأخير تجديد الإقامة',
  lateNone: 'لا يوجد',
  lateFirst: 'المرة الأولى (+500 ريال)',
  lateSecond: 'المرة الثانية (+1,000 ريال)',
  addRow: '+ إضافة مهنة أخرى',
  removeRow: 'حذف',
  quarterPerWorker: 'ربعي / عامل',
  annualPerWorker: 'سنوي / عامل',
