---
interface Props {
  lang: 'ar' | 'en';
}

const { lang } = Astro.props;
const isAr = lang === 'ar';

const t = isAr ? {
  metaTitle: 'حاسبات الامتثال — النطاقات والتكاليف الحكومية | شريك الأعمال',
  metaDesc: 'احسب نطاق السعودة المتوقع لمنشأتك وتكاليف العمالة الحكومية (رخص العمل، الإقامات، التأمين) تقديرياً خلال ثوانٍ.',
  backHome: 'الرئيسية',
  heroBadge: 'أدوات مجانية',
  heroTitle: 'حاسبات الامتثال',
  heroSub: 'احسب نطاق السعودة المتوقع وتكاليف العمالة الحكومية لمنشأتك خلال ثوانٍ — تقديرياً وقبل أي التزام.',
