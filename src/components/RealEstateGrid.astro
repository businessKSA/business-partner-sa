---
import { realEstateOpportunities, categoryLabels, type PropertyCategory } from '../content/realEstate';

interface Props {
  lang: 'ar' | 'en';
}

const { lang } = Astro.props;

const WHATSAPP_NUMBER = '966507034157';

const categories: PropertyCategory[] = ['serviced-office', 'coworking', 'commercial-building'];

const numberFmt = new Intl.NumberFormat(lang === 'ar' ? 'ar-SA' : 'en-US');

const t = lang === 'ar'
  ? {
      all: 'كل الفرص',
      area: 'المساحة',
      capacity: 'السعة',
      sqm: 'م²',
      seats: 'شخص',
      requestQuote: 'اطلب عرض سعر',
      noResults: 'لا توجد فرص مطابقة لهذا الفلتر حاليًا.',
      whatsappMsg: (name: string) => `السلام عليكم، أرغب في الاستفسار عن فرصة "${name}" ضمن الفرص العقارية.`,
    }
  : {
      all: 'All Opportunities',
      area: 'Area',
      capacity: 'Capacity',
      sqm: 'sqm',
      seats: 'people',
      requestQuote: 'Request a Quote',
      noResults: 'No opportunities match this filter yet.',
      whatsappMsg: (name: string) => `Hello, I'd like to ask about the "${name}" real estate opportunity.`,
    };

// Group opportunities by location (district), preserving first-appearance order.
const groups: { key: string; district: { ar: string; en: string }; items: typeof realEstateOpportunities }[] = [];
for (const op of realEstateOpportunities) {
  const key = op.district.en;
  let group = groups.find((g) => g.key === key);
  if (!group) {
    group = { key, district: op.district, items: [] };
    groups.push(group);
  }
  group.items.push(op);
}
---

<div class="re-filters" role="group" aria-label={lang === 'ar' ? 'فلترة الفرص العقارية' : 'Filter real estate opportunities'}>
  <button class="re-filter-btn is-active" data-filter-type="category" data-value="all">{t.all}</button>
  {categories.map((c) => (
    <button class="re-filter-btn" data-filter-type="category" data-value={c}>{categoryLabels[c][lang]}</button>
  ))}
</div>

<div id="re-groups">
  {groups.map((group) => (
    <section class="re-location-group" data-location={group.key}>
      <h2 class="re-location-title">📍 {group.district[lang]}</h2>
      <div class="re-grid">
        {group.items.map((op) => (
          <article class="re-card" data-category={op.category}>
            <div class="re-card-top">
              <span class="re-badge">{op.badge[lang]}</span>
            </div>

            <h3 class="re-card-title">{op.name[lang]}</h3>
            <p class="re-card-summary">{op.summary[lang]}</p>

            <div class="re-specs">
              {op.areaSqm && (
                <div class="re-spec">
                  <span class="re-spec-label">{t.area}</span>
                  <span class="re-spec-value">{numberFmt.format(op.areaSqm)} {t.sqm}</span>
                </div>
              )}
              {op.capacity && (
                <div class="re-spec">
                  <span class="re-spec-label">{t.capacity}</span>
                  <span class="re-spec-value">{numberFmt.format(op.capacity)} {t.seats}</span>
                </div>
              )}
            </div>

            <ul class="re-features">
              {op.features[lang].slice(0, 4).map((f) => <li>{f}</li>)}
            </ul>

            <a
              class="re-cta"
              href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(t.whatsappMsg(op.name[lang]))}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t.requestQuote}
            </a>
          </article>
        ))}
      </div>
    </section>
  ))}
</div>

<p class="re-empty" id="re-empty" hidden>{t.noResults}</p>

<style>
  .re-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }

  .re-filter-btn {
    border: 1px solid rgba(15, 23, 42, 0.15);
    background: #fff;
    color: #1e293b;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .re-filter-btn:hover {
    border-color: #2563eb;
    color: #2563eb;
  }

  .re-filter-btn.is-active {
    background: #0B1B5A;
    border-color: #0B1B5A;
    color: #fff;
  }

  .re-location-group {
    margin-bottom: 2.75rem;
  }

  .re-location-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1.1rem;
  }

  .re-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .re-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .re-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.1);
  }

  .re-card-top {
    display: flex;
    margin-bottom: 0.75rem;
  }

  .re-badge {
    background: rgba(37, 99, 235, 0.1);
    color: #2563eb;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .re-card-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 0.5rem;
  }

  .re-card-summary {
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.6;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .re-specs {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .re-spec {
    display: flex;
    flex-direction: column;
  }

  .re-spec-label {
    font-size: 0.7rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .re-spec-value {
    font-size: 0.95rem;
    color: #0f172a;
    font-weight: 700;
  }

  .re-features {
    list-style: none;
    margin: 0 0 1.1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .re-features li {
    font-size: 0.85rem;
    color: #334155;
    padding-inline-start: 1.1rem;
    position: relative;
  }

  .re-features li::before {
    content: '✓';
    position: absolute;
    inset-inline-start: 0;
    color: #16a34a;
    font-weight: 700;
  }

  .re-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #16a34a;
    color: #fff !important;
    text-decoration: none;
    font-weight: 700;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    margin-top: auto;
    transition: background 0.2s ease;
  }

  .re-cta:hover {
    background: #15803d;
  }

  .re-empty {
    text-align: center;
    color: #64748b;
    padding: 3rem 0;
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .re-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  let activeCategory = 'all';

  const buttons = document.querySelectorAll<HTMLButtonElement>('.re-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.re-card');
  const groupEls = document.querySelectorAll<HTMLElement>('.re-location-group');
  const emptyMsg = document.getElementById('re-empty');

  function applyFilters() {
    let visibleCount = 0;

    cards.forEach((card) => {
      const visible = activeCategory === 'all' || card.dataset.category === activeCategory;
      card.hidden = !visible;
      if (visible) visibleCount++;
    });

    groupEls.forEach((group) => {
      const hasVisibleCard = Array.from(group.querySelectorAll<HTMLElement>('.re-card')).some((c) => !c.hidden);
      group.hidden = !hasVisibleCard;
    });

    if (emptyMsg) emptyMsg.hidden = visibleCount !== 0;
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      activeCategory = btn.dataset.value ?? 'all';
      applyFilters();
    });
  });
</script>
