// زر عائم يفتح المساعد الصوتي الذكي (الفريق التنفيذي) — يظهر في كل الصفحات.
// موضوع فوق زر واتساب على نفس الجهة حتى لا يتعارض مع أي زر آخر.
---

<a href="/voice" class="assistant-fab" aria-label="المساعد الذكي — تحدّث بالصوت">
  <span class="af-icon" aria-hidden="true">🎙️</span>
  <span class="af-label">المساعد الذكي</span>
</a>

<style>
  .assistant-fab {
    position: fixed;
    bottom: 6.25rem; /* فوق زر واتساب (60px عند 2rem) */
    inset-inline-start: 2rem;
    z-index: 99;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    height: 56px;
    padding: 0 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, #12b3ad, #0e7f7b);
    color: #fff;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(14, 159, 154, 0.4);
    font-family: inherit;
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .assistant-fab:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 14px 36px rgba(14, 159, 154, 0.5); }
  .af-icon { font-size: 1.35rem; line-height: 1; }
  .af-label { white-space: nowrap; }
  [dir="rtl"] .assistant-fab { inset-inline-start: auto; inset-inline-end: 2rem; }
  @media (max-width: 768px) {
    .assistant-fab { padding: 0; width: 56px; justify-content: center; gap: 0; }
    .af-label { display: none; }
