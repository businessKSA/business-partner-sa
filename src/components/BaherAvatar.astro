---
// أفاتار باهر — صورة صاحب الموقع الحقيقية (بدل الرسمة بناءً على طلبه).
// دائرية بإطار أبيض، ومعها مؤشر كلام (موجات صوت) يظهر أثناء نطق الرد.
interface Props {
  size?: number;
}

const { size = 56 } = Astro.props;
---

<span class="bpw-avatar" style={`width:${size}px;height:${size}px`} aria-hidden="true">
  <img src="/baher-photo.jpg" alt="" width={size} height={size} loading="lazy" />
  <span class="bpw-speak-bars"><i></i><i></i><i></i></span>
</span>
