---
import { categoryLabels, cityLabels, type PropertyCategory } from '../content/realEstate';

interface Props {
  lang: 'ar' | 'en';
}

const { lang } = Astro.props;

const categories: PropertyCategory[] = ['serviced-office', 'coworking', 'commercial-building'];
const cities = Object.keys(cityLabels);

const t = lang === 'ar'
  ? {
      title: 'ما لقيت طلبك؟ عبّي الفورم ونطابقه لك',
      subtitle: 'أخبرنا باحتياجك العقاري أو التجاري، وسيقوم فريقنا بمطابقتك مع أنسب فرصة من شبكة الموردين لدينا.',
      name: 'الاسم',
      phone: 'رقم الجوال',
      email: 'البريد الإلكتروني (اختياري)',
      city: 'المدينة',
      category: 'نوع العقار المطلوب',
      purpose: 'الغرض',
      purposeRent: 'إيجار',
      purposeBuy: 'شراء',
      area: 'المساحة المطلوبة (م²) — اختياري',
      seats: 'عدد المقاعد/الموظفين — اختياري',
      budget: 'الميزانية (شهرية أو إجمالية) — اختياري',
      notes: 'ملاحظات إضافية',
      submit: 'أرسل طلبي',
      selectCity: 'اختر المدينة',
      selectCategory: 'اختر النوع',
      any: 'غير محدد',
    }
  : {
      title: "Didn't find what you need? Submit your request",
      subtitle: "Tell us about your real estate or workspace need, and our team will match you with the best fit from our vendor network.",
      name: 'Full Name',
      phone: 'Phone Number',
      email: 'Email (optional)',
      city: 'City',
      category: 'Property Type Needed',
      purpose: 'Purpose',
      purposeRent: 'Rent',
      purposeBuy: 'Buy',
      area: 'Area needed (sqm) — optional',
      seats: 'Seats/employees needed — optional',
      budget: 'Budget (monthly or total) — optional',
      notes: 'Additional Notes',
      submit: 'Submit My Request',
      selectCity: 'Select a city',
      selectCategory: 'Select a type',
      any: 'Not specified',
    };
---

<section class="rq-section" id="request">
  <div class="rq-head">
    <h2>{t.title}</h2>
    <p>{t.subtitle}</p>
  </div>

  <form id="re-request-form" class="rq-form">
    <div class="rq-row">
      <div class="rq-field">
        <label for="rq-name">{t.name}</label>
        <input id="rq-name" name="name" type="text" required />
      </div>
      <div class="rq-field">
        <label for="rq-phone">{t.phone}</label>
        <input id="rq-phone" name="phone" type="tel" pattern="^(?:\+?966|0)?5\d{8}$" placeholder="05XXXXXXXX" required />
      </div>
    </div>

    <div class="rq-row">
      <div class="rq-field">
        <label for="rq-email">{t.email}</label>
        <input id="rq-email" name="email" type="email" />
      </div>
      <div class="rq-field">
        <label for="rq-city">{t.city}</label>
        <select id="rq-city" name="city">
          <option value="">{t.selectCity}</option>
          {cities.map((c) => <option value={c}>{cityLabels[c][lang]}</option>)}
        </select>
      </div>
    </div>

    <div class="rq-row">
      <div class="rq-field">
        <label for="rq-category">{t.category}</label>
        <select id="rq-category" name="category">
          <option value="">{t.selectCategory}</option>
          {categories.map((c) => <option value={c}>{categoryLabels[c][lang]}</option>)}
        </select>
      </div>
      <div class="rq-field">
        <label for="rq-purpose">{t.purpose}</label>
        <select id="rq-purpose" name="purpose">
          <option value={t.purposeRent}>{t.purposeRent}</option>
          <option value={t.purposeBuy}>{t.purposeBuy}</option>
        </select>
      </div>
    </div>

    <div class="rq-row rq-row-3">
      <div class="rq-field">
        <label for="rq-area">{t.area}</label>
        <input id="rq-area" name="area" type="text" inputmode="numeric" />
      </div>
      <div class="rq-field">
        <label for="rq-seats">{t.seats}</label>
        <input id="rq-seats" name="seats" type="text" inputmode="numeric" />
      </div>
      <div class="rq-field">
        <label for="rq-budget">{t.budget}</label>
        <input id="rq-budget" name="budget" type="text" />
      </div>
    </div>

    <div class="rq-field">
      <label for="rq-notes">{t.notes}</label>
      <textarea id="rq-notes" name="notes" rows="3"></textarea>
    </div>

    <input type="hidden" name="lang" value={lang} />

    <button type="submit" class="rq-submit">
      <span class="rq-submit-text">{t.submit}</span>
    </button>

    <div id="rq-message" class="rq-result" hidden></div>
  </form>
</section>

<style>
  .rq-section {
    background: #f8fafc;
    border-radius: 20px;
    padding: 2.5rem;
    margin: 3rem 0;
  }

  .rq-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 2rem;
  }

  .rq-head h2 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 0.6rem;
  }

  .rq-head p {
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .rq-form {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rq-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .rq-row-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .rq-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .rq-field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #334155;
  }

  .rq-field input,
  .rq-field select,
  .rq-field textarea {
    padding: 0.7rem 0.9rem;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 10px;
    font-size: 0.95rem;
    font-family: inherit;
    background: #fff;
  }

  .rq-submit {
    background: #0B1B5A;
    color: #fff;
    border: none;
    padding: 0.9rem 1.5rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .rq-submit:hover {
    background: #13246e;
  }

  .rq-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .rq-result {
    padding: 0.9rem;
    border-radius: 10px;
    font-size: 0.9rem;
    text-align: center;
  }

  .rq-result.success {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }

  .rq-result.error {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  @media (max-width: 640px) {
    .rq-section {
      padding: 1.75rem 1.25rem;
    }

    .rq-row,
    .rq-row-3 {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('re-request-form') as HTMLFormElement;
  const resultBox = document.getElementById('rq-message') as HTMLDivElement;

  function showResult(message: string, type: 'success' | 'error') {
    resultBox.textContent = message;
    resultBox.className = `rq-result ${type}`;
    resultBox.hidden = false;
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const submitText = submitButton.querySelector('.rq-submit-text') as HTMLSpanElement;
      const originalText = submitText.textContent;
      const lang = document.documentElement.lang as 'ar' | 'en';

      submitButton.disabled = true;
      submitText.textContent = lang === 'ar' ? 'جاري الإرسال...' : 'Sending...';

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries()) as Record<string, string>;

      const summaryLines = [
        `${lang === 'ar' ? 'المدينة' : 'City'}: ${data.city || '-'}`,
        `${lang === 'ar' ? 'نوع العقار' : 'Property type'}: ${data.category || '-'}`,
        `${lang === 'ar' ? 'الغرض' : 'Purpose'}: ${data.purpose || '-'}`,
        `${lang === 'ar' ? 'المساحة' : 'Area'}: ${data.area || '-'}`,
        `${lang === 'ar' ? 'السعة' : 'Seats'}: ${data.seats || '-'}`,
        `${lang === 'ar' ? 'الميزانية' : 'Budget'}: ${data.budget || '-'}`,
        `${lang === 'ar' ? 'ملاحظات' : 'Notes'}: ${data.notes || '-'}`,
      ].join('\n');

      try {
        const leadEndpoint = import.meta.env.PUBLIC_LEAD_ENDPOINT || '/api/contact';

        const response = await fetch(leadEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify({
            entityName: lang === 'ar' ? 'طلب عقاري/مساحة عمل' : 'Real Estate / Workspace Request',
            contactName: data.name,
            email: data.email || 'not-provided@businesspartner.sa',
            phone: data.phone,
            message: summaryLines,
            lang: data.lang,
            source: 'businesspartner.sa/real-estate',
            timestamp: new Date().toISOString(),
          }),
        });

        if (response.ok) {
          const successMsg = lang === 'ar'
            ? 'تم إرسال طلبك بنجاح! سنتواصل معك قريبًا بأنسب الفرص المتاحة.'
            : 'Your request has been submitted! We will contact you soon with the best matching opportunities.';
          showResult(successMsg, 'success');
          form.reset();
        } else {
          throw new Error(`HTTP ${response.status}`);
        }
      } catch (error) {
        const errorMsg = lang === 'ar'
          ? 'حدث خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى أو التواصل معنا مباشرة عبر واتساب.'
          : 'An error occurred while submitting your request. Please try again or contact us directly via WhatsApp.';
        showResult(errorMsg, 'error');
        console.error('Error submitting real estate request:', error);
      } finally {
        submitButton.disabled = false;
        submitText.textContent = originalText;
      }
    });
  }
</script>
