{
  "version": "1.0.0",
  "form_title_ar": "بوابة امتثال المنشأة",
  "form_title_en": "Establishment Compliance Portal",
  "consumed_by": ["website form", "n8n WF R71kgwaBNw6WzKFI (webhook)", "WhatsApp intake", "manual admin"],
  "fields": [
    { "name": "client_name", "label_ar": "اسم العميل", "label_en": "Client Name", "type": "text", "required": true },
    { "name": "company_name", "label_ar": "اسم المنشأة", "label_en": "Company Name", "type": "text", "required": true },
    { "name": "cr_number", "label_ar": "رقم السجل التجاري", "label_en": "CR Number", "type": "text", "required": true },
    { "name": "unified_number", "label_ar": "الرقم الموحّد (700)", "label_en": "Unified Number (700)", "type": "text", "required": false },
    { "name": "entity_type", "label_ar": "نوع الكيان", "label_en": "Entity Type", "type": "select", "required": true,
      "options": ["مؤسسة فردية / Establishment", "شركة ذات مسؤولية محدودة / LLC", "شركة مساهمة / JSC", "فرع شركة أجنبية / Foreign branch", "أخرى / Other", "غير معروف / Unknown"] },
    { "name": "authorized_person", "label_ar": "المالك/المفوّض", "label_en": "Owner / Authorized person", "type": "text", "required": true },
    { "name": "mobile", "label_ar": "الجوال / واتساب", "label_en": "Mobile / WhatsApp", "type": "phone", "required": true },
    { "name": "email", "label_ar": "البريد الإلكتروني", "label_en": "Email", "type": "email", "required": true },
    { "name": "investor_type", "label_ar": "نوع المستثمر", "label_en": "Investor Type", "type": "select", "required": true,
      "options": ["سعودي / Saudi", "أجنبي / Foreign", "مختلط / Mixed", "غير معروف / Unknown"] },
    { "name": "business_activity", "label_ar": "النشاط التجاري", "label_en": "Business Activity", "type": "text", "required": true },
    { "name": "sector", "label_ar": "القطاع", "label_en": "Sector", "type": "text", "required": false },
    { "name": "has_employees", "label_ar": "لديك موظفون؟", "label_en": "Has employees?", "type": "select", "required": true, "options": ["نعم / Yes", "لا / No", "غير معروف / Unknown"] },
    { "name": "has_expats", "label_ar": "لديك وافدون؟", "label_en": "Has expats?", "type": "select", "required": true, "options": ["نعم / Yes", "لا / No", "غير معروف / Unknown"] },
    { "name": "has_location", "label_ar": "لديك موقع/مقر؟", "label_en": "Has physical location?", "type": "select", "required": true, "options": ["نعم / Yes", "لا / No", "غير معروف / Unknown"] },
    { "name": "has_import_export", "label_ar": "لديك استيراد/تصدير؟", "label_en": "Has import/export?", "type": "select", "required": true, "options": ["نعم / Yes", "لا / No", "غير معروف / Unknown"] },
    { "name": "has_regulated_products", "label_ar": "لديك منتجات خاضعة للتنظيم؟", "label_en": "Has regulated products?", "type": "select", "required": true, "options": ["نعم / Yes", "لا / No", "غير معروف / Unknown"] },
    { "name": "platforms_used", "label_ar": "المنصات المستخدمة حالياً", "label_en": "Platforms currently used", "type": "multiselect", "required": false,
      "options": ["قوى / Qiwa", "مقيم / Muqeem", "GOSI", "مدد / Mudad", "السجل التجاري / CR", "المركز السعودي للأعمال", "ZATCA", "بلدي / Balady", "الدفاع المدني / Salamah", "إيجار / Ejar", "MISA", "أخرى / Other"] },
    { "name": "documents", "label_ar": "المستندات المرفوعة", "label_en": "Uploaded documents", "type": "file", "multiple": true, "required": false,
      "accept": [".pdf", ".xlsx", ".xls", ".csv", ".png", ".jpg", ".jpeg", ".webp"],
      "hint_ar": "ارفع: السجل، المركز السعودي، قوى، مقيم، GOSI، مدد، ZATCA، الغرفة، العنوان الوطني، الرخصة البلدية، الدفاع المدني، أي مستند داعم.",
      "hint_en": "Upload: CR, Saudi Business Center, Qiwa, Muqeem, GOSI, Mudad, ZATCA, Chamber, National Address, municipal license, Civil Defense, any supporting document." },
    { "name": "urgency", "label_ar": "مستوى الاستعجال", "label_en": "Urgency level", "type": "select", "required": false, "options": ["عادي / Normal", "عاجل / Urgent", "حرج / Critical"] },
    { "name": "notes", "label_ar": "ملاحظات", "label_en": "Notes", "type": "textarea", "required": false },
    { "name": "consent", "label_ar": "أوافق على استخدام بياناتي لتحليل الامتثال فقط، وتُحفظ في مجلد خاص بمنشأتي ولا تُشارك دون موافقتي.", "label_en": "I consent to my data being used for compliance analysis only, stored in my company's private folder, and not shared without my consent.", "type": "checkbox", "required": true }
  ]
}
