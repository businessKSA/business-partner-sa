{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo \"no dependencies\"",
  "buildCommand": "node site/scripts/generate.mjs",
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/blog", "destination": "/saudi-arabia", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
