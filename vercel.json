{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo \"no dependencies\"",
  "buildCommand": "echo \"using committed static site\"",
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/blog", "destination": "/saudi-arabia", "permanent": true },
    { "source": "/business-tourism", "destination": "/tourism", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/ar/portal/index" },
    { "source": "/join", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/ar/portal/join" },
    { "source": "/dashboard", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/ar/portal/dashboard" },
    { "source": "/candidates", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/ar/portal/candidates" },
    { "source": "/en", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/portal/index" },
    { "source": "/en/join", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/portal/join" },
    { "source": "/en/dashboard", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/portal/dashboard" },
    { "source": "/en/candidates", "has": [{ "type": "host", "value": "hr.businesspartner.sa" }], "destination": "/portal/candidates" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "crons": [
    { "path": "/api/newsletter", "schedule": "0 6 * * 0" }
  ]
}
